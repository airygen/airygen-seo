msgid "An unexpected error occurred."
msgstr "ایک غیر متوقع خرابی پیش آئی۔"

#: build/admin/airygen-app.js
msgid "Uninstall"
msgstr "ان انسٹال"

#: build/admin/airygen-app.js
msgid "Choose what data is permanently removed when the plugin is deleted. These actions only run on full uninstall, not on deactivation."
msgstr "منتخب کریں کہ پلگ ان حذف ہونے پر کون سا ڈیٹا مستقل طور پر ہٹایا جائے گا۔ یہ اقدامات صرف مکمل ان انسٹال پر چلتے ہیں، غیر فعال کرنے پر نہیں۔"

#: build/admin/airygen-app.js
msgid "Remove all custom database tables"
msgstr "تمام کسٹم ڈیٹا بیس ٹیبلز ہٹائیں"

#: build/admin/airygen-app.js
msgid "Remove all plugin settings (wp_options)"
msgstr "تمام پلگ ان ترتیبات ہٹائیں (wp_options)"

#: build/admin/airygen-app.js
msgid "Remove all post, term, and user metadata"
msgstr "تمام پوسٹ، ٹرم اور صارف میٹا ڈیٹا ہٹائیں"

#: build/admin/airygen-app.js
msgid "Preferences saved."
msgstr "ترجیحات محفوظ ہو گئیں۔"

#: build/admin/airygen-app.js
msgid "Failed to save preferences."
msgstr "ترجیحات محفوظ کرنے میں ناکامی۔"

