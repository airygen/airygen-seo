msgid "Show blog link on archives"
msgstr "آرکائیوز پر بلاگ لنک دکھائیں"

#: build/admin/airygen-app.js
msgid "Include the Posts page before archive items when a static blog page is set."
msgstr "جب static بلاگ صفحہ سیٹ ہو تو archive آئٹمز سے پہلے Posts صفحہ شامل کریں۔"

#: build/admin/airygen-app.js
msgid "Show ancestor pages"
msgstr "آباؤ اجداد کے صفحات دکھائیں"

#: build/admin/airygen-app.js
msgid "Add parent pages for hierarchical content types (pages, hierarchical CPTs)."
msgstr "درجہ بند content types (pages، hierarchical CPTs) کے لیے parent pages شامل کریں۔"

#: build/admin/airygen-app.js
msgid "Hide taxonomy parents"
msgstr "taxonomy parents چھپائیں"

#: build/admin/airygen-app.js
msgid "Skip parent terms in category/tag hierarchies to keep the trail compact."
msgstr "trail مختصر رکھنے کے لیے زمرہ/ٹیگ درجہ بندیوں میں parent terms چھوڑیں۔"

#: build/admin/airygen-app.js
msgid "Labels"
msgstr "لیبلز"

#: build/admin/airygen-app.js
msgid "Customize how archives, search results, and 404 pages appear in the trail."
msgstr "trail میں آرکائیوز، سرچ نتائج اور 404 صفحات کیسے ظاہر ہوں کسٹمائز کریں۔"

#: build/admin/airygen-app.js
msgid "Home label"
msgstr "ہوم لیبل"

#: build/admin/airygen-app.js
msgid "Label used for the homepage breadcrumb."
msgstr "ہوم پیج breadcrumb کے لیے استعمال ہونے والا لیبل۔"

#: build/admin/airygen-app.js
msgid "Archive label"
msgstr "آرکائیو لیبل"

#: build/admin/airygen-app.js
msgid "Used for archive pages (category, tag, taxonomy, post type archives)."
msgstr "آرکائیو صفحات کے لیے استعمال (زمرہ، ٹیگ، taxonomy، post قسم آرکائیوز)۔"

#: build/admin/airygen-app.js
msgid "Search results label"
msgstr "سرچ نتائج لیبل"

#: build/admin/airygen-app.js
msgid "Shown when viewing the search results page."
msgstr "سرچ نتائج صفحہ دیکھتے وقت دکھایا گیا۔"

#. translators: %s is an HTTP status code and should remain numeric, e.g. 404.
#: build/admin/airygen-app.js
#, js-format
msgid "%s label"
msgstr "%s لیبل"

#: build/admin/airygen-app.js
msgid "Shown for not found pages (404 responses)."
msgstr "نہ ملنے والے صفحات کے لیے دکھایا گیا (404 جواب)۔"

#: build/admin/airygen-app.js
msgid "Social Media Tags"
msgstr "سوشل میڈیا Tags"

#: build/admin/airygen-app.js
msgid "Provide defaults for social share images and Twitter handles when per-post values are missing."
msgstr "جب فی post قدریں غائب ہوں تو سوشل شیئر تصاویر اور Twitter handles کے لیے ڈیفالٹس فراہم کریں۔"

#: build/admin/airygen-app.js
msgid "Open Graph"
msgstr "Open Graph"

#: build/admin/airygen-app.js
msgid "Enable Open Graph"
msgstr "Open Graph فعال کریں"

#: build/admin/airygen-app.js
msgid "When off, the site outputs no og:* tags. Threads and LinkedIn also rely on Open Graph, so their link previews will be affected."
msgstr "آف ہونے پر سائٹ کوئی og:* tags آؤٹ پٹ نہیں کرتی۔ Threads اور LinkedIn بھی Open Graph پر انحصار کرتے ہیں، اس لیے ان کے لنک پیش منظر متاثر ہوں گے۔"

#: build/admin/airygen-app.js
msgid "Default image — URL"
msgstr "ڈیفالٹ تصویر — URL"

#: build/admin/airygen-app.js
msgid "Default image — Attachment ID"
msgstr "ڈیفالٹ تصویر — Attachment ID"

#: build/admin/airygen-app.js
msgid "Select an image from the Media Library. If both URL and ID are set, the Attachment ID takes precedence. Set to 0 to disable."
msgstr "میڈیا لائبریری سے تصویر منتخب کریں۔ اگر URL اور ID دونوں سیٹ ہوں تو Attachment ID کو ترجیح ملتی ہے۔ غیر فعال کرنے کے لیے 0 پر سیٹ کریں۔"

#: build/admin/airygen-app.js
msgid "Publisher URL"
msgstr "ناشر URL"

#: build/admin/airygen-app.js
msgid "Optional canonical publisher page for social networks."
msgstr "سوشل نیٹ ورکس کے لیے اختیاری canonical ناشر صفحہ۔"

#: build/admin/airygen-app.js
msgid "Optional width to help caching. Suggested value: 1200."
msgstr "کیشنگ میں مدد کے لیے اختیاری چوڑائی۔ تجویز کردہ قدر: 1200۔"

#: build/admin/airygen-app.js
msgid "Optional height to help caching. Suggested value: 630."
msgstr "کیشنگ میں مدد کے لیے اختیاری اونچائی۔ تجویز کردہ قدر: 630۔"

#: build/admin/airygen-app.js
msgid "Domain verification"
msgstr "Domain تصدیق"

#: build/admin/airygen-app.js
msgid "Paste the Meta (Facebook/Instagram) Business Manager verification token to prove domain ownership. This helps Meta trust your og: tags and unlocks domain insights."
msgstr "domain ملکیت ثابت کرنے کے لیے Meta (Facebook/Instagram) Business Manager تصدیق ٹوکن پیسٹ کریں۔ یہ Meta کو آپ کے og: tags پر اعتماد کرنے اور domain insights کھولنے میں مدد دیتا ہے۔"

#: build/admin/airygen-app.js
msgid "Connect your Facebook App for advanced analytics and verification."
msgstr "اعلیٰ تجزیات اور تصدیق کے لیے اپنی Facebook ایپ جوڑیں۔"

#: build/admin/airygen-app.js
msgid "Comma-separated Facebook admin IDs so those accounts can access Page Insights for your domain. IDs are visible in page source, so only add them if you are fine with that exposure."
msgstr "کوما سے جدا Facebook ایڈمن IDs تاکہ وہ اکاؤنٹس آپ کے domain کے لیے Page Insights تک رسائی حاصل کر سکیں۔ IDs صفحہ کے سورس میں نظر آتی ہیں، اس لیے صرف اسی صورت شامل کریں جب آپ اس عوام کاری سے مطمئن ہوں۔"

#: build/admin/airygen-app.js
msgid "Twitter"
msgstr "Twitter"

#: build/admin/airygen-app.js
msgid "Enable Twitter Cards"
msgstr "Twitter Cards فعال کریں"

#: build/admin/airygen-app.js
msgid "When off, the site outputs no twitter:* tags."
msgstr "آف ہونے پر سائٹ کوئی twitter:* tags آؤٹ پٹ نہیں کرتی۔"

#: build/admin/airygen-app.js
msgid "Default card type"
msgstr "ڈیفالٹ کارڈ کی قسم"

#. translators: 1: HTML code tag for summary_large_image, 2: HTML code tag for summary.
#: build/admin/airygen-app.js
msgid "Twitter site handle"
msgstr "Twitter site handle"

#: build/admin/airygen-app.js
msgid "Brand account. Enter with or without @. Will be normalized on save."
msgstr "برانڈ اکاؤنٹ۔ @ کے ساتھ یا بغیر درج کریں۔ محفوظ کرنے پر معیاری شکل میں آ جائے گا۔"

#: build/admin/airygen-app.js
msgid "Twitter creator handle"
msgstr "Twitter creator handle"

#: build/admin/airygen-app.js
msgid "Author/creator account. Enter with or without @. Will be normalized on save."
msgstr "مصنف/تخلیق کار اکاؤنٹ۔ @ کے ساتھ یا بغیر درج کریں۔ محفوظ کرنے پر نارملائز کر دیا جائے گا۔"

#: build/admin/airygen-app.js
msgid "Inherit Open Graph image"
msgstr "Open Graph تصویر وراثت لیں"

#: build/admin/airygen-app.js
msgid "Always use the Open Graph image for Twitter cards when available. When it is missing, Twitter falls back to no image."
msgstr "جب دستیاب ہو تو Twitter cards کے لیے ہمیشہ Open Graph image استعمال کریں۔ اگر یہ موجود نہ ہو تو Twitter بغیر تصویر کے fallback کرتا ہے۔"

