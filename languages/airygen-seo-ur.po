msgid "Show current page"
msgstr "موجودہ صفحہ دکھائیں"

#: build/admin/airygen-app.js
msgid "Include the current page as the final breadcrumb (also affects the JSON-LD breadcrumb list)."
msgstr "موجودہ صفحہ کو آخری breadcrumb کے طور پر شامل کریں (JSON-LD breadcrumb فہرست کو بھی متاثر کرتا ہے)۔"

#: build/admin/airygen-app.js
msgid "Show pagination"
msgstr "صفحہ بندی دکھائیں"

#: build/admin/airygen-app.js
msgid "Append the current page number when viewing paged archives (hidden from schema by default)."
msgstr "paged archives دیکھتے وقت موجودہ صفحہ نمبر شامل کریں (بطور ڈیفالٹ schema سے مخفی)۔"

#: build/admin/airygen-app.js
msgid "Shown between each breadcrumb item."
msgstr "ہر breadcrumb آئٹم کے درمیان دکھایا گیا۔"

#: build/admin/airygen-app.js
msgid "Prefix"
msgstr "سابقہ"

#: build/admin/airygen-app.js
msgid "Text shown before the breadcrumb trail (e.g., \"You are here\")."
msgstr "breadcrumb trail سے پہلے دکھایا جانے والا متن (جیسے \"آپ یہاں ہیں\")۔"

