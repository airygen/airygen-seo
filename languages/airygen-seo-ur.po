#: build/admin/airygen-app.js
#, js-format
msgid "%s is the link placeholder and must appear exactly once."
msgstr "%s لنک کا پلیس ہولڈر ہے اور اسے صرف ایک بار ظاہر ہونا چاہیے۔"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "Shown above the main series links. Do not include %s in this description."
msgstr "مرکزی سیریز لنکس کے اوپر دکھایا گیا۔ اس تفصیل میں %s شامل نہ کریں۔"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L3 relation link description must contain exactly one %s."
msgstr "L3 تعلق لنک تفصیل میں بالکل ایک %s ہونا چاہیے۔"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L2 relation link description must contain exactly one %s."
msgstr "L2 تعلق لنک تفصیل میں بالکل ایک %s ہونا چاہیے۔"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L1 relation link description must not contain %s."
msgstr "L1 تعلق لنک تفصیل میں %s شامل نہیں ہونا چاہیے۔"

#: build/admin/airygen-app.js
msgid "Relation link descriptions"
msgstr "تعلق لنک تفصیلات"

#: build/admin/airygen-app.js
msgid "Customize the descriptions shown before related Topic Cluster links in L1, L2, and L3 articles."
msgstr "L1، L2 اور L3 مضامین میں متعلقہ ٹاپک کلسٹر لنکس سے پہلے دکھائی جانے والی تفصیلات کو اپنی مرضی کے مطابق بنائیں۔"

#: build/admin/airygen-app.js
msgid "Does your website represent a business with a physical location?"
msgstr "کیا آپ کی ویب سائٹ کسی ایسے کاروبار کی نمائندگی کرتی ہے جس کا کوئی جسمانی مقام ہو؟"

#: build/admin/airygen-app.js
msgid "For example, a restaurant, clinic, law firm, gym, or retail store."
msgstr "مثال کے طور پر، ایک ریستوران، کلینک، قانونی فرم، جم، یا ریٹیل اسٹور۔"

#: build/admin/airygen-app.js
msgid "Adds LocalBusiness schema to your site so Google can show your address, phone number, and opening hours in local search results and Maps — making it easier for nearby customers to find you."
msgstr "آپ کی سائٹ میں LocalBusiness schema شامل کرتا ہے تاکہ Google مقامی سرچ نتائج اور Maps میں آپ کا پتہ، فون نمبر اور کھلنے کے اوقات دکھا سکے — جس سے قریبی گاہکوں کے لیے آپ کو تلاش کرنا آسان ہو جاتا ہے۔"

#: build/admin/airygen-app.js
msgid "Alongside local data, also outputs Organization and WebSite schema to help Google better understand your brand."
msgstr "مقامی ڈیٹا کے ساتھ، Organization اور WebSite schema بھی آؤٹ پٹ کرتا ہے تاکہ Google آپ کے برانڈ کو بہتر طور پر سمجھ سکے۔"

#: build/admin/airygen-app.js
msgid "Does your website sell products or services online?"
msgstr "کیا آپ کی ویب سائٹ آن لائن مصنوعات یا خدمات فروخت کرتی ہے؟"

#: build/admin/airygen-app.js
msgid "For example, a WooCommerce store or any site with a shopping cart."
msgstr "مثال کے طور پر، ایک WooCommerce اسٹور یا کوئی بھی سائٹ جس میں شاپنگ کارٹ ہو۔"

#: build/admin/airygen-app.js
msgid "Automatically generates Product schema for every product page so Google can display price, stock status, and star ratings directly in search results."
msgstr "ہر پروڈکٹ صفحے کے لیے خود بخود Product schema بناتا ہے تاکہ Google سرچ نتائج میں براہ راست قیمت، اسٹاک کی صورت حال اور اسٹار ریٹنگز دکھا سکے۔"

#: build/admin/airygen-app.js
msgid "Adds site-level Organization schema to help Google identify your brand and store."
msgstr "سائٹ کی سطح پر Organization schema شامل کرتا ہے تاکہ Google آپ کے برانڈ اور اسٹور کو پہچان سکے۔"

#: build/admin/airygen-app.js
msgid "Does your site have multiple language versions or serve users in different countries?"
msgstr "کیا آپ کی سائٹ کے متعدد زبانوں کے ورژن ہیں یا مختلف ممالک میں صارفین کی خدمت کرتی ہے؟"

#: build/admin/airygen-app.js
msgid "For example, separate English and Spanish versions, or different URLs targeting different regions."
msgstr "مثال کے طور پر، الگ انگریزی اور ہسپانوی ورژن، یا مختلف علاقوں کو ہدف بنانے والے مختلف URLs۔"

#: build/admin/airygen-app.js
msgid "Hreflang"
msgstr "Hreflang"

#: build/admin/airygen-app.js
msgid "Automatically adds hreflang tags to every page so Google serves the right language version to the right audience, preventing different variants from competing with each other in search rankings."
msgstr "ہر صفحے میں خود بخود hreflang ٹیگز شامل کرتا ہے تاکہ Google صحیح زبان کا ورژن صحیح سامعین کو دکھائے اور مختلف ویریئنٹس کو سرچ رینکنگ میں ایک دوسرے سے مقابلہ کرنے سے روکے۔"

#: build/admin/airygen-app.js
msgid "Do you want links to your site to display a rich preview when shared on social media?"
msgstr "کیا آپ چاہتے ہیں کہ سوشل میڈیا پر شیئر کیے جانے پر آپ کی سائٹ کے لنکس بھرپور پیش نظارہ دکھائیں؟"

#: build/admin/airygen-app.js
msgid "Social Cards"
msgstr "سوشل کارڈز"

#: build/admin/airygen-app.js
msgid "Automatically generates Open Graph and Twitter Card meta tags for every post so shared links display your chosen image and title instead of letting platforms pick a random one."
msgstr "ہر پوسٹ کے لیے خود بخود Open Graph اور Twitter Card میٹا ٹیگز بناتا ہے تاکہ شیئر کیے گئے لنکس آپ کی منتخب تصویر اور عنوان دکھائیں بجائے اس کے کہ پلیٹ فارمز کوئی بھی چنیں۔"

#: build/admin/airygen-app.js
msgid "Does your site publish long-form articles, tutorials, or in-depth knowledge content?"
msgstr "کیا آپ کی سائٹ طویل مضامین، ٹیوٹوریلز یا گہرائی سے علمی مواد شائع کرتی ہے؟"

#: build/admin/airygen-app.js
msgid "For example, a blog, technical documentation site, or educational platform."
msgstr "مثال کے طور پر، ایک بلاگ، تکنیکی دستاویزی سائٹ، یا تعلیمی پلیٹ فارم۔"

#: build/admin/airygen-app.js
msgid "Automatically generates a table of contents at the top of long posts so readers can jump straight to any section. Google sometimes surfaces TOC links directly in search results."
msgstr "طویل پوسٹس کے اوپر خود بخود فہرست مضامین بناتا ہے تاکہ قارئین کسی بھی سیکشن میں براہ راست جا سکیں۔ Google کبھی کبھی TOC لنکس کو سرچ نتائج میں براہ راست دکھاتا ہے۔"

#: build/admin/airygen-app.js
msgid "Recommends related posts at the bottom of each article based on categories and tags, keeping readers engaged and reducing bounce rate."
msgstr "زمروں اور ٹیگز کی بنیاد پر ہر مضمون کے آخر میں متعلقہ پوسٹس تجویز کرتا ہے، قارئین کو مصروف رکھتا ہے اور باؤنس ریٹ کم کرتا ہے۔"

#: build/admin/airygen-app.js
msgid "Helps you manage a topic cluster structure (pillar → cluster → supporting articles) and automatically renders a topic navigation block within posts, making it easy for readers to explore related content while signaling topical depth to Google."
msgstr "آپ کو موضوع کلسٹر کی ساخت (پلر ← کلسٹر ← معاون مضامین) منظم کرنے میں مدد کرتا ہے اور پوسٹس کے اندر خود بخود ایک موضوع نیویگیشن بلاک پیش کرتا ہے، جس سے قارئین کے لیے متعلقہ مواد دریافت کرنا آسان ہو جاتا ہے جبکہ Google کو موضوعاتی گہرائی کا اشارہ دیتا ہے۔"

#: build/admin/airygen-app.js
msgid "Does your site have multiple authors or use many categories and tags to organize content?"
msgstr "کیا آپ کی سائٹ میں متعدد مصنفین ہیں یا مواد منظم کرنے کے لیے بہت سی زمرے اور ٹیگز استعمال ہوتے ہیں؟"

#: build/admin/airygen-app.js
msgid "Generates Person schema for every author page to establish authorship identity and strengthen the E-E-A-T signals Google increasingly factors into rankings."
msgstr "مصنف کی شناخت قائم کرنے اور E-E-A-T سگنلز کو مضبوط کرنے کے لیے ہر مصنف کے صفحے کے لیے Person schema بناتا ہے جنہیں Google رینکنگ میں بڑھتے ہوئے شامل کرتا ہے۔"

#: build/admin/airygen-app.js
msgid "Lets you customize meta titles and descriptions for taxonomy archive pages and control which ones Google should index, preventing SEO authority from being diluted across low-value pages."
msgstr "آپ کو taxonomy آرکائیو صفحات کے لیے میٹا عنوانات اور تفصیلات کسٹمائز کرنے اور یہ کنٹرول کرنے دیتا ہے کہ Google کن کو انڈیکس کرے، جس سے کم قیمت صفحات میں SEO اختیار کو پھیلنے سے روکتا ہے۔"

#: build/admin/airygen-app.js
msgid "Has your site ever changed its URL structure, or do you know some links lead to 404 pages?"
msgstr "کیا آپ کی سائٹ نے کبھی اپنی URL ساخت تبدیل کی ہے، یا کیا آپ جانتے ہیں کہ کچھ لنکس 404 صفحات تک لے جاتے ہیں؟"

#: build/admin/airygen-app.js
msgid "Set up 301/302 redirects to seamlessly transfer traffic and SEO ranking power from old URLs to new ones so your hard-earned rankings are never lost."
msgstr "301/302 ری ڈائریکٹس ترتیب دیں تاکہ پرانے URLs سے نئے URLsمیں ٹریفک اور SEO رینکنگ کی طاقت بے رکاوٹ منتقل ہو اور آپ کی محنت سے کمائی ہوئی رینکنگ کبھی ضائع نہ ہو۔"

#: build/admin/airygen-app.js
msgid "404 Manager"
msgstr "404 Manager"

#: build/admin/airygen-app.js
msgid "Automatically logs every 404 visit so you can see at a glance which broken links need fixing, and set up redirects directly from the interface."
msgstr "ہر 404 وزٹ کو خود بخود لاگ کرتا ہے تاکہ آپ ایک نظر میں دیکھ سکیں کہ کون سے ٹوٹے ہوئے لنکس کو ٹھیک کرنا ہے، اور انٹرفیس سے براہ راست ری ڈائریکٹس ترتیب دیں۔"

#: build/admin/airygen-app.js
msgid "Actively crawls your entire site to surface all broken internal and external links before Google finds them and uses them against your rankings."
msgstr "آپ کی پوری سائٹ کو فعال طور پر کرال کرتا ہے تاکہ تمام ٹوٹے ہوئے اندرونی اور بیرونی لنک Google کے انہیں دریافت کرنے اور آپ کی رینکنگ کے خلاف استعمال کرنے سے پہلے سامنے آ جائیں۔"

#: build/admin/airygen-app.js
msgid "Would you like search engines to index your new and updated content immediately after publishing?"
msgstr "کیا آپ چاہتے ہیں کہ سرچ انجن آپ کے نئے اور اپڈیٹ شدہ مواد کو شائع کرنے کے فوری بعد انڈیکس کریں؟"

#: build/admin/airygen-app.js
msgid "Uses the IndexNow protocol to push new and updated URLs to Bing and other supported search engines the moment content is published or changed — no waiting for crawlers. Especially valuable for news sites and time-sensitive content."
msgstr "IndexNow پروٹوکول استعمال کرتا ہے تاکہ مواد شائع یا تبدیل ہونے کے فوری بعد نئے اور اپڈیٹ شدہ URLs کو Bing اور دیگر سپورٹ شدہ سرچ انجنوں کو بھیجے — کرالرز کا انتظار نہیں۔ خبروں کی سائٹس اور وقت سے حساس مواد کے لیے خاص طور پر قیمتی۔"

#: build/admin/airygen-app.js
msgid "Would you like AI to help you write article outlines, FAQ sets, or plan your full content strategy?"
msgstr "کیا آپ چاہتے ہیں کہ AI آپ کو مضمون کے خاکے، FAQ سیٹ لکھنے یا اپنی مکمل مواد حکمت عملی بنانے میں مدد کرے؟"

#: build/admin/airygen-app.js
msgid "A smart AI toolkit that generates article outlines, Content Blueprints, full Article drafts, and Deep FAQ sets from a keyword — making content creation faster and easier."
msgstr "ایک ذہین AI ٹول کٹ جو کسی کلیدی لفظ سے مضمون کے خاکے، Content Blueprints، مکمل مضمون کے مسودے اور Deep FAQ سیٹ تیار کرتی ہے — جس سے مواد بنانا تیز اور آسان ہو جاتا ہے۔"

#: build/admin/airygen-app.js
msgid "Would you like AI tools like ChatGPT and Perplexity to more easily discover and cite your site?"
msgstr "کیا آپ چاہتے ہیں کہ ChatGPT اور Perplexity جیسے AI ٹولز آپ کی سائٹ کو زیادہ آسانی سے دریافت اور حوالہ دے سکیں؟"

#: build/admin/airygen-app.js
msgid "AI search is changing how people find information — make sure your site is visible in the AI era."
msgstr "AI سرچ لوگوں کے معلومات تلاش کرنے کے طریقے کو بدل رہی ہے — یقینی بنائیں کہ آپ کی سائٹ AI دور میں نظر آتی ہے۔"

#: build/admin/airygen-app.js
msgid "Automatically generates an llms.txt file — like a sitemap for AI — so tools like ChatGPT and Perplexity know what content on your site is available to cite."
msgstr "خود بخود ایک llms.txt فائل بناتا ہے — AI کے لیے سائٹ میپ کی طرح — تاکہ ChatGPT اور Perplexity جیسے ٹولز جانیں کہ آپ کی سائٹ پر حوالہ دینے کے لیے کون سا مواد دستیاب ہے۔"

#: build/admin/airygen-app.js
msgid "Automatically converts your posts into AI-friendly Markdown so AI agents can read and understand your content without struggling to parse HTML."
msgstr "آپ کی پوسٹس کو خود بخود AI دوستانہ Markdown میں تبدیل کرتا ہے تاکہ AI ایجنٹ HTML پارس کرنے کی مشکل کے بغیر آپ کا مواد پڑھ اور سمجھ سکیں۔"

#: build/admin/airygen-app.js
msgid "Includes Deep FAQ, which automatically generates structured Q&A from your post content. AI search engines favor content that directly answers questions, boosting your visibility in AI-powered search results."
msgstr "Deep FAQ شامل ہے، جو آپ کی پوسٹ کے مواد سے خود بخود منظم سوال و جواب بناتا ہے۔ AI سرچ انجنز ایسے مواد کو ترجیح دیتے ہیں جو سوالات کا براہ راست جواب دیتا ہے، جس سے AI سے چلنے والے سرچ نتائج میں آپ کی نمائش بڑھتی ہے۔"

#: build/admin/airygen-app.js
msgid "Free"
msgstr "مفت"

#: build/admin/airygen-app.js
msgid "Requires a plan upgrade"
msgstr "پلان اپگریڈ ضروری ہے"

#: build/admin/airygen-app.js
msgid "Requires"
msgstr "ضروری ہے"

#: build/admin/airygen-app.js
msgid "plan to activate"
msgstr "فعال کرنے کا پلان"

#: build/admin/airygen-app.js
msgid "Got it, don't show again"
msgstr "سمجھ گیا، دوبارہ نہ دکھائیں"

#: build/admin/airygen-app.js
msgid "← Back"
msgstr "واپس →"

#: build/admin/airygen-app.js
msgid "Get started →"
msgstr "← شروع کریں"

#: build/admin/airygen-app.js
msgid "Next →"
msgstr "← اگلا"

#: build/admin/airygen-app.js
msgid "Apply & finish"
msgstr "لاگو کریں اور ختم کریں"

#: build/admin/airygen-app.js
msgid "Welcome to Airygen SEO!"
msgstr "Airygen SEO میں خوش آمدید!"

#: build/admin/airygen-app.js
msgid "Answer 10 quick questions and we'll recommend the right SEO modules for your site — then enable them all with one click."
msgstr "10 فوری سوالوں کے جواب دیں اور ہم آپ کی سائٹ کے لیے صحیح SEO ماڈیولز تجویز کریں گے — پھر انہیں ایک کلک سے فعال کریں۔"

#: build/admin/airygen-app.js
msgid "Don't worry — every question is just Yes or No. No technical knowledge needed. It takes about 2 minutes. 😊"
msgstr "فکر نہ کریں — ہر سوال صرف ہاں یا نہیں ہے۔ کوئی تکنیکی معلومات درکار نہیں۔ اس میں تقریباً 2 منٹ لگتے ہیں۔ 😊"

#: build/admin/airygen-app.js
msgid "🎉 All done! Here's what we recommend based on your answers:"
msgstr "🎉 سب ہو گیا! آپ کے جوابات کی بنیاد پر ہم یہ تجویز کرتے ہیں:"

#: build/admin/airygen-app.js
msgid "Will be enabled (included in your plan)"
msgstr "فعال کیا جائے گا (آپ کے پلان میں شامل)"

#: build/admin/airygen-app.js
msgid "Requires an upgrade to enable"
msgstr "فعال کرنے کے لیے اپگریڈ ضروری ہے"

#: build/admin/airygen-app.js
msgid "Upgrade to"
msgstr "اپگریڈ کریں"

#: build/admin/airygen-app.js
msgid "No modules selected. Click Finish to close the wizard."
msgstr "کوئی ماڈیول منتخب نہیں ہوا۔ وزرڈ بند کرنے کے لیے ختم کریں پر کلک کریں۔"

#: build/admin/airygen-app.js
msgid "Setup Wizard"
msgstr "سیٹ اپ وزرڈ"

#: build/admin/airygen-app.js
msgid "Drop blocks here"
msgstr "یہاں بلاکس چھوڑیں"

#: build/admin/airygen-app.js
msgid "Two ways to open settings"
msgstr "ترتیبات کھولنے کے دو طریقے"

#: build/admin/airygen-app.js
msgid "Click \"Open global settings\" here, or use Settings in the top navigation bar — both take you to the same settings page."
msgstr "یہاں \"عمومی ترتیبات کھولیں\" پر کلک کریں، یا اوپر کے نیویگیشن بار میں Settings استعمال کریں — دونوں آپ کو ایک ہی ترتیبات کے صفحے پر لے جاتے ہیں۔"

#: build/admin/airygen-app.js
msgid "Drag modules to reorder"
msgstr "دوبارہ ترتیب دینے کے لیے ماڈیولز گھسیٹیں"

#: build/admin/airygen-app.js
msgid "Drag any module card to rearrange them. The Settings menu bar reflects this exact order — put your most-used modules up front."
msgstr "انہیں دوبارہ ترتیب دینے کے لیے کوئی بھی ماڈیول کارڈ گھسیٹیں۔ Settings مینو بار بالکل اسی ترتیب کی عکاسی کرتا ہے — سب سے زیادہ استعمال ہونے والے ماڈیولز کو آگے رکھیں۔"

#: build/admin/airygen-app.js
msgid "Control editor panel order"
msgstr "ایڈیٹر پینل کی ترتیب کنٹرول کریں"

#: build/admin/airygen-app.js
msgid "Drag these panel cards to set the display order of sidebar panels shown in the post editor. The order here is the order there."
msgstr "پوسٹ ایڈیٹر میں دکھائے گئے سائڈبار پینلز کی ڈسپلے ترتیب سیٹ کرنے کے لیے یہ پینل کارڈز گھسیٹیں۔ یہاں کی ترتیب وہاں کی ترتیب ہے۔"

#: build/admin/airygen-app.js
msgid "Skip tour"
msgstr "ٹور چھوڑیں"

#: build/admin/airygen-app.js
msgid "Done"
msgstr "مکمل"

#: build/admin/airygen-app.js
msgid "In-Article Content Order"
msgstr "مضمون کے اندر مواد کی ترتیب"

#: build/admin/airygen-app.js
msgid "Drag content blocks between zones to control where they appear, and reorder within each zone to set their stacking sequence."
msgstr "مواد کے بلاکس کو زونز کے درمیان گھسیٹیں تاکہ کنٹرول کر سکیں وہ کہاں ظاہر ہوں، اور ان کی اسٹیکنگ ترتیب سیٹ کرنے کے لیے ہر زون میں دوبارہ ترتیب دیں۔"

#: build/admin/airygen-app.js
msgid "Gap between blocks (px)"
msgstr "بلاکس کے درمیان فاصلہ (px)"

#: build/admin/airygen-app.js
msgid "Content top margin (px)"
msgstr "مواد کا اوپری مارجن (px)"

#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "The focus keyphrase is the main keyword or phrase this post is optimized for. AI modules use it to guide content generation — keeping the output relevant and keyword-focused."
msgstr "فوکس کلیدی جملہ وہ مرکزی لفظ یا جملہ ہے جس کے لیے یہ پوسٹ بہتر بنائی گئی ہے۔ AI ماڈیولز اسے مواد تخلیق رہنمائی کے لیے استعمال کرتے ہیں — آؤٹ پٹ کو متعلقہ اور کلیدی لفظ مرکوز رکھتے ہوئے۔"

#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Focus keyphrase help"
msgstr "فوکس کلیدی جملے کی مدد"
