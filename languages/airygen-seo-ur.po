#: build/admin/airygen-app.js
msgid "Scan content for broken and redirected links, and monitor crawl health."
msgstr "ٹوٹے اور redirect شدہ لنکس کے لیے مواد اسکین کریں اور crawl صحت کی نگرانی کریں۔"

#: build/admin/airygen-app.js
msgid "Link Counter must be enabled to gather internal link data."
msgstr "اندرونی لنک ڈیٹا جمع کرنے کے لیے Link Counter فعال ہونا چاہیے۔"

#: build/admin/airygen-app.js
msgid "Tune scan frequency and limits. Lower numbers are safer on shared hosts."
msgstr "اسکین تعدد اور حدیں ٹھیک کریں۔ مشترکہ hosts پر کم تعداد محفوظ ہے۔"

#: build/admin/airygen-app.js
msgid "How often the scanner runs. Set higher on large sites."
msgstr "اسکینر کتنی بار چلے۔ بڑی سائٹس پر زیادہ سیٹ کریں۔"

#: build/admin/airygen-app.js
msgid "Max requests per run"
msgstr "فی چلانے زیادہ سے زیادہ درخواستیں"

#: build/admin/airygen-app.js
msgid "Limits simultaneous HTTP requests during a scan."
msgstr "اسکین کے دوران بیک وقت HTTP درخواستیں محدود کرتا ہے۔"

#: build/admin/airygen-app.js
msgid "Pause between request batches to reduce load."
msgstr "لوڈ کم کرنے کے لیے درخواست بیچوں کے درمیان توقف۔"

#: build/admin/airygen-app.js
msgid "Older log entries are deleted automatically."
msgstr "پرانے لاگ اندراجات خودکار حذف ہو جاتے ہیں۔"

#: build/admin/airygen-app.js
msgid "Max time to open a connection before aborting."
msgstr "ختم کرنے سے پہلے کنکشن کھولنے کا زیادہ سے زیادہ وقت۔"

#: build/admin/airygen-app.js
msgid "Max time to complete a request before aborting."
msgstr "ختم کرنے سے پہلے درخواست مکمل کرنے کا زیادہ سے زیادہ وقت۔"

#: build/admin/airygen-app.js
msgid "Treat redirects as warnings"
msgstr "redirects کو انتباہ سمجھیں"

#: build/admin/airygen-app.js
msgid "When on, redirected links are flagged but not counted as errors."
msgstr "آن ہونے پر redirect شدہ لنکس نشان زد ہوتے ہیں لیکن غلطیوں میں شمار نہیں ہوتے۔"

#: build/admin/airygen-app.js
msgid "Choose which link types are included in broken-link scans."
msgstr "ٹوٹے ہوئے لنک اسکینز میں کون سی لنک اقسام شامل ہوں منتخب کریں۔"

#: build/admin/airygen-app.js
msgid "Link types to scan"
msgstr "اسکین کرنے کے لیے لنک اقسام"

#: build/admin/airygen-app.js
msgid "External"
msgstr "بیرونی"

#: build/admin/airygen-app.js
msgid "Internal"
msgstr "اندرونی"

#: build/admin/airygen-app.js
msgid "Shows current background job status for Broken Link Checker scans."
msgstr "Broken Link Checker اسکینز کے لیے موجودہ پس منظر کام کی حیثیت دکھاتا ہے۔"

#: build/admin/airygen-app.js
msgid "Link log"
msgstr "لنک لاگ"

#: build/admin/airygen-app.js
msgid "Review recent link checks and jump to affected posts."
msgstr "حالیہ لنک جانچیں دیکھیں اور متاثرہ posts پر جائیں۔"

#: build/admin/airygen-app.js
msgid "Filters"
msgstr "فلٹرز"

#: build/admin/airygen-app.js
msgid "Toggle which statuses appear in the log."
msgstr "ٹوگل کریں کہ لاگ میں کون سی حیثیتیں ظاہر ہوں۔"

#: build/admin/airygen-app.js
msgid "OK"
msgstr "ٹھیک ہے"

#: build/admin/airygen-app.js
msgid "Redirect"
msgstr "Redirect"

#: build/admin/airygen-app.js
msgid "URL"
msgstr "URL"

#: build/admin/airygen-app.js
msgid "Checked at"
msgstr "چیک کیا گیا:"

#: build/admin/airygen-app.js
msgid "Edit post"
msgstr "post ترمیم کریں"

#: build/admin/airygen-app.js
msgid "View post"
msgstr "post دیکھیں"

#: build/admin/airygen-app.js
msgid "Open link"
msgstr "لنک کھولیں"

#: build/admin/airygen-app.js
msgid "pts"
msgstr "پوائنٹس"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Your SEO title should be long enough to explain the topic, but short enough to avoid truncation."
msgstr "آپ کا SEO عنوان موضوع سمجھانے کے لیے کافی لمبا ہونا چاہیے، لیکن کٹنے سے بچنے کے لیے کافی چھوٹا۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Aim for about 50–60 characters. Front-load the most important words."
msgstr "تقریباً 50–60 حروف کا ہدف رکھیں۔ سب سے اہم الفاظ شروع میں رکھیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear, visible titles improve click-through rate from search results."
msgstr "واضح اور نظر آنے والے عنوانات سرچ نتائج سے کلک ریٹ بہتر کرتے ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Search engines expect the primary topic to appear in the title."
msgstr "سرچ انجنز توقع کرتے ہیں کہ مرکزی موضوع عنوان میں ظاہر ہو۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Include your focus keyphrase naturally near the start of the title."
msgstr "عنوان کے شروع کے قریب قدرتی طور پر فوکس keyphrase شامل کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves topical relevance and makes the result more recognizable."
msgstr "موضوعاتی ربط بہتر کرتا ہے اور نتیجے کو زیادہ قابلِ شناخت بناتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "A meta description helps search engines and users understand the page."
msgstr "ایک meta description سرچ انجنز اور صارفین کو صفحہ سمجھنے میں مدد دیتی ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Write 1–2 sentences that summarize the page and invite a click."
msgstr "1–2 جملے لکھیں جو صفحے کا خلاصہ کریں اور کلک کی دعوت دیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Better snippets can lift click-through rate even if rankings stay the same."
msgstr "بہتر snippets کلک ریٹ بڑھا سکتے ہیں چاہے رینکنگ ویسی ہی رہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Descriptions that are too short or too long get cut off in results."
msgstr "بہت چھوٹی یا بہت لمبی وضاحتیں نتائج میں کٹ جاتی ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep it roughly 140–160 characters and prioritize the main benefit."
msgstr "اسے تقریباً 140–160 حروف رکھیں اور مرکزی فائدے کو ترجیح دیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Full snippets look more professional and improve engagement."
msgstr "مکمل snippets زیادہ پیشہ ورانہ لگتے ہیں اور مشغولیت بہتر کرتے ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the focus phrase helps confirm the page topic."
msgstr "فوکس جملہ شامل کرنا صفحہ موضوع کی تصدیق میں مدد دیتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Work the focus keyphrase into the first sentence naturally."
msgstr "فوکس keyphrase کو پہلے جملے میں قدرتی طور پر شامل کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger relevance signals can improve ranking and user confidence."
msgstr "مضبوط ربط اشارے رینکنگ اور صارف اعتماد بہتر کر سکتے ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Title and description should not repeat each other."
msgstr "عنوان اور وضاحت کو ایک دوسرے کو نہیں دہرانا چاہیے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the title to state the topic and the description to add benefit or context."
msgstr "موضوع بیان کرنے کے لیے عنوان اور فائدہ یا سیاق و سباق شامل کرنے کے لیے وضاحت استعمال کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Distinct messaging gives users more reasons to click."
msgstr "منفرد پیغامات صارفین کو کلک کرنے کی زیادہ وجوہات دیتے ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Pages should have a single main heading (H1)."
msgstr "صفحات میں ایک مرکزی سرخی (H1) ہونی چاہیے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep one H1 that matches the page topic, and use H2/H3 for sections."
msgstr "صفحہ موضوع سے مطابق ایک H1 رکھیں، اور سیکشنز کے لیے H2/H3 استعمال کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear structure helps search engines understand the content hierarchy."
msgstr "واضح ڈھانچہ سرچ انجنوں کو مواد کی درجہ بندی سمجھنے میں مدد دیتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Subheadings break long content into scannable sections."
msgstr "ذیلی سرخیاں لمبے مواد کو قابلِ اسکین حصوں میں توڑتی ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add 2–8 H2/H3 headings that summarize key sections."
msgstr "اہم حصوں کا خلاصہ کرنے کے لیے 2–8 H2/H3 سرخیاں شامل کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves readability and keeps users engaged longer."
msgstr "پڑھنے کی سہولت بہتر کرتا ہے اور صارفین کو زیادہ دیر مشغول رکھتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the keyphrase in a subheading reinforces the main topic."
msgstr "ذیلی سرخی میں keyphrase شامل کرنا مرکزی موضوع کو تقویت دیتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Place the focus keyphrase in one relevant H2 or H3."
msgstr "فوکس keyphrase کو ایک متعلقہ H2 یا H3 میں رکھیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps search engines connect sections to the main theme."
msgstr "سرچ انجنوں کو سیکشنز کو مرکزی موضوع سے جوڑنے میں مدد دیتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "The opening paragraph sets context for both users and search engines."
msgstr "آغازی پیراگراف صارفین اور سرچ انجنوں دونوں کے لیے سیاق و سباق قائم کرتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the focus keyphrase once in the first 1–2 sentences."
msgstr "پہلے 1–2 جملوں میں فوکس keyphrase ایک بار استعمال کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger topical clarity can improve relevance signals."
msgstr "مضبوط موضوعاتی وضاحت ربط اشارے بہتر کر سکتی ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keyphrase density shows how often the main topic appears."
msgstr "Keyphrase کثافت دکھاتی ہے کہ مرکزی موضوع کتنی بار ظاہر ہوتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the keyphrase naturally throughout the content without stuffing."
msgstr "مواد میں keyphrase کو بھرے بغیر قدرتی طور پر استعمال کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Balanced usage supports relevance while avoiding spam signals."
msgstr "متوازن استعمال ربط کو سہارا دیتا ہے اور سپام اشاروں سے بچاتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long-tail phrases capture more specific search intent."
msgstr "Long-tail جملے زیادہ مخصوص سرچ ارادے کو پکڑتے ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add your long-tail phrases where they fit naturally in sections."
msgstr "اپنے long-tail phrases وہاں شامل کریں جہاں وہ حصوں میں قدرتی طور پر فٹ ہوں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps the page rank for more specific queries."
msgstr "صفحے کو زیادہ مخصوص سوالات کے لیے رینک کرنے میں مدد دیتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Very short pages often lack depth to satisfy readers."
msgstr "بہت چھوٹے صفحات میں اکثر قارئین کو مطمئن کرنے کی گہرائی نہیں ہوتی۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Expand the content with examples, steps, or FAQs."
msgstr "مثالوں، مراحل یا FAQs کے ساتھ مواد پھیلائیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "More complete content tends to perform better for informational queries."
msgstr "زیادہ مکمل مواد معلوماتی سوالات کے لیے بہتر کارکردگی دکھاتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Readable content keeps users engaged and reduces bounce."
msgstr "پڑھنے کے قابل مواد صارفین کو مشغول رکھتا اور bounce کم کرتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Shorten sentences, use simpler words, and break up long paragraphs."
msgstr "جملے چھوٹے کریں، آسان الفاظ استعمال کریں اور لمبے پیراگراف توڑیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improved clarity boosts dwell time and user satisfaction."
msgstr "بہتر وضاحت رکنے کے وقت اور صارف اطمینان کو بڑھاتی ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long sentences are hard to read in CJK languages."
msgstr "CJK زبانوں میں لمبے جملے پڑھنا مشکل ہوتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Split long sentences and add punctuation for clearer flow."
msgstr "لمبے جملے توڑیں اور واضح بہاؤ کے لیے رموزِ اوقاف شامل کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clearer reading experience helps users stay on the page."
msgstr "بہتر پڑھنے کا تجربہ صارفین کو صفحہ پر رکنے میں مدد دیتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Images support understanding and break up long text."
msgstr "تصاویر سمجھنے میں مدد دیتی ہیں اور لمبے متن کو توڑتی ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add at least one relevant image that illustrates the topic."
msgstr "موضوع کی وضاحت کرنے والی کم از کم ایک متعلقہ تصویر شامل کریں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Visuals improve engagement and can help with image search."
msgstr "بصری عناصر مشغولیت بہتر کرتے ہیں اور تصویری سرچ میں مدد کر سکتے ہیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Alt text helps search engines and screen readers interpret images."
msgstr "Alt text سرچ انجنز اور screen readers کو تصاویر سمجھنے میں مدد دیتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Describe each image in plain language, focusing on what it shows."
msgstr "ہر تصویر کو سادہ زبان میں بیان کریں، جو دکھاتی ہے اس پر توجہ دیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves accessibility and adds extra relevance signals."
msgstr "قابلیتِ رسائی بہتر کرتا ہے اور اضافی ربط اشارے شامل کرتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spacing long-tail phrases prevents keyword stuffing."
msgstr "long-tail جملوں کو فاصلے پر رکھنا keyword stuffing سے بچاتا ہے۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spread similar phrases across different sections."
msgstr "ملتے جلتے جملوں کو مختلف حصوں میں پھیلائیں۔"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keeps content natural while still covering long-tail queries."
