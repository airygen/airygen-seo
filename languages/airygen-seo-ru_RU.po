msgid "Show home link"
msgstr "Показать ссылку главной"

#: build/admin/airygen-app.js
msgid "Start the trail with your homepage label and URL."
msgstr "Начните цепочку с метки и URL вашей главной страницы."

#: build/admin/airygen-app.js
msgid "Show blog link on archives"
msgstr "Показать ссылку блога в архивах"

#: build/admin/airygen-app.js
msgid "Include the Posts page before archive items when a static blog page is set."
msgstr "Включить страницу записей перед элементами архива, когда установлена статическая страница блога."

#: build/admin/airygen-app.js
msgid "Show ancestor pages"
msgstr "Показать родительские страницы"

#: build/admin/airygen-app.js
msgid "Add parent pages for hierarchical content types (pages, hierarchical CPTs)."
msgstr "Добавьте родительские страницы для иерархических типов контента (страницы, иерархические CPT)."

#: build/admin/airygen-app.js
msgid "Hide taxonomy parents"
msgstr "Скрыть родителей таксономии"

#: build/admin/airygen-app.js
msgid "Skip parent terms in category/tag hierarchies to keep the trail compact."
msgstr "Пропускайте родительские термины в иерархиях категорий/тегов, чтобы держать цепочку компактной."

#: build/admin/airygen-app.js
msgid "Labels"
msgstr "Метки"

#: build/admin/airygen-app.js
msgid "Customize how archives, search results, and 404 pages appear in the trail."
msgstr "Настройте, как архивы, результаты поиска и страницы 404 отображаются в цепочке."

#: build/admin/airygen-app.js
msgid "Home label"
msgstr "Метка главной"

#: build/admin/airygen-app.js
msgid "Label used for the homepage breadcrumb."
msgstr "Метка, используемая для навигационной цепочки главной страницы."

#: build/admin/airygen-app.js
msgid "Archive label"
msgstr "Метка архива"

#: build/admin/airygen-app.js
msgid "Used for archive pages (category, tag, taxonomy, post type archives)."
msgstr "Используется для страниц архивов (категория, тег, таксономия, архивы типов записей)."

#: build/admin/airygen-app.js
msgid "Search results label"
msgstr "Метка результатов поиска"

#: build/admin/airygen-app.js
msgid "Shown when viewing the search results page."
msgstr "Показано при просмотре страницы результатов поиска."

#. translators: %s is an HTTP status code and should remain numeric, e.g. 404.
#: build/admin/airygen-app.js
#, js-format
msgid "%s label"
msgstr "Метка %s"

#: build/admin/airygen-app.js
msgid "Shown for not found pages (404 responses)."
msgstr "Показано для не найденных страниц (ответы 404)."

#: build/admin/airygen-app.js
msgid "Social Media Tags"
msgstr "Теги социальных медиа"

#: build/admin/airygen-app.js
msgid "Provide defaults for social share images and Twitter handles when per-post values are missing."
msgstr "Предоставьте значения по умолчанию для изображений для социальных сетей и дескрипторов Twitter, когда значения для каждой записи отсутствуют."

#: build/admin/airygen-app.js
msgid "Open Graph"
msgstr "Open Graph"

#: build/admin/airygen-app.js
msgid "Enable Open Graph"
msgstr "Включить Open Graph"

#: build/admin/airygen-app.js
msgid "When off, the site outputs no og:* tags. Threads and LinkedIn also rely on Open Graph, so their link previews will be affected."
msgstr "При отключении сайт не выводит теги og:*. Threads и LinkedIn также полагаются на Open Graph, поэтому их предпросмотры ссылок будут затронуты."

#: build/admin/airygen-app.js
msgid "Default image — URL"
msgstr "Изображение по умолчанию — URL"

#: build/admin/airygen-app.js
msgid "Default image — Attachment ID"
msgstr "Изображение по умолчанию — ID вложения"

#: build/admin/airygen-app.js
msgid "Select an image from the Media Library. If both URL and ID are set, the Attachment ID takes precedence. Set to 0 to disable."
msgstr "Выберите изображение из медиабиблиотеки. Если заданы и URL, и ID, ID вложения имеет приоритет. Установите 0 для отключения."

#: build/admin/airygen-app.js
msgid "Publisher URL"
msgstr "URL издателя"

#: build/admin/airygen-app.js
msgid "Optional canonical publisher page for social networks."
msgstr "Необязательная каноническая страница издателя для социальных сетей."

#: build/admin/airygen-app.js
msgid "Optional width to help caching. Suggested value: 1200."
msgstr "Необязательная ширина для помощи кешированию. Рекомендуемое значение: 1200."

#: build/admin/airygen-app.js
msgid "Optional height to help caching. Suggested value: 630."
msgstr "Необязательная высота для помощи кешированию. Рекомендуемое значение: 630."

#: build/admin/airygen-app.js
msgid "Domain verification"
msgstr "Верификация домена"

#: build/admin/airygen-app.js
msgid "Paste the Meta (Facebook/Instagram) Business Manager verification token to prove domain ownership. This helps Meta trust your og: tags and unlocks domain insights."
msgstr "Вставьте токен верификации Meta (Facebook/Instagram) Business Manager для подтверждения владения доменом. Это помогает Meta доверять вашим og: тегам и разблокировать статистику домена."

#: build/admin/airygen-app.js
msgid "Connect your Facebook App for advanced analytics and verification."
msgstr "Подключите ваше приложение Facebook для расширенной аналитики и верификации."

#: build/admin/airygen-app.js
msgid "Comma-separated Facebook admin IDs so those accounts can access Page Insights for your domain. IDs are visible in page source, so only add them if you are fine with that exposure."
msgstr "ID администраторов Facebook через запятую, чтобы эти аккаунты могли получить доступ к Page Insights для вашего домена. ID видны в исходном коде страницы, поэтому добавляйте их только если вы согласны с таким раскрытием."

#: build/admin/airygen-app.js
msgid "Twitter"
msgstr "Twitter"

#: build/admin/airygen-app.js
msgid "Enable Twitter Cards"
msgstr "Включить Twitter Cards"

#: build/admin/airygen-app.js
msgid "When off, the site outputs no twitter:* tags."
msgstr "При отключении сайт не выводит теги twitter:*."

#: build/admin/airygen-app.js
msgid "Default card type"
msgstr "Тип карточки по умолчанию"

#. translators: 1: HTML code tag for summary_large_image, 2: HTML code tag for summary.
