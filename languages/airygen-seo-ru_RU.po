msgstr "Отправьте образец дайджеста для подтверждения работы доставки по email."

#: build/admin/airygen-app.js
msgid "Test Email"
msgstr "Тест Email"

#: build/admin/airygen-app.js
msgid "SMTP"
msgstr "SMTP"

#: build/admin/airygen-app.js
