#: build/admin/airygen-app.js
msgid "Review recent link checks and jump to affected posts."
msgstr "Просмотрите недавние проверки ссылок и перейдите к затронутым записям."

#: build/admin/airygen-app.js
msgid "Filters"
msgstr "Фильтры"

#: build/admin/airygen-app.js
msgid "Toggle which statuses appear in the log."
msgstr "Переключите, какие статусы отображаются в логе."

#: build/admin/airygen-app.js
msgid "OK"
msgstr "OK"

#: build/admin/airygen-app.js
msgid "Redirect"
msgstr "Редирект"

#: build/admin/airygen-app.js
msgid "URL"
msgstr "URL"

#: build/admin/airygen-app.js
msgid "Checked at"
msgstr "Проверено"

#: build/admin/airygen-app.js
msgid "Edit post"
msgstr "Редактировать запись"

#: build/admin/airygen-app.js
msgid "View post"
msgstr "Просмотреть запись"

#: build/admin/airygen-app.js
msgid "Open link"
msgstr "Открыть ссылку"

#: build/admin/airygen-app.js
msgid "pts"
msgstr "бал."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Your SEO title should be long enough to explain the topic, but short enough to avoid truncation."
msgstr "Ваш SEO заголовок должен быть достаточно длинным, чтобы объяснить тему, но достаточно коротким, чтобы избежать обрезки."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Aim for about 50–60 characters. Front-load the most important words."
msgstr "Стремитесь к примерно 50-60 символам. Размещайте самые важные слова в начале."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear, visible titles improve click-through rate from search results."
msgstr "Четкие, видимые заголовки улучшают кликабельность из результатов поиска."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Search engines expect the primary topic to appear in the title."
msgstr "Поисковые системы ожидают, что основная тема появится в заголовке."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Include your focus keyphrase naturally near the start of the title."
msgstr "Включите вашу фокусную ключевую фразу естественно ближе к началу заголовка."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves topical relevance and makes the result more recognizable."
msgstr "Улучшает тематическую релевантность и делает результат более узнаваемым."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "A meta description helps search engines and users understand the page."
msgstr "Мета-описание помогает поисковым системам и пользователям понять страницу."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Write 1–2 sentences that summarize the page and invite a click."
msgstr "Напишите 1-2 предложения, которые обобщают страницу и приглашают к клику."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Better snippets can lift click-through rate even if rankings stay the same."
msgstr "Лучшие сниппеты могут повысить кликабельность, даже если позиции остаются прежними."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Descriptions that are too short or too long get cut off in results."
msgstr "Описания, которые слишком короткие или слишком длинные, обрезаются в результатах."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep it roughly 140–160 characters and prioritize the main benefit."
msgstr "Держите примерно 140-160 символов и приоритизируйте основную выгоду."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Full snippets look more professional and improve engagement."
msgstr "Полные сниппеты выглядят более профессионально и улучшают вовлеченность."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the focus phrase helps confirm the page topic."
msgstr "Включение фокусной фразы помогает подтвердить тему страницы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Work the focus keyphrase into the first sentence naturally."
msgstr "Вставьте фокусную ключевую фразу в первое предложение естественным образом."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger relevance signals can improve ranking and user confidence."
msgstr "Более сильные сигналы релевантности могут улучшить ранжирование и доверие пользователей."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Title and description should not repeat each other."
msgstr "Заголовок и описание не должны повторять друг друга."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the title to state the topic and the description to add benefit or context."
msgstr "Используйте заголовок для обозначения темы, а описание для добавления выгоды или контекста."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Distinct messaging gives users more reasons to click."
msgstr "Различающиеся сообщения дают пользователям больше причин кликнуть."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Pages should have a single main heading (H1)."
msgstr "Страницы должны иметь один основной заголовок (H1)."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep one H1 that matches the page topic, and use H2/H3 for sections."
msgstr "Держите один H1, соответствующий теме страницы, и используйте H2/H3 для разделов."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear structure helps search engines understand the content hierarchy."
msgstr "Четкая структура помогает поисковым системам понять иерархию контента."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Subheadings break long content into scannable sections."
msgstr "Подзаголовки разбивают длинный контент на сканируемые разделы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add 2–8 H2/H3 headings that summarize key sections."
msgstr "Добавьте 2-8 заголовков H2/H3, которые обобщают ключевые разделы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves readability and keeps users engaged longer."
msgstr "Улучшает читаемость и удерживает пользователей дольше."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the keyphrase in a subheading reinforces the main topic."
msgstr "Включение ключевой фразы в подзаголовок усиливает основную тему."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Place the focus keyphrase in one relevant H2 or H3."
msgstr "Поместите фокусную ключевую фразу в один релевантный H2 или H3."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps search engines connect sections to the main theme."
msgstr "Помогает поисковым системам связывать разделы с основной темой."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "The opening paragraph sets context for both users and search engines."
msgstr "Вступительный абзац задает контекст как для пользователей, так и для поисковых систем."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the focus keyphrase once in the first 1–2 sentences."
msgstr "Используйте фокусную ключевую фразу один раз в первых 1-2 предложениях."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger topical clarity can improve relevance signals."
msgstr "Более сильная тематическая ясность может улучшить сигналы релевантности."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keyphrase density shows how often the main topic appears."
msgstr "Плотность ключевой фразы показывает, как часто появляется основная тема."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the keyphrase naturally throughout the content without stuffing."
msgstr "Используйте ключевую фразу естественным образом по всему контенту без переспама."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Balanced usage supports relevance while avoiding spam signals."
msgstr "Сбалансированное использование поддерживает релевантность, избегая сигналов спама."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long-tail phrases capture more specific search intent."
msgstr "Длиннохвостые фразы улавливают более конкретное поисковое намерение."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add your long-tail phrases where they fit naturally in sections."
msgstr "Добавьте длиннохвостые фразы там, где они естественно вписываются в разделы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps the page rank for more specific queries."
msgstr "Помогает странице ранжироваться по более конкретным запросам."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Very short pages often lack depth to satisfy readers."
msgstr "Очень короткие страницы часто не имеют достаточной глубины для удовлетворения читателей."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Expand the content with examples, steps, or FAQs."
msgstr "Расширьте контент примерами, шагами или FAQ."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "More complete content tends to perform better for informational queries."
msgstr "Более полный контент, как правило, лучше работает для информационных запросов."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Readable content keeps users engaged and reduces bounce."
msgstr "Читаемый контент удерживает пользователей и уменьшает показатель отказов."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Shorten sentences, use simpler words, and break up long paragraphs."
msgstr "Сокращайте предложения, используйте более простые слова и разбивайте длинные абзацы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improved clarity boosts dwell time and user satisfaction."
msgstr "Улучшенная ясность повышает время пребывания и удовлетворенность пользователей."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long sentences are hard to read in CJK languages."
msgstr "Длинные предложения трудны для чтения на CJK языках."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Split long sentences and add punctuation for clearer flow."
msgstr "Разделяйте длинные предложения и добавляйте пунктуацию для более четкого потока."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clearer reading experience helps users stay on the page."
msgstr "Более ясный опыт чтения помогает пользователям оставаться на странице."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Images support understanding and break up long text."
msgstr "Изображения поддерживают понимание и разбивают длинный текст."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add at least one relevant image that illustrates the topic."
msgstr "Добавьте хотя бы одно релевантное изображение, иллюстрирующее тему."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Visuals improve engagement and can help with image search."
msgstr "Визуальные элементы улучшают вовлеченность и могут помочь с поиском изображений."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Alt text helps search engines and screen readers interpret images."
msgstr "Alt-текст помогает поисковым системам и программам чтения с экрана интерпретировать изображения."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Describe each image in plain language, focusing on what it shows."
msgstr "Опишите каждое изображение простым языком, сосредоточившись на том, что оно показывает."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves accessibility and adds extra relevance signals."
msgstr "Улучшает доступность и добавляет дополнительные сигналы релевантности."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spacing long-tail phrases prevents keyword stuffing."
msgstr "Размещение длиннохвостых фраз предотвращает переспам ключевыми словами."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spread similar phrases across different sections."
msgstr "Распределяйте похожие фразы по разным разделам."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keeps content natural while still covering long-tail queries."
msgstr "Сохраняет естественность контента, при этом охватывая длиннохвостые запросы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the keyphrase in one image alt text reinforces the topic."
msgstr "Включение ключевой фразы в один alt-текст изображения усиливает тему."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the focus phrase in a single relevant image alt description."
msgstr "Используйте фокусную фразу в одном релевантном alt-описании изображения."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Adds topical relevance without over-optimizing every image."
msgstr "Добавляет тематическую релевантность без чрезмерной оптимизации каждого изображения."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Internal links help users and search engines discover related pages."
msgstr "Внутренние ссылки помогают пользователям и поисковым системам находить связанные страницы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Link to 1–3 relevant posts or pages using descriptive anchor text."
msgstr "Создайте ссылки на 1-3 релевантные записи или страницы, используя описательный анкорный текст."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves site structure and can pass authority to key pages."
msgstr "Улучшает структуру сайта и может передавать авторитет ключевым страницам."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "External links show credibility and provide references."
msgstr "Внешние ссылки показывают авторитетность и предоставляют ссылки."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add at least one trusted source link that supports your content."
msgstr "Добавьте хотя бы одну ссылку на надежный источник, подтверждающий ваш контент."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Builds trust and can improve perceived quality."
msgstr "Создает доверие и может улучшить воспринимаемое качество."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Rel attributes clarify how external links should be treated."
msgstr "Атрибуты Rel уточняют, как должны обрабатываться внешние ссылки."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add rel values like nofollow, sponsored, or ugc where appropriate."
msgstr "Добавьте значения rel, такие как nofollow, sponsored или ugc, где это уместно."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps avoid link spam signals and keeps compliance clean."
msgstr "Помогает избежать сигналов спам-ссылок и поддерживает чистоту соответствия."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Short, readable URLs are easier to understand and share."
msgstr "Короткие, читаемые URL легче понять и поделиться."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use 2–5 words that match the topic and remove stop words."
msgstr "Используйте 2-5 слов, соответствующих теме, и удалите стоп-слова."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clean URLs improve clarity and can increase click confidence."
msgstr "Чистые URL улучшают ясность и могут повысить доверие к кликам."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the focus phrase in the URL reinforces relevance."
msgstr "Включение фокусной фразы в URL усиливает релевантность."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add the focus keyphrase to the slug without extra filler."
msgstr "Добавьте фокусную ключевую фразу в слаг без лишних слов."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Strengthens topical signals and makes URLs clearer."
msgstr "Усиливает тематические сигналы и делает URL более ясными."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Canonical URLs tell search engines which version to index."
msgstr "Канонические URL сообщают поисковым системам, какую версию индексировать."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Ensure the canonical points to the main URL of the page."
msgstr "Убедитесь, что канонический URL указывает на основной URL страницы."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Prevents duplicate content issues and consolidates ranking signals."
msgstr "Предотвращает проблемы дублированного контента и консолидирует сигналы ранжирования."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Article schema helps search engines understand your content type."
msgstr "Схема статьи помогает поисковым системам понять тип вашего контента."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Enable Article schema in Schema Markup settings."
msgstr "Включите схему статьи в настройках Schema Markup."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Structured data can improve search appearance and visibility."
msgstr "Структурированные данные могут улучшить внешний вид в поиске и видимость."

#: build/admin/airygen-app.js
