msgstr "Включите функцию шаблона, шорткод и вывод блока для отображения навигационной цепочки."

#: build/admin/airygen-app.js
msgid "Enable automatic breadcrumbs injection"
msgstr "Включить автоматическое встраивание навигационной цепочки"

