#: build/admin/airygen-app.js
msgid "Daily Digest"
msgstr "Ежедневный дайджест"

#: build/admin/airygen-app.js
msgid "Schedule and dispatch one daily digest for 404s, broken links, and related site alerts."
msgstr "Планируйте и отправляйте один ежедневный дайджест для 404, битых ссылок и сопутствующих оповещений сайта."

#: build/admin/airygen-app.js
msgid "Email"
msgstr "Электронная почта"

#: build/admin/airygen-app.js
msgid "Deliver digest notifications through wp_mail recipients."
msgstr "Доставлять уведомления дайджеста получателям через wp_mail."

#: build/admin/airygen-app.js
msgid "Telegram"
msgstr "Telegram"

#: build/admin/airygen-app.js
msgid "Send digest notifications to Telegram Bot chats."
msgstr "Отправляйте уведомления дайджеста в чаты Telegram Bot."

#: build/admin/airygen-app.js
msgid "Discord"
msgstr "Discord"

#: build/admin/airygen-app.js
msgid "Push digest messages to a Discord webhook endpoint."
msgstr "Отправляйте сообщения дайджеста на Discord-вебхук."

#: build/admin/airygen-app.js
msgid "Microsoft Teams"
msgstr "Microsoft Teams"

#: build/admin/airygen-app.js
msgid "Post digest messages to a Teams incoming webhook URL."
msgstr "Публиковать сообщения дайджеста на URL входящего вебхука Teams."

#: build/admin/airygen-app.js
msgid "Configure delivery channels for daily 404 digest alerts."
msgstr "Настройте каналы доставки для ежедневных оповещений дайджеста 404."

#: build/admin/airygen-app.js
msgid "Reports"
msgstr "Отчёты"

#: build/admin/airygen-app.js
msgid "Manage daily digest scheduling and delivery controls."
msgstr "Управляйте расписанием ежедневного дайджеста и элементами управления доставкой."

#: build/admin/airygen-app.js
msgid "Channels"
msgstr "Каналы"

#: build/admin/airygen-app.js
msgid "Enable channels and open each card to configure delivery details."
msgstr "Включите каналы и откройте каждую карточку для настройки деталей доставки."

#: build/admin/airygen-app.js
msgid "Configure digest schedule, trigger delivery, and review send logs."
msgstr "Настройте расписание дайджеста, запустите доставку и просмотрите журналы отправки."

#: build/admin/airygen-app.js
msgid "Configure daily digest schedule and send behavior."
msgstr "Настройте расписание ежедневного дайджеста и поведение отправки."

#: build/admin/airygen-app.js
msgid "Enable daily digest"
msgstr "Включить ежедневный дайджест"

#: build/admin/airygen-app.js
msgid "When enabled, Airygen sends one digest daily at the configured time."
msgstr "При включении Airygen отправляет один дайджест ежедневно в настроенное время."

#: build/admin/airygen-app.js
msgid "Timezone"
msgstr "Часовой пояс"

#: build/admin/airygen-app.js
msgid "Choose a timezone for daily digest scheduling."
msgstr "Выберите часовой пояс для планирования ежедневного дайджеста."

#: build/admin/airygen-app.js
msgid "Daily send time"
msgstr "Время ежедневной отправки"

#: build/admin/airygen-app.js
msgid "24-hour format, such as 09:00."
msgstr "24-часовой формат, например 09:00."

#: build/admin/airygen-app.js
msgid "Log retention (days)"
msgstr "Хранение логов (дней)"

#: build/admin/airygen-app.js
msgid "Keep digest logs for this many days before automatic cleanup."
msgstr "Хранить журналы дайджеста столько дней до автоматической очистки."

#: build/admin/airygen-app.js
msgid "Message subject"
msgstr "Тема сообщения"

#: build/admin/airygen-app.js
msgid "Email and message title used for daily digest delivery."
msgstr "Электронная почта и заголовок сообщения для доставки ежедневного дайджеста."

#: build/admin/airygen-app.js
msgid "Intro"
msgstr "Вступление"

#: build/admin/airygen-app.js
msgid "Shown before digest sections."
msgstr "Отображается перед разделами дайджеста."

#: build/admin/airygen-app.js
msgid "Shown after digest sections."
msgstr "Отображается после разделов дайджеста."

#: build/admin/airygen-app.js
msgid "Send now"
msgstr "Отправить сейчас"

#: build/admin/airygen-app.js
msgid "Daily digest is sent by background processing, but you can also send one immediately now."
msgstr "Ежедневный дайджест отправляется фоновой обработкой, но вы также можете отправить его прямо сейчас."

#: build/admin/airygen-app.js
msgid "Digest sent. Check channel results in logs below."
msgstr "Дайджест отправлен. Проверьте результаты каналов в журналах ниже."

#: build/admin/airygen-app.js
msgid "No enabled channels. Enable at least one channel to send a digest."
msgstr "Нет включённых каналов. Включите хотя бы один канал для отправки дайджеста."

#: build/admin/airygen-app.js
msgid "Failed to send digest."
msgstr "Не удалось отправить дайджест."

#: build/admin/airygen-app.js
msgid "Arrange cards to control which sections are shown in digest content."
msgstr "Расположите карточки, чтобы контролировать, какие разделы отображаются в дайджесте."

#: build/admin/airygen-app.js
msgid "Message content"
msgstr "Содержимое сообщения"

#: build/admin/airygen-app.js
msgid "Blocks here are included in the digest message."
msgstr "Блоки здесь включены в сообщение дайджеста."

#: build/admin/airygen-app.js
msgid "Blocks here are not included in the digest message."
msgstr "Блоки здесь не включены в сообщение дайджеста."

#: build/admin/airygen-app.js
msgid "Shows current background job status for Daily Digest delivery."
msgstr "Показывает текущий статус фонового задания для доставки ежедневного дайджеста."

#: build/admin/airygen-app.js
msgid "Review daily digest delivery history and channel outcomes."
msgstr "Просматривайте историю доставки ежедневного дайджеста и результаты каналов."

#: build/admin/airygen-app.js
msgid "Latest run"
msgstr "Последний запуск"

#: build/admin/airygen-app.js
msgid "Runs (24h)"
msgstr "Запусков (24ч)"

#: build/admin/airygen-app.js
msgid "Success / failed (24h)"
msgstr "Успешно / неудачно (24ч)"

#: build/admin/airygen-app.js
msgid "Runs (7d)"
msgstr "Запусков (7д)"

#: build/admin/airygen-app.js
msgid "Delivery date"
msgstr "Дата доставки"

#: build/admin/airygen-app.js
msgid "Results"
msgstr "Результаты"

#: build/admin/airygen-app.js
msgid "Loading logs…"
msgstr "Загрузка журналов…"

#: build/admin/airygen-app.js
msgid "No channel results."
msgstr "Нет результатов каналов."

#: build/admin/airygen-app.js
msgid "Success"
msgstr "Успех"

#: build/admin/airygen-app.js
msgid "Configure recipients and test digest delivery using wp_mail."
msgstr "Настройте получателей и протестируйте доставку дайджеста через wp_mail."

#: build/admin/airygen-app.js
msgid "Set up SMTP delivery, recipients, and test sending for Email notifications."
msgstr "Настройте доставку SMTP, получателей и тестовую отправку для email-уведомлений."

#: build/admin/airygen-app.js
msgid "Enable Email"
msgstr "Включить электронную почту"

#: build/admin/airygen-app.js
msgid "Send digest messages through built-in SMTP settings."
msgstr "Отправляйте сообщения дайджеста через встроенные настройки SMTP."

#: build/admin/airygen-app.js
msgid "Recipients"
msgstr "Получатели"

#: build/admin/airygen-app.js
msgid "One email per line or separated by commas."
msgstr "По одному email в строке или через запятую."

#: build/admin/airygen-app.js
msgid "Add all destination email addresses for daily reports."
msgstr "Добавьте все адреса электронной почты для ежедневных отчётов."

#: build/admin/airygen-app.js
msgid "Test delivery"
msgstr "Тест доставки"

#: build/admin/airygen-app.js
