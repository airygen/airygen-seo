msgstr "Настройте стиль текста и ссылок для навигационной цепочки."

#: build/admin/airygen-app.js
msgid "Text color"
msgstr "Цвет текста"

#: build/admin/airygen-app.js
msgid "Link color"
msgstr "Цвет ссылки"

