msgstr "Задаёт цвет текста для содержимого анонса."

#: build/admin/airygen-app.js
msgid "Max chars"
msgstr "Макс. символов"

#: build/admin/airygen-app.js
msgid "Limits how many characters are shown before excerpt text is truncated."
msgstr "Ограничивает количество символов, отображаемых до усечения текста анонса."

#: build/admin/airygen-app.js
msgid "Fade mask"
msgstr "Маска затухания"

#: build/admin/airygen-app.js
msgid "Adds a fade effect at the end of excerpt text to make truncated content look smoother."
msgstr "Добавляет эффект затухания в конце текста анонса, делая усечённый контент более плавным."

#: build/admin/airygen-app.js
msgid "Fade color"
msgstr "Цвет затухания"

#: build/admin/airygen-app.js
msgid "Choose the ending color used by the fade mask effect."
msgstr "Выберите конечный цвет для эффекта маски затухания."

#: build/admin/airygen-app.js
msgid "Mask height"
msgstr "Высота маски"

#: build/admin/airygen-app.js
msgid "Controls how tall the fade mask overlay appears at the bottom of excerpt text."
msgstr "Управляет высотой маски затухания в нижней части текста анонса."

#: build/admin/airygen-app.js
msgid "Author & Date"
msgstr "Автор и дата"

#: build/admin/airygen-app.js
msgid "Sets the text size for both author and date blocks."
msgstr "Задаёт размер текста для блоков автора и даты."

#: build/admin/airygen-app.js
msgid "Sets the text color for both author and date blocks."
msgstr "Задаёт цвет текста для блоков автора и даты."

#: build/admin/airygen-app.js
msgid "Choose whether author and date text are bold or italic."
msgstr "Выберите, будут ли текст автора и даты жирными или курсивными."

#: build/admin/airygen-app.js
msgid "Configure enable state and integration methods for related posts output."
msgstr "Настройте состояние включения и методы интеграции для вывода похожих записей."

#: build/admin/airygen-app.js
msgid "Requires Link Suggestions and outputs related post cards via shortcode or automatic insertion."
msgstr "Требует «Предложений ссылок» и выводит карточки похожих записей через шорткод или автоматическую вставку."

#: build/admin/airygen-app.js
msgid "Automatically inject related posts into content based on the insertion settings below."
msgstr "Автоматически встраивать похожие записи в контент на основе настроек вставки ниже."

#: build/admin/airygen-app.js
msgid "Choose whether automatic related posts appear before or after the article content."
msgstr "Выберите, будут ли автоматические похожие записи появляться до или после контента статьи."

#: build/admin/airygen-app.js
msgid "Post type scope is synced from Link Suggestions and cannot be edited here."
msgstr "Область охвата типа записи синхронизирована из «Предложений ссылок» и не может быть изменена здесь."

#: build/admin/airygen-app.js
msgid "Preview related posts output based on current layout and style settings."
msgstr "Предпросмотр вывода похожих записей на основе текущих настроек макета и стиля."

#: build/admin/airygen-app.js
msgid "Failed to load 404 stats."
msgstr "Не удалось загрузить статистику 404."

#. translators: %s is an HTTP status code and should remain numeric, e.g. 404.
#: build/admin/airygen-app.js
#, js-format
msgid "Failed to load %s records."
msgstr "Не удалось загрузить записи %s."

#: build/admin/airygen-app.js
msgid "Failed to update 404 record."
msgstr "Не удалось обновить запись 404."

#: build/admin/airygen-app.js
msgid "Record updated."
msgstr "Запись обновлена."

#. translators: %s is an HTTP status code and should remain numeric, e.g. 404.
#: build/admin/airygen-app.js
#, js-format
msgid "%s Manager"
msgstr "%s Менеджер"

#: build/admin/airygen-app.js
msgid "Track 404 traffic, keep only meaningful logs, and define fallback behavior when no specific redirect rule matches."
msgstr "Отслеживайте трафик 404, храните только значимые журналы и определяйте резервное поведение при отсутствии подходящего правила редиректа."

#: build/admin/airygen-app.js
msgid "Monitoring"
msgstr "Мониторинг"

#: build/admin/airygen-app.js
msgid "Control how 404 requests are tracked, stored, and filtered."
msgstr "Управляйте отслеживанием, хранением и фильтрацией запросов 404."

#: build/admin/airygen-app.js
msgid "Monitor mode"
msgstr "Режим мониторинга"

#: build/admin/airygen-app.js
msgid "Simple"
msgstr "Простой"

#: build/admin/airygen-app.js
msgid "Advanced"
msgstr "Расширенный"

#: build/admin/airygen-app.js
msgid "Simple logs the first hit only. Advanced keeps hits, last seen time, referer, and user agent updated."
msgstr "Простой режим записывает только первый запрос. Расширенный режим ведёт обновляемые данные: запросы, время последнего просмотра, реферер и user agent."

#: build/admin/airygen-app.js
msgid "Log limit"
msgstr "Лимит журнала"

#. translators: %s is an HTTP status code and should remain numeric, e.g. 404.
#: build/admin/airygen-app.js
#, js-format
msgid "Maximum number of %s records kept in the database."
msgstr "Максимальное количество записей %s, хранимых в базе данных."

#: build/admin/airygen-app.js
msgid "Retention days"
msgstr "Дней хранения"

#: build/admin/airygen-app.js
msgid "Old logs are cleaned up automatically after this period."
msgstr "Старые журналы автоматически очищаются по истечении этого периода."

#: build/admin/airygen-app.js
msgid "Ignore query params"
msgstr "Игнорировать параметры запроса"

#: build/admin/airygen-app.js
msgid "Treat /page?a=1 and /page?a=2 as the same path."
msgstr "Считать /page?a=1 и /page?a=2 одним путём."

#: build/admin/airygen-app.js
msgid "Exclude patterns"
msgstr "Шаблоны исключений"

#: build/admin/airygen-app.js
msgid "One pattern per line. Requests matching these patterns are ignored."
msgstr "По одному шаблону в строке. Запросы, соответствующие этим шаблонам, игнорируются."

#: build/admin/airygen-app.js
msgid "Daily alerts"
msgstr "Ежедневные оповещения"

#: build/admin/airygen-app.js
msgid "Receive daily alerts for newly detected records."
msgstr "Получайте ежедневные оповещения о вновь обнаруженных записях."

#: build/admin/airygen-app.js
msgid "Fallback redirect"
msgstr "Резервный редирект"

#: build/admin/airygen-app.js
msgid "Define what should happen when a URL hits 404 and no redirect rule is matched."
msgstr "Определите, что должно происходить, когда URL возвращает 404 и ни одно правило редиректа не совпадает."

