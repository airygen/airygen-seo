msgstr "Menampilkan status tugas latar belakang saat ini untuk pemindaian Pemeriksa Tautan Rusak."

#: build/admin/airygen-app.js
msgid "Link log"
msgstr "Log tautan"

#: build/admin/airygen-app.js
