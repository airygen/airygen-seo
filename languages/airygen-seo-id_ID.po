#: build/admin/airygen-app.js
msgid "Export settings"
msgstr "Ekspor pengaturan"

#: build/admin/airygen-app.js
msgid "Download a JSON snapshot of all your current settings. Use this to back up your configuration or transfer it to another site."
msgstr "Unduh snapshot JSON dari semua pengaturan Anda saat ini. Gunakan ini untuk mencadangkan konfigurasi atau mentransfernya ke situs lain."

#: build/admin/airygen-app.js
