msgstr "Impor pengaturan"

#: build/admin/airygen-app.js
msgid "Upload a JSON file exported from Airygen SEO to restore or copy your settings. Existing settings will be overwritten."
msgstr "Unggah file JSON yang diekspor dari Airygen SEO untuk memulihkan atau menyalin pengaturan Anda. Pengaturan yang ada akan ditimpa."

#: build/admin/airygen-app.js
msgid "Settings imported successfully."
msgstr "Pengaturan berhasil diimpor."

#: build/admin/airygen-app.js
msgid "Import failed. Please check the file and try again."
msgstr "Impor gagal. Silakan periksa file dan coba lagi."

#: build/admin/airygen-app.js
