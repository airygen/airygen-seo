msgstr "Uninstall"

#: build/admin/airygen-app.js
msgid "Choose what data is permanently removed when the plugin is deleted. These actions only run on full uninstall, not on deactivation."
msgstr "Pilih data yang akan dihapus secara permanen saat plugin dihapus. Tindakan ini hanya berjalan saat uninstall penuh, bukan saat dinonaktifkan."

#: build/admin/airygen-app.js
msgid "Remove all custom database tables"
msgstr "Hapus semua tabel database kustom"

#: build/admin/airygen-app.js
msgid "Remove all plugin settings (wp_options)"
msgstr "Hapus semua pengaturan plugin (wp_options)"

#: build/admin/airygen-app.js
msgid "Remove all post, term, and user metadata"
msgstr "Hapus semua metadata post, term, dan pengguna"

