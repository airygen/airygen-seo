#: build/admin/airygen-app.js
msgid "Broken Link Checker"
msgstr "Pemeriksa Tautan Rusak"

#: build/admin/airygen-app.js
msgid "Scan content for broken and redirected links, and monitor crawl health."
msgstr "Pindai konten untuk tautan rusak dan dialihkan, serta pantau kesehatan perayapan."

#: build/admin/airygen-app.js
msgid "Link Counter must be enabled to gather internal link data."
msgstr "Link Counter harus diaktifkan untuk mengumpulkan data tautan internal."

#: build/admin/airygen-app.js
msgid "Tune scan frequency and limits. Lower numbers are safer on shared hosts."
msgstr "Sesuaikan frekuensi dan batas pemindaian. Angka yang lebih kecil lebih aman pada host bersama."

#: build/admin/airygen-app.js
msgid "How often the scanner runs. Set higher on large sites."
msgstr "Seberapa sering pemindai berjalan. Atur lebih tinggi untuk situs besar."

#: build/admin/airygen-app.js
msgid "Max requests per run"
msgstr "Maks. permintaan per proses"

#: build/admin/airygen-app.js
msgid "Limits simultaneous HTTP requests during a scan."
msgstr "Membatasi permintaan HTTP simultan selama pemindaian."

#: build/admin/airygen-app.js
msgid "Pause between request batches to reduce load."
msgstr "Jeda antara batch permintaan untuk mengurangi beban."

#: build/admin/airygen-app.js
msgid "Older log entries are deleted automatically."
msgstr "Entri log yang lebih lama dihapus secara otomatis."

#: build/admin/airygen-app.js
msgid "Max time to open a connection before aborting."
msgstr "Waktu maksimum untuk membuka koneksi sebelum dibatalkan."

#: build/admin/airygen-app.js
msgid "Max time to complete a request before aborting."
msgstr "Waktu maksimum untuk menyelesaikan permintaan sebelum dibatalkan."

#: build/admin/airygen-app.js
msgid "Treat redirects as warnings"
msgstr "Perlakukan pengalihan sebagai peringatan"

#: build/admin/airygen-app.js
msgid "When on, redirected links are flagged but not counted as errors."
msgstr "Saat diaktifkan, tautan yang dialihkan ditandai tetapi tidak dihitung sebagai kesalahan."

#: build/admin/airygen-app.js
msgid "Choose which link types are included in broken-link scans."
msgstr "Pilih jenis tautan mana yang disertakan dalam pemindaian tautan rusak."

#: build/admin/airygen-app.js
msgid "Link types to scan"
msgstr "Jenis tautan yang dipindai"

#: build/admin/airygen-app.js
