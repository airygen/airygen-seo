#, php-format
msgid "Focus keyphrase density %1$s%%-%2$s%%"
msgstr "फोकस कीफ़्रेज़ घनत्व %1$s%%-%2$s%%"

#. translators: 1: per phrase minimum density, 2: per phrase maximum density, 3: total maximum density.
#, php-format
msgid "Long-tail keyphrase density %1$s%%-%2$s%% each, total <= %3$s%%"
msgstr "long-tail कीफ़्रेज़ घनत्व %1$s%%-%2$s%% प्रत्येक, कुल <= %3$s%%"

#. translators: %d is the minimum word count.
#, php-format
msgid "Word count at least %d"
msgstr "शब्द संख्या कम-से-कम %d"

#. translators: %d is the minimum Flesch score.
#, php-format
msgid "Flesch reading ease >= %d (non-CJK)"
msgstr "Flesch रीडिंग ईज़ >= %d (गैर-CJK)"

#. translators: %d is the maximum CJK sentence length.
#, php-format
msgid "Average sentence length <= %d (CJK)"
msgstr "औसत वाक्य लंबाई <= %d (CJK)"

msgid "At least one image in content"
msgstr "सामग्री में कम से कम एक छवि"

msgid "All images have alt text"
msgstr "सभी छवियों में alt text है"

#. translators: %d is the minimum spacing distance.
#, php-format
msgid "Long-tail keyphrases spaced %d+ words/chars from other keyphrases"
msgstr "long-tail कीफ़्रेज़ अन्य कीफ़्रेज़ से %d+ शब्द/अक्षर की दूरी पर हों"

msgid "At least one image alt has focus keyphrase"
msgstr "कम से कम एक छवि alt में फोकस कीफ्रेज़ है"

#. translators: 1: minimum internal links, 2: maximum internal links.
#, php-format
msgid "Internal links between %1$d and %2$d"
msgstr "आंतरिक लिंक %1$d और %2$d के बीच"

#. translators: %d is the minimum external links count.
#, php-format
msgid "External links at least %d"
msgstr "बाहरी links कम से कम %d"

msgid "External links use rel attributes"
msgstr "बाहरी links rel attributes का उपयोग करते हैं"

msgid "Slug has 2–5 words"
msgstr "स्लग में 2–5 शब्द हैं"

msgid "Slug includes focus keyphrase"
msgstr "स्लग में फोकस कीफ्रेज शामिल है"

msgid "Canonical is valid"
msgstr "कैनोनिकल वैध है"

msgid "Article structured data present"
msgstr "आर्टिकल संरचित डेटा मौजूद"

msgid "Breadcrumb structured data present"
msgstr "Breadcrumb संरचित डेटा मौजूद"

