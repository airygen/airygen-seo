#: build/admin/airygen-app.js
msgid "Set a limit for video preview duration."
msgstr "वीडियो प्रीव्यू अवधि के लिए एक सीमा सेट करें।"

#: build/admin/airygen-app.js
msgid "Extra directives"
msgstr "अतिरिक्त directives"

#: build/admin/airygen-app.js
msgid "Add additional robots directives like nosnippet or noarchive."
msgstr "nosnippet या noarchive जैसे अतिरिक्त robots निर्देश जोड़ें।"

#: build/admin/airygen-app.js
msgid "Custom directives"
msgstr "कस्टम directives"

#: build/admin/airygen-app.js
msgid "Comma-separated directives. Known directives are deduped; unknown ones are passed through."
msgstr "कॉमा से अलग किए गए directives। ज्ञात directives को dedupe किया जाता है; अज्ञात directives यथावत भेजे जाते हैं।"

#: build/admin/airygen-app.js
msgid "Preview robots meta value"
msgstr "robots meta मान प्रीव्यू"

#: build/admin/airygen-app.js
msgid "Robots meta copied"
msgstr "Robots मेटा कॉपी किया गया"

#: build/admin/airygen-app.js
msgid "Unable to copy robots meta"
msgstr "robots meta कॉपी करने में असमर्थ"

#: build/admin/airygen-app.js
msgid "This is the exact content that will be output in the <meta name=\"robots\"> tag."
msgstr "यही सटीक सामग्री है जो <meta name=\"robots\"> टैग में आउटपुट होगी।"

#: build/admin/airygen-app.js
msgid "Robots.txt"
msgstr "Robots.txt"

#: build/admin/airygen-app.js
msgid "Add rules for crawlers such as disallow paths or custom user-agent directives."
msgstr "क्रॉलर के लिए नियम जोड़ें जैसे disallow पथ या कस्टम यूजर-एजेंट निर्देश।"

#: build/admin/airygen-app.js
msgid "Additional rules"
msgstr "अतिरिक्त नियम"

#: build/admin/airygen-app.js
msgid "These lines will be appended to the robots.txt output."
msgstr "ये पंक्तियाँ robots.txt आउटपुट में जोड़ी जाएँगी।"

#: build/admin/airygen-app.js
msgid "Preview URL"
msgstr "URL प्रीव्यू"

#: build/admin/airygen-app.js
msgid "Preview link copied"
msgstr "प्रीव्यू लिंक कॉपी किया गया"

#: build/admin/airygen-app.js
msgid "Unable to copy preview link"
msgstr "पूर्वावलोकन लिंक कॉपी करने में असमर्थ"

#: build/admin/airygen-app.js
msgid "Open robots.txt in a new tab to verify output."
msgstr "आउटपुट की पुष्टि के लिए robots.txt को नए टैब में खोलें।"

#: build/admin/airygen-app.js
msgid "Soft parchment yellow for warm, readable TOCs."
msgstr "गर्म, पढ़ने योग्य TOCs के लिए नरम parchment yellow।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Table of Contents"
msgstr "विषय-सूची"

#: build/admin/airygen-app.js
msgid "Section 1"
msgstr "अनुभाग 1"

#: build/admin/airygen-app.js
msgid "Section 2"
msgstr "अनुभाग 2"

#: build/admin/airygen-app.js
msgid "TOC"
msgstr "TOC"

#: build/admin/airygen-app.js
msgid "Generate a navigable outline of headings and control where it appears in your content."
msgstr "हेडिंग्स की नेविगेट की जा सकने वाली रूपरेखा जनरेट करें और नियंत्रित करें कि यह आपकी सामग्री में कहाँ दिखाई दे।"

#: build/admin/airygen-app.js
msgid "Configure manual output and automatic injection for table of contents."
msgstr "विषय-सूची के लिए मैन्युअल आउटपुट और स्वचालित इंजेक्शन कॉन्फ़िगर करें।"

#: build/admin/airygen-app.js
msgid "Allows TOC output via template function, shortcode, or block."
msgstr "टेम्पलेट फ़ंक्शन, शॉर्टकोड या ब्लॉक के माध्यम से TOC आउटपुट की अनुमति देता है।"

#: build/admin/airygen-app.js
msgid "Automatically injects TOC into eligible post content."
msgstr "योग्य पोस्ट सामग्री में TOC स्वचालित रूप से इंजेक्ट करता है।"

#: build/admin/airygen-app.js
msgid "After first paragraph"
msgstr "पहले पैराग्राफ के बाद"

#: build/admin/airygen-app.js
msgid "Choose where TOC is inserted when automatic injection is enabled."
msgstr "स्वचालित इंजेक्शन सक्षम होने पर TOC कहां डाला जाता है चुनें।"

#: build/admin/airygen-app.js
msgid "Choose which post types are eligible for TOC output."
msgstr "चुनें कि कौन से पोस्ट प्रकार TOC आउटपुट के लिए योग्य हैं।"

#: build/admin/airygen-app.js
msgid "Post types to include"
msgstr "शामिल किए जाने वाले पोस्ट प्रकार"

#: build/admin/airygen-app.js
msgid "Structure"
msgstr "संरचना"

#: build/admin/airygen-app.js
msgid "Choose heading levels and placement."
msgstr "शीर्षक स्तर और प्लेसमेंट चुनें।"

#: build/admin/airygen-app.js
msgid "Minimum headings"
msgstr "न्यूनतम हेडिंग्स"

#: build/admin/airygen-app.js
msgid "Only show the TOC when this many headings are found."
msgstr "TOC केवल तभी दिखाएँ जब इतनी हेडिंग्स मिलें।"

#: build/admin/airygen-app.js
msgid "Heading levels"
msgstr "हेडिंग स्तर"

#: build/admin/airygen-app.js
msgid "Choose which heading levels are included in the TOC list."
msgstr "चुनें कि TOC सूची में कौन से शीर्षक स्तर शामिल हैं।"

#: build/admin/airygen-app.js
msgid "Control how visitors interact with the TOC links."
msgstr "visitors TOC links के साथ कैसे इंटरैक्ट करें, यह नियंत्रित करें।"

#: build/admin/airygen-app.js
msgid "Smooth scroll"
msgstr "स्मूथ स्क्रोल"

#: build/admin/airygen-app.js
msgid "Animate scrolling when visitors click TOC links."
msgstr "जब विज़िटर TOC लिंक पर क्लिक करते हैं तो स्क्रॉलिंग एनिमेट करें।"

#: build/admin/airygen-app.js
msgid "Add numbering"
msgstr "नंबरिंग जोड़ें"

#: build/admin/airygen-app.js
msgid "Show ordered numbers for each heading item."
msgstr "प्रत्येक heading आइटम के लिए क्रमांकित संख्याएँ दिखाएँ।"

#: build/admin/airygen-app.js
msgid "Collapse on load"
msgstr "लोड होने पर समेटें"

#: build/admin/airygen-app.js
msgid "Start with the TOC collapsed for a cleaner page."
msgstr "साफ-सुथरे पेज के लिए TOC को संकुचित अवस्था में शुरू करें।"

#: build/admin/airygen-app.js
msgid "Anchors"
msgstr "एंकर"

#: build/admin/airygen-app.js
msgid "Control anchor IDs and exclusions when building the TOC."
msgstr "TOC बनाते समय anchor IDs और exclusions नियंत्रित करें।"

#: build/admin/airygen-app.js
msgid "Anchor prefix"
msgstr "एंकर उपसर्ग"

#: build/admin/airygen-app.js
msgid "Prefix applied to generated heading IDs to avoid clashes."
msgstr "टकराव से बचने के लिए जनरेट की गई heading IDs पर लागू प्रिफ़िक्स।"

#: build/admin/airygen-app.js
msgid "Exclude headings"
msgstr "headings को बाहर रखें"

#: build/admin/airygen-app.js
msgid "Separate phrases with commas to skip matching headings."
msgstr "मेल खाते headings को छोड़ने के लिए वाक्यांशों को कॉमा से अलग करें।"

#: build/admin/airygen-app.js
msgid "Themes"
msgstr "थीम्स"

#: build/admin/airygen-app.js
msgid "Choose a preset theme as the base style for TOC preview and output."
msgstr "TOC पूर्वावलोकन और आउटपुट के लिए बेस स्टाइल के रूप में एक प्रीसेट थीम चुनें।"

#: build/admin/airygen-app.js
msgid "Selected"
msgstr "चयनित"

#: build/admin/airygen-app.js
msgid "Adjust spacing and borders to match your theme."
msgstr "अपनी थीम से मेल खाने के लिए स्पेसिंग और बॉर्डर समायोजित करें।"

#: build/admin/airygen-app.js
msgid "Choose whether TOC links are bold, italic, or underlined."
msgstr "चुनें कि TOC लिंक बोल्ड, इटैलिक या अंडरलाइन हैं।"

#: build/admin/airygen-app.js
msgid "Sets the color of TOC links."
msgstr "TOC लिंक्स का रंग सेट करता है।"

#: build/admin/airygen-app.js
msgid "Adjust the font size of TOC links."
msgstr "TOC लिंक का फ़ॉन्ट साइज़ समायोजित करें।"

#: build/admin/airygen-app.js
msgid "Padding inside the list of TOC links."
msgstr "TOC लिंक की सूची के अंदर पैडिंग।"

#: build/admin/airygen-app.js
msgid "TOC preview"
msgstr "TOC पूर्वावलोकन"

#: build/admin/airygen-app.js
msgid "Uses the post title."
msgstr "post title का उपयोग करता है।"

#: build/admin/airygen-app.js
msgid "Uses the image file name."
msgstr "image file name का उपयोग करता है।"

#: build/admin/airygen-app.js
msgid "Uses the attachment title from the Media Library."
msgstr "Media Library से attachment title का उपयोग करता है।"

#: build/admin/airygen-app.js
msgid "Adds a running number for each image."
msgstr "प्रत्येक छवि के लिए एक क्रमांक जोड़ता है।"

#: build/admin/airygen-app.js
msgid "Uses the focus keyphrase (blank if none is set)."
msgstr "focus keyphrase का उपयोग करता है (यदि कोई सेट नहीं है तो खाली)।"

#: build/admin/airygen-app.js
msgid "Uses a random long-tail keyphrase (blank if none are set)."
msgstr "एक यादृच्छिक long-tail keyphrase का उपयोग करता है (यदि कोई सेट नहीं है तो खाली)।"

#: build/admin/airygen-app.js
msgid "Uses the separator value configured below."
msgstr "नीचे कॉन्फ़िगर किए गए separator मान का उपयोग करता है।"

#: build/admin/airygen-app.js
msgid "Image SEO"
msgstr "इमेज SEO"

#: build/admin/airygen-app.js
msgid "Automatically add missing ALT and TITLE attributes with templated values."
msgstr "टेम्पलेटेड मानों के साथ अनुपलब्ध ALT और TITLE एट्रिब्यूट स्वचालित रूप से जोड़ें।"

#: build/admin/airygen-app.js
msgid "Add missing alt attributes"
msgstr "अनुपलब्ध alt एट्रिब्यूट जोड़ें"

#: build/admin/airygen-app.js
msgid "Runtime-only change; stored post content never updates."
msgstr "केवल रनटाइम बदलाव; संग्रहीत पोस्ट सामग्री कभी अपडेट नहीं होती।"

#: build/admin/airygen-app.js
msgid "ALT attribute template"
msgstr "ALT एट्रिब्यूट टेम्पलेट"

#: build/admin/airygen-app.js
msgid "Build the ALT template using tokens only."
msgstr "केवल टोकन का उपयोग करके ALT टेम्पलेट बनाएं।"

#: build/admin/airygen-app.js
msgid "Add missing title attributes"
msgstr "अनुपलब्ध title एट्रिब्यूट जोड़ें"

#: build/admin/airygen-app.js
msgid "TITLE attribute template"
msgstr "TITLE attribute टेम्पलेट"

#: build/admin/airygen-app.js
msgid "Build the TITLE template using tokens only."
msgstr "केवल टोकन का उपयोग करके TITLE टेम्पलेट बनाएं।"

#: build/admin/airygen-app.js
msgid "Template settings"
msgstr "टेम्पलेट सेटिंग्स"

#: build/admin/airygen-app.js
msgid "Define shared tokens used by your image templates."
msgstr "अपने image templates द्वारा उपयोग किए जाने वाले shared tokens निर्धारित करें।"

#: build/admin/airygen-app.js
msgid "Language Versions"
msgstr "भाषा संस्करण"

#: build/admin/airygen-app.js
msgid "Tell search engines which URL is the right version for each language."
msgstr "search engines को बताएं कि प्रत्येक भाषा के लिए कौन सा URL सही संस्करण है।"

#: build/admin/airygen-app.js
msgid "Add language"
msgstr "भाषा जोड़ें"

#: build/admin/airygen-app.js
msgid "Mappings"
msgstr "मैपिंग्स"

#: build/admin/airygen-app.js
msgid "Airygen can use WPML/Polylang automatically, and you can add manual mappings here."
msgstr "Airygen स्वचालित रूप से WPML/Polylang का उपयोग कर सकता है, और आप यहां मैन्युअल मैपिंग जोड़ सकते हैं।"

#: build/admin/airygen-app.js
msgid "manual alternates"
msgstr "मैनुअल alternates"

#: build/admin/airygen-app.js
msgid "languages"
msgstr "भाषाएँ"

#: build/admin/airygen-app.js
msgid "automatic mappings"
msgstr "स्वचालित mappings"

#. translators: 1: item label, 2: action label, 3: override target label. Example: No manual alternates yet. Add languages to override automatic mappings.
#: build/admin/airygen-app.js
#, js-format
msgid "No %1$s yet. Add %2$s to override %3$s."
msgstr "अभी तक कोई %1$s नहीं है। %3$s को ओवरराइड करने के लिए %2$s जोड़ें।"

#: build/admin/airygen-app.js
msgid "Language code"
msgstr "भाषा कोड"

#: build/admin/airygen-app.js
msgid "Language URL"
msgstr "भाषा URL"

#: build/admin/airygen-app.js
msgid "Default"
msgstr "डिफ़ॉल्ट"

#: build/admin/airygen-app.js
msgid "Set a fallback URL when a visitor’s language isn’t listed above."
msgstr "जब किसी आगंतुक की भाषा ऊपर सूचीबद्ध न हो, तब एक fallback URL सेट करें।"

#: build/admin/airygen-app.js
msgid "Include x-default"
msgstr "x-default शामिल करें"

#: build/admin/airygen-app.js
msgid "Use your main language page as the fallback."
msgstr "अपनी मुख्य भाषा पेज को fallback के रूप में उपयोग करें।"

#: build/admin/airygen-app.js
msgid "Sitemap"
msgstr "साइटमैप"

#: build/admin/airygen-app.js
msgid "Choose which content types appear in your XML sitemaps and tune pagination."
msgstr "चुनें कि आपके XML sitemap में कौन से सामग्री प्रकार प्रदर्शित होते हैं और पेजिनेशन ट्यून करें।"

#: build/admin/airygen-app.js
msgid "Choose which post types and taxonomies are included in your XML sitemaps."
msgstr "चुनें कि आपके XML sitemap में कौन से पोस्ट प्रकार और टैक्सोनॉमी शामिल हैं।"

#: build/admin/airygen-app.js
msgid "Exclude empty taxonomies"
msgstr "खाली taxonomies को बाहर रखें"

#: build/admin/airygen-app.js
msgid "Control sitemap pagination and preview the generated index."
msgstr "sitemap pagination नियंत्रित करें और generated index का preview देखें।"

#: build/admin/airygen-app.js
msgid "Items per sitemap page"
msgstr "प्रति sitemap पेज आइटम"

#: build/admin/airygen-app.js
msgid "Large sites should keep this lower to avoid memory issues on crawl."
msgstr "crawl के दौरान memory issues से बचने के लिए बड़ी साइटों को इसे कम रखना चाहिए।"

#: build/admin/airygen-app.js
msgid "Preview link"
msgstr "प्रीव्यू लिंक"

#: build/admin/airygen-app.js
msgid "Open in a new tab to verify the generated sitemap index."
msgstr "जनरेट किए गए sitemap index की पुष्टि के लिए नए टैब में खोलें।"

#: build/admin/airygen-app.js
msgid "Head"
msgstr "हेड"

#: build/admin/airygen-app.js
msgid "Snippets in this area are injected into the <head> section."
msgstr "इस क्षेत्र के स्निपेट्स <head> अनुभाग में inject किए जाते हैं।"

#: build/admin/airygen-app.js
msgid "Body"
msgstr "बॉडी"

#: build/admin/airygen-app.js
msgid "Snippets in this area are injected right after <body>."
msgstr "इस क्षेत्र के स्निपेट्स <body> के तुरंत बाद inject किए जाते हैं।"

#: build/admin/airygen-app.js
msgid "Footer"
msgstr "फ़ुटर"

#: build/admin/airygen-app.js
msgid "Snippets in this area are injected before </body>."
msgstr "इस क्षेत्र के स्निपेट्स </body> से पहले inject किए जाते हैं।"

#: build/admin/airygen-app.js
msgid "Disabled snippets staging area"
msgstr "अक्षम स्निपेट्स स्टेजिंग क्षेत्र"

#: build/admin/airygen-app.js
msgid "Keep snippets here when you do not want them rendered."
msgstr "जब आप नहीं चाहते कि स्निपेट रेंडर हों, तो उन्हें यहाँ रखें।"

#: build/admin/airygen-app.js
msgid "No description"
msgstr "कोई विवरण नहीं"

#: build/admin/airygen-app.js
msgid "Code Snippets"
msgstr "कोड स्निपेट्स"

#: build/admin/airygen-app.js
msgid "Configure GA4, GTM, and custom tracking snippets for your site."
msgstr "अपनी साइट के लिए GA4, GTM और custom tracking snippets कॉन्फ़िगर करें।"

#: build/admin/airygen-app.js
msgid "Paste tracking IDs. Airygen SEO prints GA4/GTM tags automatically when IDs are set."
msgstr "tracking IDs पेस्ट करें। IDs सेट होने पर Airygen SEO स्वतः GA4/GTM tags प्रिंट करता है।"

#: build/admin/airygen-app.js
msgid "Google Analytics 4"
msgstr "Google Analytics 4"

#: build/admin/airygen-app.js
msgid "Enable GA4 tracking"
msgstr "GA4 tracking सक्षम करें"

#: build/admin/airygen-app.js
msgid "Measurement ID"
msgstr "मापन ID"

#. translators: %s is an HTML code tag for the GA4 ID prefix (G-).
#: build/admin/airygen-app.js
#, js-format
msgid "Paste your Google Analytics 4 ID from Google Analytics Admin. It usually starts with %s."
msgstr "Google Analytics Admin से अपनी Google Analytics 4 ID पेस्ट करें। यह आमतौर पर %s से शुरू होती है।"

