#: build/admin/airygen-app.js
msgid "Broken Link Checker"
msgstr "Verificador de Links Quebrados"

#: build/admin/airygen-app.js
msgid "Scan content for broken and redirected links, and monitor crawl health."
msgstr "Verificar conteúdo para links quebrados e redirecionados, e monitorar saúde do rastreamento."

#: build/admin/airygen-app.js
msgid "Link Counter must be enabled to gather internal link data."
msgstr "O Contador de Links deve estar habilitado para coletar dados de links internos."

#: build/admin/airygen-app.js
msgid "Tune scan frequency and limits. Lower numbers are safer on shared hosts."
msgstr "Ajustar frequência e limites de verificação. Números menores são mais seguros em hospedagens compartilhadas."

#: build/admin/airygen-app.js
msgid "How often the scanner runs. Set higher on large sites."
msgstr "Com que frequência o scanner é executado. Defina valores mais altos em sites grandes."

#: build/admin/airygen-app.js
msgid "Max requests per run"
msgstr "Solicitações máximas por execução"

#: build/admin/airygen-app.js
msgid "Limits simultaneous HTTP requests during a scan."
msgstr "Limita solicitações HTTP simultâneas durante uma verificação."

#: build/admin/airygen-app.js
msgid "Pause between request batches to reduce load."
msgstr "Pausar entre lotes de solicitações para reduzir carga."

#: build/admin/airygen-app.js
msgid "Older log entries are deleted automatically."
msgstr "Entradas de log mais antigas são excluídas automaticamente."

#: build/admin/airygen-app.js
msgid "Max time to open a connection before aborting."
msgstr "Tempo máximo para abrir uma conexão antes de abortar."

#: build/admin/airygen-app.js
msgid "Max time to complete a request before aborting."
msgstr "Tempo máximo para concluir uma solicitação antes de abortar."

#: build/admin/airygen-app.js
msgid "Treat redirects as warnings"
msgstr "Tratar redirecionamentos como avisos"

#: build/admin/airygen-app.js
msgid "When on, redirected links are flagged but not counted as errors."
msgstr "Quando ligado, links redirecionados são sinalizados mas não contados como erros."

#: build/admin/airygen-app.js
msgid "Choose which link types are included in broken-link scans."
msgstr "Escolha quais tipos de link estão incluídos nas varreduras de links quebrados."

#: build/admin/airygen-app.js
msgid "Link types to scan"
msgstr "Tipos de link para verificar"

#: build/admin/airygen-app.js
