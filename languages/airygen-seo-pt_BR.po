msgstr "Revisar verificações recentes de links e ir para posts afetados."

#: build/admin/airygen-app.js
msgid "Filters"
msgstr "Filtros"

#: build/admin/airygen-app.js
msgid "Toggle which statuses appear in the log."
msgstr "Alternar quais status aparecem no log."

