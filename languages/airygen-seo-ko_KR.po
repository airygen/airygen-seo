#: build/admin/airygen-app.js
msgid "Measurement ID"
msgstr "측정 ID"

#. translators: %s is an HTML code tag for the GA4 ID prefix (G-).
#: build/admin/airygen-app.js
#, js-format
msgid "Paste your Google Analytics 4 ID from Google Analytics Admin. It usually starts with %s."
msgstr "Google Analytics 관리자에서 Google Analytics 4 ID를 붙여넣으세요. 일반적으로 %s로 시작합니다."

#: build/admin/airygen-app.js
msgid "Google Tag Manager"
