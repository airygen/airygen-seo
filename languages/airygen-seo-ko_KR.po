msgstr "Airygen은 WPML/Polylang을 자동으로 사용할 수 있으며 여기에 수동 매핑을 추가할 수 있습니다."

#: build/admin/airygen-app.js
msgid "manual alternates"
msgstr "수동 대체"

#: build/admin/airygen-app.js
msgid "languages"
msgstr "언어"

