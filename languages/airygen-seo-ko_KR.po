msgstr "변경 사항 저장"

#: build/admin/airygen-app.js
msgid "Internal reference only. This is not output on the frontend."
msgstr "내부 참조용입니다. 프론트엔드에는 출력되지 않습니다."

#: build/admin/airygen-app.js
msgid "Code"
msgstr "코드"

#. translators: %s is an HTML code tag for script tags (<script>).
#: build/admin/airygen-app.js
#, js-format
msgid "Paste code only. Do not include %s tags."
msgstr "코드만 붙여넣으세요. %s 태그는 포함하지 마세요."

