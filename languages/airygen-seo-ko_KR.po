msgstr "정규 URL 태그를 출력합니다."

#: build/admin/airygen-app.js
msgid "Robots meta"
msgstr "Robots 메타"

#: build/admin/airygen-app.js
msgid "Outputs a robots tag when custom directives are set."
msgstr "사용자 정의 지시문이 설정되면 robots 태그를 출력합니다."

#: build/admin/airygen-app.js
msgid "Set the default title and description templates used when posts are missing custom SEO fields."
msgstr "게시물에 사용자 정의 SEO 필드가 없을 때 사용되는 기본 제목 및 설명 템플릿을 설정하세요."

#: build/admin/airygen-app.js
msgid "Default title template"
msgstr "기본 제목 템플릿"

#: build/admin/airygen-app.js
