msgstr "게시물에 사용자 정의 SEO 제목이 없을 때 대체 제목을 제어합니다."

#: build/admin/airygen-app.js
msgid "Default description template"
msgstr "기본 설명 템플릿"

#: build/admin/airygen-app.js
msgid "Controls the fallback description when a post has no custom SEO description."
msgstr "게시물에 사용자 정의 SEO 설명이 없을 때 대체 설명을 제어합니다."

#: build/admin/airygen-app.js
msgid "Separator"
msgstr "구분 기호"

