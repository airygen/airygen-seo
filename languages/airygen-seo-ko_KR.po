#: build/admin/airygen-app.js
msgid "Google verification"
msgstr "Google 인증"

#: build/admin/airygen-app.js
msgid "google-site-verification token"
msgstr "google-site-verification 토큰"

#: build/admin/airygen-app.js
msgid "Bing verification"
msgstr "Bing 인증"

#: build/admin/airygen-app.js
msgid "msvalidate.01 token"
msgstr "msvalidate.01 토큰"

#: build/admin/airygen-app.js
msgid "Yandex verification"
msgstr "Yandex 인증"

#: build/admin/airygen-app.js
msgid "yandex-verification token"
msgstr "yandex-verification 토큰"

#: build/admin/airygen-app.js
msgid "Baidu verification"
msgstr "Baidu 인증"

#: build/admin/airygen-app.js
msgid "baidu-site-verification token"
msgstr "baidu-site-verification 토큰"

#: build/admin/airygen-app.js
msgid "Pinterest verification"
msgstr "Pinterest 인증"

#: build/admin/airygen-app.js
msgid "p:domain_verify token"
msgstr "p:domain_verify 토큰"

#: build/admin/airygen-app.js
msgid "RSS Feed Signature"
msgstr "RSS 피드 서명"

#: build/admin/airygen-app.js
msgid "Add branding or attribution snippets to your RSS feed entries."
msgstr "RSS 피드 항목에 브랜딩 또는 출처 표시 스니펫을 추가하세요."

