msgstr "토큰만 사용하여 TITLE 템플릿을 빌드합니다."

#: build/admin/airygen-app.js
msgid "Template settings"
msgstr "템플릿 설정"

#: build/admin/airygen-app.js
msgid "Define shared tokens used by your image templates."
msgstr "이미지 템플릿에서 사용하는 공유 토큰을 정의하세요."

