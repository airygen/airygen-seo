#: build/admin/airygen-app.js
#, js-format
msgid "No %1$s yet. Add %2$s to override %3$s."
msgstr "아직 %1$s가 없습니다. %3$s을(를) 재정의하려면 %2$s를 추가하세요."

#: build/admin/airygen-app.js
msgid "Language code"
msgstr "언어 코드"

#: build/admin/airygen-app.js
msgid "Language URL"
msgstr "언어 URL"

#: build/admin/airygen-app.js
