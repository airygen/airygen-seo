#: build/admin/airygen-app.js
msgid "Image SEO"
msgstr "이미지 SEO"

#: build/admin/airygen-app.js
msgid "Automatically add missing ALT and TITLE attributes with templated values."
msgstr "템플릿 값으로 누락된 ALT 및 TITLE 속성을 자동으로 추가합니다."

