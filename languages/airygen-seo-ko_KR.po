msgstr "%s에서 사용하는 값을 설정합니다. 생략하려면 비워 두세요."

#: build/admin/airygen-app.js
msgid "Custom token 2"
msgstr "사용자 정의 토큰 2"

#: build/admin/airygen-app.js
msgid "Custom token 3"
msgstr "사용자 정의 토큰 3"

#: build/admin/airygen-app.js
msgid "Per post type overrides"
msgstr "게시물 유형별 재정의"

#: build/admin/airygen-app.js
msgid "Override the global template for specific post types. Separator and custom tokens reuse the values set above."
msgstr "특정 게시물 유형에 대해 전역 템플릿을 재정의합니다. 구분 기호 및 사용자 정의 토큰은 위에 설정된 값을 재사용합니다."

#: build/admin/airygen-app.js
msgid "Please configure this in WooCommerce SEO settings."
msgstr "WooCommerce SEO 설정에서 이것을 구성하세요."

#: build/admin/airygen-app.js
msgid "Title template"
msgstr "제목 템플릿"

#: build/admin/airygen-app.js
msgid "Override the default title template for this post type."
msgstr "이 게시물 유형의 기본 제목 템플릿을 재정의합니다."

#: build/admin/airygen-app.js
msgid "Description template"
msgstr "설명 템플릿"

#: build/admin/airygen-app.js
msgid "Override the default description template for this post type."
msgstr "이 게시물 유형의 기본 설명 템플릿을 재정의합니다."

#: build/admin/airygen-app.js
msgid "Blog"
msgstr "블로그"

#: build/admin/airygen-app.js
msgid "Example post"
msgstr "예제 게시물"

#: build/admin/airygen-app.js
msgid "Breadcrumbs"
msgstr "브레드크럼"

#: build/admin/airygen-app.js
msgid "Configure the on-page breadcrumb trail and labels used in Schema."
msgstr "스키마에서 사용되는 페이지 내 브레드크럼 트레일 및 레이블을 구성하세요."

#: build/admin/airygen-app.js
msgid "Control which parts of the trail are shown and how separators render."
msgstr "트레일의 어떤 부분이 표시되고 구분 기호가 렌더링되는 방식을 제어합니다."

#: build/admin/airygen-app.js
msgid "Enable manual breadcrumbs output"
msgstr "브레드크럼 수동 출력 활성화"

#: build/admin/airygen-app.js
msgid "Enable template function, shortcode, and block output for breadcrumb trail rendering."
msgstr "브레드크럼 경로 렌더링을 위한 템플릿 함수, 쇼트코드 및 블록 출력을 활성화합니다."

#: build/admin/airygen-app.js
msgid "Enable automatic breadcrumbs injection"
msgstr "브레드크럼 자동 삽입 활성화"

#: build/admin/airygen-app.js
msgid "Automatically insert breadcrumbs into post content based on the selected position."
msgstr "선택한 위치에 따라 브레드크럼을 게시물 콘텐츠에 자동 삽입합니다."

#: build/admin/airygen-app.js
msgid "Choose where automatic breadcrumb output appears in the main content area."
msgstr "기본 콘텐츠 영역에서 자동 브레드크럼 출력이 표시될 위치를 선택하세요."

#: build/admin/airygen-app.js
msgid "Show current page"
msgstr "현재 페이지 표시"

#: build/admin/airygen-app.js
msgid "Include the current page as the final breadcrumb (also affects the JSON-LD breadcrumb list)."
msgstr "현재 페이지를 최종 브레드크럼으로 포함합니다 (JSON-LD 브레드크럼 목록에도 영향을 줍니다)."

#: build/admin/airygen-app.js
msgid "Show pagination"
msgstr "페이지 매김 표시"

#: build/admin/airygen-app.js
msgid "Append the current page number when viewing paged archives (hidden from schema by default)."
msgstr "페이지가 나뉜 아카이브를 볼 때 현재 페이지 번호를 추가합니다 (기본적으로 스키마에서 숨겨짐)."

#: build/admin/airygen-app.js
msgid "Shown between each breadcrumb item."
msgstr "각 브레드크럼 항목 사이에 표시됩니다."

#: build/admin/airygen-app.js
msgid "Prefix"
msgstr "접두사"

#: build/admin/airygen-app.js
msgid "Text shown before the breadcrumb trail (e.g., \"You are here\")."
msgstr "브레드크럼 트레일 앞에 표시되는 텍스트 (예: \"현재 위치\")입니다."

#: build/admin/airygen-app.js
msgid "Container"
msgstr "컨테이너"

#: build/admin/airygen-app.js
msgid "Adjust the breadcrumb container box style."
msgstr "브레드크럼 컨테이너 박스 스타일을 조정하세요."

#: build/admin/airygen-app.js
msgid "Container background color"
msgstr "컨테이너 배경색"

#: build/admin/airygen-app.js
msgid "Trail"
msgstr "트레일"

#: build/admin/airygen-app.js
msgid "Adjust text and link styling for the breadcrumb trail."
msgstr "브레드크럼 경로의 텍스트 및 링크 스타일을 조정하세요."

#: build/admin/airygen-app.js
msgid "Text color"
msgstr "텍스트 색상"

#: build/admin/airygen-app.js
msgid "Link color"
msgstr "링크 색상"

#: build/admin/airygen-app.js
msgid "Underline links"
msgstr "링크에 밑줄"

#: build/admin/airygen-app.js
msgid "Enable underline styling for breadcrumb links."
msgstr "브레드크럼 링크에 밑줄 스타일을 활성화합니다."

#: build/admin/airygen-app.js
msgid "This is how the breadcrumb trail will appear with the current style settings."
msgstr "현재 스타일 설정으로 브레드크럼 트레일이 표시되는 방식입니다."

#: build/admin/airygen-app.js
msgid "Hierarchy"
msgstr "계층 구조"

#: build/admin/airygen-app.js
msgid "Fine-tune which links appear in the chain."
msgstr "체인에 나타나는 링크를 미세 조정하세요."

#: build/admin/airygen-app.js
msgid "Show home link"
msgstr "홈 링크 표시"

#: build/admin/airygen-app.js
msgid "Start the trail with your homepage label and URL."
msgstr "홈페이지 레이블과 URL로 트레일을 시작합니다."

#: build/admin/airygen-app.js
msgid "Show blog link on archives"
msgstr "아카이브에 블로그 링크 표시"

#: build/admin/airygen-app.js
msgid "Include the Posts page before archive items when a static blog page is set."
msgstr "정적 블로그 페이지가 설정된 경우 아카이브 항목 앞에 게시물 페이지를 포함합니다."

#: build/admin/airygen-app.js
msgid "Show ancestor pages"
msgstr "조상 페이지 표시"

#: build/admin/airygen-app.js
msgid "Add parent pages for hierarchical content types (pages, hierarchical CPTs)."
msgstr "계층 구조 콘텐츠 유형(페이지, 계층 구조 CPT)에 상위 페이지를 추가하세요."

#: build/admin/airygen-app.js
msgid "Hide taxonomy parents"
msgstr "분류 부모 숨기기"

#: build/admin/airygen-app.js
msgid "Skip parent terms in category/tag hierarchies to keep the trail compact."
msgstr "트레일을 간결하게 유지하기 위해 카테고리/태그 계층 구조에서 부모 용어를 건너뜁니다."

#: build/admin/airygen-app.js
msgid "Labels"
msgstr "레이블"

#: build/admin/airygen-app.js
msgid "Customize how archives, search results, and 404 pages appear in the trail."
msgstr "트레일에서 아카이브, 검색 결과 및 404 페이지가 표시되는 방식을 사용자 정의하세요."

#: build/admin/airygen-app.js
msgid "Home label"
msgstr "홈 레이블"

#: build/admin/airygen-app.js
msgid "Label used for the homepage breadcrumb."
msgstr "홈페이지 브레드크럼에 사용되는 레이블입니다."

#: build/admin/airygen-app.js
msgid "Archive label"
msgstr "아카이브 레이블"

#: build/admin/airygen-app.js
msgid "Used for archive pages (category, tag, taxonomy, post type archives)."
msgstr "아카이브 페이지 (카테고리, 태그, 분류, 게시물 유형 아카이브)에 사용됩니다."

#: build/admin/airygen-app.js
msgid "Search results label"
msgstr "검색 결과 레이블"

#: build/admin/airygen-app.js
msgid "Shown when viewing the search results page."
msgstr "검색 결과 페이지를 볼 때 표시됩니다."

#. translators: %s is an HTTP status code and should remain numeric, e.g. 404.
#: build/admin/airygen-app.js
#, js-format
msgid "%s label"
msgstr "%s 레이블"

#: build/admin/airygen-app.js
msgid "Shown for not found pages (404 responses)."
msgstr "찾을 수 없는 페이지 (404 응답)에 표시됩니다."

#: build/admin/airygen-app.js
msgid "Social Media Tags"
msgstr "소셜 미디어 태그"

#: build/admin/airygen-app.js
msgid "Provide defaults for social share images and Twitter handles when per-post values are missing."
msgstr "게시물별 값이 없을 때 소셜 공유 이미지 및 Twitter 핸들에 대한 기본값을 제공합니다."

#: build/admin/airygen-app.js
msgid "Open Graph"
msgstr "Open Graph"

#: build/admin/airygen-app.js
msgid "Enable Open Graph"
msgstr "Open Graph 활성화"

#: build/admin/airygen-app.js
msgid "When off, the site outputs no og:* tags. Threads and LinkedIn also rely on Open Graph, so their link previews will be affected."
msgstr "비활성화되면 사이트는 og:* 태그를 출력하지 않습니다. Threads 및 LinkedIn도 Open Graph에 의존하므로 링크 미리보기가 영향을 받습니다."

#: build/admin/airygen-app.js
msgid "Default image — URL"
msgstr "기본 이미지 — URL"

#: build/admin/airygen-app.js
msgid "Default image — Attachment ID"
msgstr "기본 이미지 — 첨부 파일 ID"

#: build/admin/airygen-app.js
msgid "Select an image from the Media Library. If both URL and ID are set, the Attachment ID takes precedence. Set to 0 to disable."
msgstr "미디어 라이브러리에서 이미지를 선택하세요. URL과 ID가 모두 설정된 경우 첨부 파일 ID가 우선합니다. 비활성화하려면 0으로 설정하세요."

#: build/admin/airygen-app.js
msgid "Publisher URL"
msgstr "게시자 URL"

#: build/admin/airygen-app.js
msgid "Optional canonical publisher page for social networks."
msgstr "소셜 네트워크를 위한 선택적 정규 게시자 페이지입니다."

#: build/admin/airygen-app.js
msgid "Optional width to help caching. Suggested value: 1200."
msgstr "캐싱을 돕기 위한 선택적 너비. 권장 값: 1200."

#: build/admin/airygen-app.js
msgid "Optional height to help caching. Suggested value: 630."
msgstr "캐싱을 돕기 위한 선택적 높이. 권장 값: 630."

#: build/admin/airygen-app.js
msgid "Domain verification"
msgstr "도메인 인증"

#: build/admin/airygen-app.js
msgid "Paste the Meta (Facebook/Instagram) Business Manager verification token to prove domain ownership. This helps Meta trust your og: tags and unlocks domain insights."
msgstr "도메인 소유권을 증명하기 위해 Meta (Facebook/Instagram) Business Manager 확인 토큰을 붙여넣으세요. 이것은 Meta가 og: 태그를 신뢰하고 도메인 인사이트를 잠금 해제하는 데 도움이 됩니다."

#: build/admin/airygen-app.js
msgid "Connect your Facebook App for advanced analytics and verification."
msgstr "고급 분석 및 확인을 위해 Facebook 앱을 연결하세요."

#: build/admin/airygen-app.js
msgid "Comma-separated Facebook admin IDs so those accounts can access Page Insights for your domain. IDs are visible in page source, so only add them if you are fine with that exposure."
msgstr "쉼표로 구분된 Facebook 관리자 ID로 해당 계정이 도메인에 대한 페이지 인사이트에 접근할 수 있습니다. ID는 페이지 소스에서 볼 수 있으므로 노출이 괜찮은 경우에만 추가하세요."

#: build/admin/airygen-app.js
msgid "Twitter"
msgstr "Twitter"

#: build/admin/airygen-app.js
msgid "Enable Twitter Cards"
msgstr "Twitter 카드 활성화"

#: build/admin/airygen-app.js
msgid "When off, the site outputs no twitter:* tags."
msgstr "비활성화되면 사이트는 twitter:* 태그를 출력하지 않습니다."

#: build/admin/airygen-app.js
msgid "Default card type"
msgstr "기본 카드 유형"

#. translators: 1: HTML code tag for summary_large_image, 2: HTML code tag for summary.
#: build/admin/airygen-app.js
msgid "Twitter site handle"
msgstr "Twitter 사이트 핸들"

#: build/admin/airygen-app.js
msgid "Brand account. Enter with or without @. Will be normalized on save."
msgstr "브랜드 계정. @를 포함하거나 포함하지 않고 입력하세요. 저장 시 정규화됩니다."

#: build/admin/airygen-app.js
msgid "Twitter creator handle"
msgstr "Twitter 크리에이터 핸들"

#: build/admin/airygen-app.js
msgid "Author/creator account. Enter with or without @. Will be normalized on save."
msgstr "작성자/크리에이터 계정. @를 포함하거나 포함하지 않고 입력하세요. 저장 시 정규화됩니다."

#: build/admin/airygen-app.js
msgid "Inherit Open Graph image"
msgstr "Open Graph 이미지 상속"

