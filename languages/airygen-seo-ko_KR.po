msgstr "Action Scheduler 누락"

#: build/admin/airygen-app.js
msgid "Unable to load status."
msgstr "상태를 로드할 수 없습니다."

#: build/admin/airygen-app.js
msgid "Instant Indexing"
msgstr "즉시 색인 생성"

#: build/admin/airygen-app.js
msgid "Submit URLs to supported search engines via IndexNow and monitor delivery."
msgstr "IndexNow를 통해 지원되는 검색 엔진에 URL을 제출하고 전달을 모니터링합니다."

#: build/admin/airygen-app.js
msgid "Set your IndexNow key and submission limits so search engines can receive updates faster."
msgstr "검색 엔진이 업데이트를 더 빠르게 받을 수 있도록 IndexNow 키 및 제출 제한을 설정하세요."

#: build/admin/airygen-app.js
msgid "Enable Instant Indexing"
msgstr "즉시 색인 생성 활성화"

