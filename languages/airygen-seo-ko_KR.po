#: build/admin/airygen-app.js
msgid "Add missing title attributes"
msgstr "누락된 title 속성 추가"

#: build/admin/airygen-app.js
msgid "TITLE attribute template"
msgstr "TITLE 속성 템플릿"

#: build/admin/airygen-app.js
