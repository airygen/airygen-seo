msgid "Status of Airygen SEO health checks, mirroring the Site Health Status page."
msgstr "Stato dei controlli di salute di Airygen SEO, che rispecchia la pagina Stato Salute Sito."

msgid "Airygen SEO could not compute this diagnostic."
msgstr "Airygen SEO non ha potuto calcolare questa diagnostica."

msgid "Airygen sitemap is reachable"
msgstr "La sitemap Airygen è raggiungibile"

msgid "Airygen SEO confirmed the custom sitemap endpoint responded successfully."
msgstr "Airygen SEO ha confermato che l'endpoint della sitemap personalizzata ha risposto correttamente."

msgid "Open sitemap"
msgstr "Apri sitemap"

msgid "Sitemap request failed"
msgstr "Richiesta sitemap fallita"

msgid "Airygen SEO could not reach the custom sitemap endpoint."
msgstr "Airygen SEO non ha potuto raggiungere l'endpoint della sitemap personalizzata."

msgid "Airygen sitemap returned an unexpected status"
msgstr "La sitemap Airygen ha restituito uno stato inatteso"

msgid "The custom sitemap endpoint responded, but did not return a 2xx status code."
msgstr "L’endpoint sitemap personalizzato ha risposto, ma non ha restituito un codice di stato 2xx."

msgid "Airygen sitemap disabled"
msgstr "Sitemap Airygen disabilitata"

msgid "The Airygen sitemap module is disabled. Enable it under Airygen SEO settings to serve /sitemap.xml."
msgstr "Il modulo sitemap di Airygen è disabilitato. Abilitalo nelle impostazioni di Airygen SEO per servire /sitemap.xml."

msgid "WordPress sitemap is reachable"
msgstr "La sitemap WordPress è raggiungibile"

msgid "Airygen SEO confirmed the core sitemap endpoint responded successfully."
msgstr "Airygen SEO ha confermato che l'endpoint della sitemap principale ha risposto correttamente."

msgid "Core sitemap appears disabled"
msgstr "La sitemap principale sembra disabilitata"

msgid "WordPress reported that the core sitemap feature is disabled. If this is intentional, no action is required."
msgstr "WordPress ha segnalato che la funzionalità sitemap principale è disabilitata. Se questo è intenzionale, non è richiesta alcuna azione."

msgid "Core sitemap request failed"
msgstr "Richiesta sitemap principale fallita"

msgid "Airygen SEO could not reach the WordPress core sitemap endpoint."
msgstr "Airygen SEO non ha potuto raggiungere l'endpoint della sitemap principale di WordPress."

msgid "Core sitemap returned an unexpected status"
msgstr "La sitemap principale ha restituito uno stato inatteso"

msgid "The sitemap endpoint responded, but did not return a 2xx status code."
msgstr "L'endpoint della sitemap ha risposto, ma non ha restituito un codice di stato 2xx."

msgid "Score Calculator endpoint is healthy"
msgstr "L'endpoint Calcolatore Punteggio è corretto"

msgid "Airygen SEO successfully queried the scoring endpoint."
msgstr "Airygen SEO ha interrogato con successo l'endpoint di punteggio."

msgid "Score Calculator REST route missing"
msgstr "Route REST Calcolatore Punteggio mancante"

msgid "The /airygen/v1/score route is not registered. Ensure the Score Calculator module is enabled."
msgstr "La route /airygen/v1/score non è registrata. Assicurati che il modulo Calcolatore Punteggio sia abilitato."

msgid "No published posts available for scoring"
msgstr "Nessun articolo pubblicato disponibile per la valutazione"

msgid "Airygen SEO could not find a published post to test the scoring endpoint."
msgstr "Airygen SEO non ha potuto trovare un articolo pubblicato per testare l'endpoint di punteggio."

msgid "Score Calculator endpoint returned an error"
msgstr "L'endpoint Calcolatore Punteggio ha restituito un errore"

msgid "The scoring endpoint responded with an error when requested."
msgstr "L'endpoint di punteggio ha risposto con un errore quando richiesto."

msgid "Score Calculator endpoint returned an unexpected status"
msgstr "L'endpoint Calcolatore Punteggio ha restituito uno stato inatteso"

msgid "The scoring endpoint responded, but did not return a 2xx HTTP status."
msgstr "L'endpoint di punteggio ha risposto, ma non ha restituito uno stato HTTP 2xx."

msgid "Score Calculator endpoint status unknown"
msgstr "Stato endpoint Calcolatore Punteggio sconosciuto"

msgid "Airygen SEO could not confirm the scoring endpoint status."
msgstr "Airygen SEO non ha potuto confermare lo stato dell'endpoint di punteggio."

msgid "Robots visibility is healthy"
msgstr "La visibilità robots è corretta"

msgid "Search engines are allowed to index this site."
msgstr "Ai motori di ricerca è consentito indicizzare questo sito."

msgid "WordPress is set to discourage indexing"
msgstr "WordPress è impostato per scoraggiare l'indicizzazione"

msgid "The “Discourage search engines from indexing” option is enabled. Disable it in Settings → Reading for production sites."
msgstr "L’opzione «Scoraggia i motori di ricerca dall’indicizzazione» è abilitata. Disabilitala in Impostazioni → Lettura per i siti in produzione."

msgid "Open Reading Settings"
msgstr "Apri Impostazioni Lettura"

msgid "Airygen SEO default robots directive blocks indexing"
msgstr "La direttiva robots predefinita di Airygen SEO blocca l'indicizzazione"

msgid "The Airygen SEO robots settings apply a noindex directive by default. Update the setting if this site should be indexable."
msgstr "Le impostazioni robots di Airygen SEO applicano una direttiva noindex per impostazione predefinita. Aggiorna l’impostazione se questo sito deve essere indicizzabile."

msgid "Open Airygen SEO settings"
msgstr "Apri impostazioni Airygen SEO"

msgid "Non-production environment detected"
msgstr "Ambiente non di produzione rilevato"

msgid "Search engine visibility checks are informational outside production environments."
msgstr "I controlli di visibilità sui motori di ricerca sono informativi al di fuori degli ambienti di produzione."

msgid "Permalink structure includes post names"
msgstr "La struttura permalink include i nomi degli articoli"

msgid "Your permalinks include %postname%, which is ideal for SEO."
msgstr "I tuoi permalink includono %postname%, che è ideale per il SEO."

msgid "Pretty permalinks are disabled"
msgstr "I pretty permalink sono disabilitati"

msgid "Switch to a custom permalink structure instead of the default ?p=ID format."
msgstr "Passa a una struttura permalink personalizzata invece del formato predefinito ?p=ID."

msgid "Open Permalink Settings"
msgstr "Apri Impostazioni Permalink"

msgid "Post names missing from permalinks"
msgstr "Nomi articoli mancanti dai permalink"

msgid "Use a custom structure containing %postname% for better readability and SEO."
msgstr "Usa una struttura personalizzata contenente %postname% per una migliore leggibilità e SEO."

