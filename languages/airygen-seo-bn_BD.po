#: build/admin/airygen-app.js
msgid "Title tag"
msgstr "শিরোনাম ট্যাগ"

#: build/admin/airygen-app.js
msgid "Outputs a title tag when a title is available."
msgstr "শিরোনাম পাওয়া গেলে একটি শিরোনাম ট্যাগ আউটপুট করে।"

#: build/admin/airygen-app.js
msgid "Outputs a description tag when a description exists."
