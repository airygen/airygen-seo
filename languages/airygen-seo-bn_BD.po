#: build/admin/airygen-app.js
msgid "Outputs a canonical URL tag."
msgstr "একটি ক্যানোনিক্যাল URL ট্যাগ আউটপুট করে।"

#: build/admin/airygen-app.js
msgid "Robots meta"
msgstr "Robots মেটা"

#: build/admin/airygen-app.js
msgid "Outputs a robots tag when custom directives are set."
msgstr "কাস্টম নির্দেশনা সেট থাকলে একটি robots ট্যাগ আউটপুট করে।"

#: build/admin/airygen-app.js
msgid "Set the default title and description templates used when posts are missing custom SEO fields."
msgstr "পোস্টে কাস্টম SEO ক্ষেত্র না থাকলে ব্যবহৃত ডিফল্ট শিরোনাম ও বর্ণনা টেমপ্লেট সেট করুন।"

#: build/admin/airygen-app.js
msgid "Default title template"
msgstr "ডিফল্ট শিরোনাম টেমপ্লেট"

#: build/admin/airygen-app.js
msgid "Controls the fallback title when a post has no custom SEO title."
msgstr "কোনো post-এ custom SEO title না থাকলে fallback title নিয়ন্ত্রণ করে।"

#: build/admin/airygen-app.js
msgid "Default description template"
msgstr "ডিফল্ট বর্ণনা টেমপ্লেট"

#: build/admin/airygen-app.js
msgid "Controls the fallback description when a post has no custom SEO description."
msgstr "কোনো post-এ custom SEO description না থাকলে fallback description নিয়ন্ত্রণ করে।"

#: build/admin/airygen-app.js
msgid "Separator"
msgstr "বিভাজক"

#. translators: %s is the template token placeholder wrapped in a code tag.
#: build/admin/airygen-app.js
#, js-format
msgid "Inserted between token values when you add %s. One space is added on both sides automatically."
msgstr "%s যোগ করলে টোকেন মানের মধ্যে ঢোকানো হয়। উভয় পাশে স্বয়ংক্রিয়ভাবে একটি স্পেস যোগ হয়।"

#: build/admin/airygen-app.js
msgid "Custom token 1"
msgstr "কাস্টম token 1"

#. translators: %s is the template token placeholder wrapped in a code tag.
#. translators: %s is the template token placeholder.
#: build/admin/airygen-app.js
#, js-format
msgid "Sets the value used by %s. Leave blank to omit it."
msgstr "%s দ্বারা ব্যবহৃত মান সেট করে। বাদ দিতে খালি রাখুন।"

#: build/admin/airygen-app.js
msgid "Custom token 2"
msgstr "কাস্টম token 2"

#: build/admin/airygen-app.js
msgid "Custom token 3"
msgstr "কাস্টম token 3"

#: build/admin/airygen-app.js
msgid "Per post type overrides"
msgstr "পোস্ট ধরন প্রতি ওভাররাইড"

#: build/admin/airygen-app.js
msgid "Override the global template for specific post types. Separator and custom tokens reuse the values set above."
msgstr "নির্দিষ্ট পোস্ট ধরনের জন্য গ্লোবাল টেমপ্লেট ওভাররাইড করুন। বিভাজক ও কাস্টম টোকেন উপরে সেট করা মান পুনরায় ব্যবহার করে।"

#: build/admin/airygen-app.js
msgid "Please configure this in WooCommerce SEO settings."
msgstr "অনুগ্রহ করে WooCommerce SEO সেটিংসে এটি কনফিগার করুন।"

#: build/admin/airygen-app.js
msgid "Title template"
msgstr "শিরোনাম টেমপ্লেট"

#: build/admin/airygen-app.js
msgid "Override the default title template for this post type."
msgstr "এই পোস্ট ধরনের জন্য ডিফল্ট শিরোনাম টেমপ্লেট ওভাররাইড করুন।"

#: build/admin/airygen-app.js
msgid "Description template"
msgstr "বর্ণনা টেমপ্লেট"

#: build/admin/airygen-app.js
msgid "Override the default description template for this post type."
msgstr "এই পোস্ট ধরনের জন্য ডিফল্ট বর্ণনা টেমপ্লেট ওভাররাইড করুন।"

#: build/admin/airygen-app.js
msgid "Blog"
msgstr "ব্লগ"

#: build/admin/airygen-app.js
msgid "Example post"
msgstr "উদাহরণ পোস্ট"

#: build/admin/airygen-app.js
msgid "Breadcrumbs"
msgstr "ব্রেডক্রাম্ব"

#: build/admin/airygen-app.js
msgid "Configure the on-page breadcrumb trail and labels used in Schema."
msgstr "on-page ব্রেডক্রাম্ব trail এবং Schema-তে ব্যবহৃত labelগুলো কনফিগার করুন।"

#: build/admin/airygen-app.js
msgid "Control which parts of the trail are shown and how separators render."
msgstr "trail-এর কোন অংশ দেখানো হবে এবং separator কীভাবে render হবে তা নিয়ন্ত্রণ করুন।"

#: build/admin/airygen-app.js
msgid "Enable manual breadcrumbs output"
msgstr "ম্যানুয়াল breadcrumbs আউটপুট সক্রিয় করুন"

#: build/admin/airygen-app.js
msgid "Enable template function, shortcode, and block output for breadcrumb trail rendering."
msgstr "breadcrumb ট্রেইল রেন্ডারিংয়ের জন্য টেমপ্লেট ফাংশন, শর্টকোড এবং ব্লক আউটপুট সক্রিয় করুন।"

#: build/admin/airygen-app.js
msgid "Enable automatic breadcrumbs injection"
msgstr "স্বয়ংক্রিয় breadcrumbs ইনজেকশন সক্রিয় করুন"

#: build/admin/airygen-app.js
msgid "Automatically insert breadcrumbs into post content based on the selected position."
msgstr "নির্বাচিত অবস্থানের ভিত্তিতে ব্রেডক্রাম্বগুলো পোস্ট কনটেন্টে স্বয়ংক্রিয়ভাবে ইনসার্ট করুন।"

#: build/admin/airygen-app.js
msgid "Choose where automatic breadcrumb output appears in the main content area."
msgstr "main content area-তে automatic ব্রেডক্রাম্ব output কোথায় দেখাবে তা বেছে নিন।"

#: build/admin/airygen-app.js
msgid "Show current page"
msgstr "বর্তমান পৃষ্ঠা দেখান"

#: build/admin/airygen-app.js
msgid "Include the current page as the final breadcrumb (also affects the JSON-LD breadcrumb list)."
msgstr "বর্তমান পৃষ্ঠাকে শেষ breadcrumb হিসেবে অন্তর্ভুক্ত করুন (JSON-LD breadcrumb তালিকাকেও প্রভাবিত করে)।"

#: build/admin/airygen-app.js
msgid "Show pagination"
msgstr "পেজিনেশন দেখান"

#: build/admin/airygen-app.js
msgid "Append the current page number when viewing paged archives (hidden from schema by default)."
msgstr "পৃষ্ঠা করা আর্কাইভ দেখার সময় বর্তমান পৃষ্ঠার নম্বর যোগ করুন (ডিফল্টভাবে schema থেকে লুকানো)।"

#: build/admin/airygen-app.js
msgid "Shown between each breadcrumb item."
msgstr "প্রতিটি breadcrumb আইটেমের মধ্যে দেখানো।"

#: build/admin/airygen-app.js
msgid "Prefix"
msgstr "প্রিফিক্স"

#: build/admin/airygen-app.js
msgid "Text shown before the breadcrumb trail (e.g., \"You are here\")."
msgstr "breadcrumb ট্রেইলের আগে দেখানো টেক্সট (যেমন, \"আপনি এখানে আছেন\")।"

#: build/admin/airygen-app.js
msgid "Container"
msgstr "কনটেইনার"

#: build/admin/airygen-app.js
msgid "Adjust the breadcrumb container box style."
msgstr "ব্রেডক্রাম্ব কন্টেইনার বক্সের স্টাইল সামঞ্জস্য করুন।"

#: build/admin/airygen-app.js
msgid "Container background color"
msgstr "কনটেইনারের ব্যাকগ্রাউন্ড রঙ"

#: build/admin/airygen-app.js
msgid "Trail"
msgstr "ট্রেইল"

#: build/admin/airygen-app.js
msgid "Adjust text and link styling for the breadcrumb trail."
msgstr "ব্রেডক্রাম্ব ট্রেইলের টেক্সট ও লিংক স্টাইলিং সামঞ্জস্য করুন।"

#: build/admin/airygen-app.js
msgid "Text color"
msgstr "টেক্সট রং"

#: build/admin/airygen-app.js
msgid "Link color"
msgstr "লিংকের রং"

#: build/admin/airygen-app.js
msgid "Underline links"
msgstr "লিংক আন্ডারলাইন করুন"

#: build/admin/airygen-app.js
msgid "Enable underline styling for breadcrumb links."
msgstr "breadcrumb লিংকের জন্য আন্ডারলাইন স্টাইলিং সক্রিয় করুন।"

#: build/admin/airygen-app.js
msgid "This is how the breadcrumb trail will appear with the current style settings."
msgstr "বর্তমান স্টাইল সেটিংস দিয়ে breadcrumb ট্রেইল এভাবে দেখাবে।"

#: build/admin/airygen-app.js
msgid "Hierarchy"
msgstr "শ্রেণিবিন্যাস"

#: build/admin/airygen-app.js
msgid "Fine-tune which links appear in the chain."
msgstr "চেইনে কোন লিংক দেখাবে তা সূক্ষ্মভাবে সামঞ্জস্য করুন।"

#: build/admin/airygen-app.js
msgid "Show home link"
msgstr "হোম লিংক দেখান"

#: build/admin/airygen-app.js
msgid "Start the trail with your homepage label and URL."
msgstr "আপনার হোমপেজের লেবেল ও URL দিয়ে ট্রেইল শুরু করুন।"

#: build/admin/airygen-app.js
msgid "Show blog link on archives"
msgstr "আর্কাইভে ব্লগ লিংক দেখান"

#: build/admin/airygen-app.js
msgid "Include the Posts page before archive items when a static blog page is set."
msgstr "স্ট্যাটিক ব্লগ পৃষ্ঠা সেট থাকলে আর্কাইভ আইটেমের আগে Posts পৃষ্ঠা অন্তর্ভুক্ত করুন।"

#: build/admin/airygen-app.js
msgid "Show ancestor pages"
msgstr "পূর্বপুরুষ পৃষ্ঠাসমূহ দেখান"

#: build/admin/airygen-app.js
msgid "Add parent pages for hierarchical content types (pages, hierarchical CPTs)."
msgstr "hierarchical content type-এর জন্য প্যারেন্ট পেজ যোগ করুন (pages, hierarchical CPTs)।"

#: build/admin/airygen-app.js
msgid "Hide taxonomy parents"
msgstr "ট্যাক্সোনমি প্যারেন্ট লুকান"

#: build/admin/airygen-app.js
msgid "Skip parent terms in category/tag hierarchies to keep the trail compact."
msgstr "ট্রেইল সংক্ষিপ্ত রাখতে ক্যাটাগরি/ট্যাগ শ্রেণিবিন্যাসে প্যারেন্ট টার্ম এড়িয়ে যান।"

#: build/admin/airygen-app.js
msgid "Labels"
msgstr "লেবেলসমূহ"

#: build/admin/airygen-app.js
msgid "Customize how archives, search results, and 404 pages appear in the trail."
msgstr "trail-এ archive, search result ও 404 page কীভাবে দেখাবে তা কাস্টমাইজ করুন।"

#: build/admin/airygen-app.js
msgid "Home label"
msgstr "হোমের লেবেল"

#: build/admin/airygen-app.js
msgid "Label used for the homepage breadcrumb."
msgstr "হোমপেজের breadcrumb-এর জন্য ব্যবহৃত লেবেল।"

#: build/admin/airygen-app.js
msgid "Archive label"
msgstr "আর্কাইভ লেবেল"

#: build/admin/airygen-app.js
msgid "Used for archive pages (category, tag, taxonomy, post type archives)."
msgstr "আর্কাইভ পৃষ্ঠার জন্য ব্যবহৃত (ক্যাটাগরি, ট্যাগ, ট্যাক্সোনমি, পোস্ট ধরনের আর্কাইভ)।"

#: build/admin/airygen-app.js
msgid "Search results label"
msgstr "সার্চ ফলাফলের লেবেল"

#: build/admin/airygen-app.js
msgid "Shown when viewing the search results page."
msgstr "সার্চ ফলাফল পৃষ্ঠা দেখার সময় দেখানো।"

#. translators: %s is an HTTP status code and should remain numeric, e.g. 404.
#: build/admin/airygen-app.js
#, js-format
msgid "%s label"
msgstr "%s লেবেল"

#: build/admin/airygen-app.js
msgid "Shown for not found pages (404 responses)."
msgstr "পাওয়া যায়নি পৃষ্ঠার জন্য দেখানো (৪০৪ প্রতিক্রিয়া)।"

#: build/admin/airygen-app.js
msgid "Social Media Tags"
msgstr "সোশ্যাল মিডিয়া ট্যাগ"

#: build/admin/airygen-app.js
msgid "Provide defaults for social share images and Twitter handles when per-post values are missing."
msgstr "প্রতি-পোস্ট মান অনুপস্থিত হলে সোশ্যাল শেয়ার ছবি ও Twitter হ্যান্ডেলের ডিফল্ট প্রদান করুন।"

#: build/admin/airygen-app.js
msgid "Open Graph"
msgstr "Open Graph"

#: build/admin/airygen-app.js
msgid "Enable Open Graph"
msgstr "Open Graph সক্রিয় করুন"

#: build/admin/airygen-app.js
msgid "When off, the site outputs no og:* tags. Threads and LinkedIn also rely on Open Graph, so their link previews will be affected."
msgstr "বন্ধ হলে সাইট কোনো og:* ট্যাগ আউটপুট করে না। Threads ও LinkedIn-ও Open Graph-এর উপর নির্ভর করে, তাই তাদের লিংক প্রিভিউ প্রভাবিত হবে।"

#: build/admin/airygen-app.js
msgid "Default image — URL"
msgstr "ডিফল্ট ছবি — URL"

#: build/admin/airygen-app.js
msgid "Default image — Attachment ID"
msgstr "ডিফল্ট ছবি — অ্যাটাচমেন্ট ID"

#: build/admin/airygen-app.js
msgid "Select an image from the Media Library. If both URL and ID are set, the Attachment ID takes precedence. Set to 0 to disable."
msgstr "Media Library থেকে একটি ছবি নির্বাচন করুন। URL ও ID উভয় সেট থাকলে Attachment ID অগ্রাধিকার পায়। নিষ্ক্রিয় করতে ০ সেট করুন।"

#: build/admin/airygen-app.js
msgid "Publisher URL"
msgstr "প্রকাশকের URL"

#: build/admin/airygen-app.js
msgid "Optional canonical publisher page for social networks."
msgstr "সোশ্যাল নেটওয়ার্কের জন্য ঐচ্ছিক ক্যানোনিক্যাল প্রকাশক পৃষ্ঠা।"

#: build/admin/airygen-app.js
msgid "Optional width to help caching. Suggested value: 1200."
msgstr "ক্যাশিং সাহায্যের জন্য ঐচ্ছিক প্রস্থ। পরামর্শকৃত মান: ১২০০।"

#: build/admin/airygen-app.js
msgid "Optional height to help caching. Suggested value: 630."
msgstr "ক্যাশিং সাহায্যের জন্য ঐচ্ছিক উচ্চতা। পরামর্শকৃত মান: ৬৩০।"

#: build/admin/airygen-app.js
msgid "Domain verification"
msgstr "ডোমেইন যাচাইকরণ"

#: build/admin/airygen-app.js
msgid "Paste the Meta (Facebook/Instagram) Business Manager verification token to prove domain ownership. This helps Meta trust your og: tags and unlocks domain insights."
msgstr "ডোমেইনের মালিকানা প্রমাণ করতে Meta (Facebook/Instagram) Business Manager যাচাইকরণ টোকেন পেস্ট করুন। এটি Meta-কে আপনার og: ট্যাগ বিশ্বাস করতে এবং ডোমেইন ইনসাইট আনলক করতে সাহায্য করে।"

#: build/admin/airygen-app.js
msgid "Connect your Facebook App for advanced analytics and verification."
