msgstr "মাইন্ড ম্যাপ সেভ করার আগে প্রতিটি গ্রুপে ঠিক একটি L1 বিষয় থাকতে হবে।"

msgid "Every L2 or L3 topic must reference a valid parent in the same group."
msgstr "প্রতিটি L2 বা L3 বিষয়কে একই গ্রুপের একটি বৈধ প্যারেন্ট রেফারেন্স করতে হবে।"

msgid "L2 topics must reference an L1 parent."
msgstr "L2 বিষয়কে একটি L1 প্যারেন্ট রেফারেন্স করতে হবে।"

msgid "L3 topics must reference an L2 parent."
msgstr "L3 বিষয়কে একটি L2 প্যারেন্ট রেফারেন্স করতে হবে।"

msgid "Previous ordering links must point to the same level in the same group."
msgstr "Previous অর্ডারিং লিংকগুলোকে একই গ্রুপের একই স্তরে নির্দেশ করতে হবে।"

msgid "L3 ordering links must stay within the same parent topic."
msgstr "L3 অর্ডারিং লিংকগুলো অবশ্যই একই প্যারেন্ট বিষয়ের মধ্যে থাকতে হবে।"

msgid "Next ordering links must point to the same level in the same group."
msgstr "Next অর্ডারিং লিংকগুলোকে একই গ্রুপের একই স্তরে নির্দেশ করতে হবে।"

#: build/admin/airygen-app.js
msgid "Topic Cluster level updated in draft."
msgstr "ড্রাফটে Topic Cluster স্তর আপডেট করা হয়েছে।"

#: build/admin/airygen-app.js
msgid "L3 ordering only works within the same L2 parent."
msgstr "L3 অর্ডারিং শুধুমাত্র একই L2 প্যারেন্টের মধ্যে কাজ করে।"

#: build/admin/airygen-app.js
msgid "Left/right ordering updated in draft."
msgstr "ড্রাফটে বাম/ডান অর্ডারিং আপডেট করা হয়েছে।"

#: build/admin/airygen-app.js
msgid "Cluster relationship updated in draft."
msgstr "ড্রাফটে ক্লাস্টার সম্পর্ক আপডেট করা হয়েছে।"

#: build/admin/airygen-app.js
msgid "Relation removed in draft."
msgstr "ড্রাফটে সম্পর্ক সরানো হয়েছে।"

#: build/admin/airygen-app.js
msgid "Select a group before saving the mind map."
msgstr "মাইন্ড ম্যাপ সেভ করার আগে একটি গ্রুপ নির্বাচন করুন।"

#: build/admin/airygen-app.js
msgid "Mind map saved."
msgstr "মাইন্ড ম্যাপ সেভ করা হয়েছে।"

#: build/admin/airygen-app.js
msgid "Unable to save the mind map."
msgstr "মাইন্ড ম্যাপ সেভ করা যাচ্ছে না।"

#: build/admin/airygen-app.js
msgid "Mind map reset to last saved state."
msgstr "মাইন্ড ম্যাপ শেষ সেভ করা অবস্থায় রিসেট করা হয়েছে।"

#: build/admin/airygen-app.js
msgid "Reset mind map changes"
msgstr "মাইন্ড ম্যাপের পরিবর্তনগুলো রিসেট করুন"

#: build/admin/airygen-app.js
msgid "Reset the current mind map to the last saved state?"
msgstr "বর্তমান মাইন্ড ম্যাপটি কি শেষ সেভ করা অবস্থায় রিসেট করবেন?"

#: build/admin/airygen-app.js
msgid "Unsaved node positions and relationships in this mind map will be discarded."
msgstr "এই মাইন্ড ম্যাপে সেভ না করা নোডের অবস্থান ও সম্পর্ক বাতিল হয়ে যাবে।"

#. translators: 1: current PHP version, 2: required PHP version
#, php-format
msgid "Airygen SEO requires PHP %2$s or higher. Your current PHP version is %1$s. Please upgrade PHP and try again."
msgstr "Airygen SEO-এর জন্য PHP %2$s বা উচ্চতর প্রয়োজন। আপনার বর্তমান PHP সংস্করণ %1$s। অনুগ্রহ করে PHP আপগ্রেড করুন এবং আবার চেষ্টা করুন।"

msgid "Plugin Activation Error"
msgstr "প্লাগিন অ্যাক্টিভেশন ত্রুটি"

msgid "Invalid import payload."
msgstr "অবৈধ ইমপোর্ট পেলোড।"

msgid "Missing settings key in import payload."
msgstr "ইমপোর্ট পেলোডে সেটিংস কী অনুপস্থিত।"

msgid "Only network administrators can change uninstall preferences."
msgstr "শুধুমাত্র নেটওয়ার্ক অ্যাডমিনিস্ট্রেটররা আনইনস্টল পছন্দ পরিবর্তন করতে পারেন।"

msgid "Invalid uninstall preferences payload."
msgstr "অবৈধ আনইনস্টল পছন্দ পেলোড।"

#: build/admin/airygen-app.js
msgid "Export or import all plugin settings, and configure what data is removed when the plugin is uninstalled."
msgstr "সমস্ত প্লাগিন সেটিংস এক্সপোর্ট বা ইমপোর্ট করুন এবং আনইনস্টলের সময় কোন ডেটা মুছে যাবে তা কনফিগার করুন।"

#: build/admin/airygen-app.js
msgid "Export settings"
msgstr "সেটিংস এক্সপোর্ট করুন"

#: build/admin/airygen-app.js
msgid "Download a JSON snapshot of all your current settings. Use this to back up your configuration or transfer it to another site."
msgstr "আপনার সমস্ত বর্তমান সেটিংসের একটি JSON স্ন্যাপশট ডাউনলোড করুন। আপনার কনফিগারেশন ব্যাকআপ নিতে বা অন্য সাইটে স্থানান্তর করতে এটি ব্যবহার করুন।"

#: build/admin/airygen-app.js
msgid "Exporting…"
msgstr "এক্সপোর্ট হচ্ছে…"

#: build/admin/airygen-app.js
msgid "Export"
msgstr "এক্সপোর্ট"

#: build/admin/airygen-app.js
msgid "Import settings"
msgstr "সেটিংস ইমপোর্ট করুন"

#: build/admin/airygen-app.js
msgid "Upload a JSON file exported from Airygen SEO to restore or copy your settings. Existing settings will be overwritten."
msgstr "আপনার সেটিংস পুনরুদ্ধার বা কপি করতে Airygen SEO থেকে এক্সপোর্ট করা JSON ফাইল আপলোড করুন। বিদ্যমান সেটিংস ওভাররাইট হবে।"

#: build/admin/airygen-app.js
msgid "Settings imported successfully."
msgstr "সেটিংস সফলভাবে ইমপোর্ট হয়েছে।"

#: build/admin/airygen-app.js
msgid "Import failed. Please check the file and try again."
msgstr "ইমপোর্ট ব্যর্থ হয়েছে। অনুগ্রহ করে ফাইলটি পরীক্ষা করুন এবং আবার চেষ্টা করুন।"

#: build/admin/airygen-app.js
msgid "An unexpected error occurred."
msgstr "একটি অপ্রত্যাশিত ত্রুটি ঘটেছে।"

#: build/admin/airygen-app.js
msgid "Uninstall"
msgstr "আনইনস্টল"

#: build/admin/airygen-app.js
msgid "Choose what data is permanently removed when the plugin is deleted. These actions only run on full uninstall, not on deactivation."
msgstr "প্লাগিন মুছে ফেলার সময় কোন ডেটা স্থায়ীভাবে মুছে যাবে তা নির্বাচন করুন। এই ক্রিয়াগুলি শুধুমাত্র সম্পূর্ণ আনইনস্টলের সময় চলে, নিষ্ক্রিয় করার সময় নয়।"

#: build/admin/airygen-app.js
msgid "Remove all custom database tables"
msgstr "সমস্ত কাস্টম ডেটাবেস টেবিল মুছুন"

#: build/admin/airygen-app.js
msgid "Remove all plugin settings (wp_options)"
msgstr "সমস্ত প্লাগিন সেটিংস মুছুন (wp_options)"

#: build/admin/airygen-app.js
msgid "Remove all post, term, and user metadata"
msgstr "সমস্ত পোস্ট, টার্ম এবং ইউজার মেটাডেটা মুছুন"

#: build/admin/airygen-app.js
msgid "Preferences saved."
msgstr "পছন্দগুলি সংরক্ষিত হয়েছে।"

#: build/admin/airygen-app.js
msgid "Failed to save preferences."
msgstr "পছন্দগুলি সংরক্ষণ করতে ব্যর্থ হয়েছে।"

#. translators: %s is the required link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "%s is the link placeholder and must appear exactly once."
msgstr "%s হল লিঙ্ক প্লেসহোল্ডার এবং এটি ঠিক একবার আসতে হবে।"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "Shown above the main series links. Do not include %s in this description."
msgstr "মূল সিরিজ লিঙ্কের উপরে দেখানো হয়। এই বর্ণনায় %s অন্তর্ভুক্ত করবেন না।"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L3 relation link description must contain exactly one %s."
msgstr "L3 রিলেশন লিঙ্ক বর্ণনায় ঠিক একটি %s থাকতে হবে।"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L2 relation link description must contain exactly one %s."
msgstr "L2 রিলেশন লিঙ্ক বর্ণনায় ঠিক একটি %s থাকতে হবে।"

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L1 relation link description must not contain %s."
msgstr "L1 রিলেশন লিঙ্ক বর্ণনায় %s থাকা উচিত নয়।"

#: build/admin/airygen-app.js
msgid "Relation link descriptions"
msgstr "রিলেশন লিঙ্ক বর্ণনাসমূহ"

#: build/admin/airygen-app.js
msgid "Customize the descriptions shown before related Topic Cluster links in L1, L2, and L3 articles."
msgstr "L1, L2 এবং L3 নিবন্ধে সম্পর্কিত টপিক ক্লাস্টার লিঙ্কের আগে প্রদর্শিত বর্ণনাগুলি কাস্টমাইজ করুন।"

#: build/admin/airygen-app.js
msgid "Does your website represent a business with a physical location?"
msgstr "আপনার ওয়েবসাইট কি একটি শারীরিক অবস্থান সহ একটি ব্যবসা প্রতিষ্ঠানের প্রতিনিধিত্ব করে?"

#: build/admin/airygen-app.js
msgid "For example, a restaurant, clinic, law firm, gym, or retail store."
msgstr "উদাহরণস্বরূপ, একটি রেস্তোরাঁ, ক্লিনিক, আইনি সংস্থা, জিম বা খুচরা দোকান।"

#: build/admin/airygen-app.js
msgid "Adds LocalBusiness schema to your site so Google can show your address, phone number, and opening hours in local search results and Maps — making it easier for nearby customers to find you."
msgstr "আপনার সাইটে LocalBusiness স্কিমা যোগ করে যাতে Google স্থানীয় অনুসন্ধান ফলাফলে আপনার ঠিকানা, ফোন নম্বর এবং খোলার সময় দেখাতে পারে।"

#: build/admin/airygen-app.js
msgid "Alongside local data, also outputs Organization and WebSite schema to help Google better understand your brand."
msgstr "স্থানীয় ডেটার পাশাপাশি Google-কে আপনার ব্র্যান্ড আরও ভালোভাবে বুঝতে সাহায্য করতে Organization এবং WebSite স্কিমাও আউটপুট করে।"

#: build/admin/airygen-app.js
msgid "Does your website sell products or services online?"
msgstr "আপনার ওয়েবসাইট কি অনলাইনে পণ্য বা পরিষেবা বিক্রি করে?"

#: build/admin/airygen-app.js
msgid "For example, a WooCommerce store or any site with a shopping cart."
msgstr "উদাহরণস্বরূপ, একটি WooCommerce স্টোর বা শপিং কার্ট সহ যেকোনো সাইট।"

#: build/admin/airygen-app.js
msgid "Automatically generates Product schema for every product page so Google can display price, stock status, and star ratings directly in search results."
msgstr "প্রতিটি পণ্য পৃষ্ঠার জন্য স্বয়ংক্রিয়ভাবে Product স্কিমা তৈরি করে যাতে Google সরাসরি অনুসন্ধান ফলাফলে মূল্য, স্টক অবস্থা এবং স্টার রেটিং দেখাতে পারে।"

#: build/admin/airygen-app.js
msgid "Adds site-level Organization schema to help Google identify your brand and store."
msgstr "সাইট-স্তরের Organization স্কিমা যোগ করে যা Google-কে আপনার ব্র্যান্ড শনাক্ত করতে সাহায্য করে।"

#: build/admin/airygen-app.js
msgid "Does your site have multiple language versions or serve users in different countries?"
msgstr "আপনার সাইটের কি একাধিক ভাষা সংস্করণ আছে বা বিভিন্ন দেশের ব্যবহারকারীদের সেবা দেওয়া হয়?"

#: build/admin/airygen-app.js
msgid "For example, separate English and Spanish versions, or different URLs targeting different regions."
msgstr "উদাহরণস্বরূপ, আলাদা ইংরেজি এবং স্প্যানিশ সংস্করণ, বা বিভিন্ন অঞ্চলকে লক্ষ্য করে বিভিন্ন URL।"

#: build/admin/airygen-app.js
msgid "Hreflang"
msgstr "Hreflang"

#: build/admin/airygen-app.js
msgid "Automatically adds hreflang tags to every page so Google serves the right language version to the right audience, preventing different variants from competing with each other in search rankings."
msgstr "প্রতিটি পৃষ্ঠায় স্বয়ংক্রিয়ভাবে hreflang ট্যাগ যোগ করে যাতে Google সঠিক দর্শকদের কাছে সঠিক ভাষার সংস্করণ পরিবেশন করে।"

#: build/admin/airygen-app.js
msgid "Do you want links to your site to display a rich preview when shared on social media?"
msgstr "আপনি কি চান যে সোশ্যাল মিডিয়ায় শেয়ার করার সময় আপনার সাইটের লিঙ্কগুলি একটি সমৃদ্ধ প্রিভিউ দেখাক?"

#: build/admin/airygen-app.js
msgid "Social Cards"
msgstr "সোশ্যাল কার্ড"

#: build/admin/airygen-app.js
msgid "Automatically generates Open Graph and Twitter Card meta tags for every post so shared links display your chosen image and title instead of letting platforms pick a random one."
msgstr "প্রতিটি পোস্টের জন্য স্বয়ংক্রিয়ভাবে Open Graph এবং Twitter Card মেটা ট্যাগ তৈরি করে যাতে শেয়ার করা লিঙ্কগুলি আপনার বেছে নেওয়া ছবি এবং শিরোনাম দেখায়।"

#: build/admin/airygen-app.js
msgid "Does your site publish long-form articles, tutorials, or in-depth knowledge content?"
msgstr "আপনার সাইট কি দীর্ঘ আর্টিকেল, টিউটোরিয়াল বা গভীর জ্ঞান-ভিত্তিক কন্টেন্ট প্রকাশ করে?"

#: build/admin/airygen-app.js
msgid "For example, a blog, technical documentation site, or educational platform."
msgstr "উদাহরণস্বরূপ, একটি ব্লগ, প্রযুক্তিগত ডকুমেন্টেশন সাইট, বা শিক্ষামূলক প্ল্যাটফর্ম।"

#: build/admin/airygen-app.js
msgid "Automatically generates a table of contents at the top of long posts so readers can jump straight to any section. Google sometimes surfaces TOC links directly in search results."
msgstr "দীর্ঘ পোস্টের শীর্ষে স্বয়ংক্রিয়ভাবে একটি সূচিপত্র তৈরি করে যাতে পাঠকরা সরাসরি যেকোনো বিভাগে যেতে পারেন।"

#: build/admin/airygen-app.js
msgid "Recommends related posts at the bottom of each article based on categories and tags, keeping readers engaged and reducing bounce rate."
msgstr "বিভাগ এবং ট্যাগের উপর ভিত্তি করে প্রতিটি আর্টিকেলের নীচে সংশ্লিষ্ট পোস্ট সুপারিশ করে।"

#: build/admin/airygen-app.js
msgid "Helps you manage a topic cluster structure (pillar → cluster → supporting articles) and automatically renders a topic navigation block within posts, making it easy for readers to explore related content while signaling topical depth to Google."
msgstr "আপনাকে একটি টপিক ক্লাস্টার কাঠামো পরিচালনা করতে সাহায্য করে এবং পোস্টের মধ্যে স্বয়ংক্রিয়ভাবে একটি টপিক নেভিগেশন ব্লক রেন্ডার করে।"

#: build/admin/airygen-app.js
msgid "Does your site have multiple authors or use many categories and tags to organize content?"
msgstr "আপনার সাইটে কি একাধিক লেখক আছেন বা কন্টেন্ট সংগঠিত করতে অনেক বিভাগ ও ট্যাগ ব্যবহার করা হয়?"

#: build/admin/airygen-app.js
msgid "Generates Person schema for every author page to establish authorship identity and strengthen the E-E-A-T signals Google increasingly factors into rankings."
msgstr "লেখকত্বের পরিচয় প্রতিষ্ঠা করতে এবং E-E-A-T সংকেত শক্তিশালী করতে প্রতিটি লেখক পৃষ্ঠার জন্য Person স্কিমা তৈরি করে।"

#: build/admin/airygen-app.js
msgid "Lets you customize meta titles and descriptions for taxonomy archive pages and control which ones Google should index, preventing SEO authority from being diluted across low-value pages."
msgstr "আপনাকে ট্যাক্সোনমি আর্কাইভ পৃষ্ঠাগুলির জন্য মেটা শিরোনাম এবং বিবরণ কাস্টমাইজ করতে এবং Google কোনগুলি ইন্ডেক্স করবে তা নিয়ন্ত্রণ করতে দেয়।"

#: build/admin/airygen-app.js
msgid "Has your site ever changed its URL structure, or do you know some links lead to 404 pages?"
msgstr "আপনার সাইট কি কখনো তার URL কাঠামো পরিবর্তন করেছে, বা আপনি কি জানেন যে কিছু লিঙ্ক 404 পৃষ্ঠায় নিয়ে যায়?"

#: build/admin/airygen-app.js
msgid "Set up 301/302 redirects to seamlessly transfer traffic and SEO ranking power from old URLs to new ones so your hard-earned rankings are never lost."
msgstr "পুরানো URL থেকে নতুনগুলিতে ট্র্যাফিক এবং SEO র‍্যাংকিং শক্তি স্থানান্তর করতে 301/302 রিডাইরেক্ট সেট আপ করুন।"

#: build/admin/airygen-app.js
msgid "404 Manager"
msgstr "৪০৪ ম্যানেজার"

#: build/admin/airygen-app.js
msgid "Automatically logs every 404 visit so you can see at a glance which broken links need fixing, and set up redirects directly from the interface."
msgstr "প্রতিটি 404 ভিজিট স্বয়ংক্রিয়ভাবে লগ করে যাতে আপনি এক নজরে দেখতে পারেন কোন ভাঙা লিঙ্কগুলি ঠিক করা দরকার।"

#: build/admin/airygen-app.js
msgid "Actively crawls your entire site to surface all broken internal and external links before Google finds them and uses them against your rankings."
msgstr "Google সেগুলো ব্যবহার করার আগেই সমস্ত ভাঙা লিঙ্ক খুঁজে বের করতে আপনার সম্পূর্ণ সাইট সক্রিয়ভাবে ক্রল করে।"

#: build/admin/airygen-app.js
msgid "Would you like search engines to index your new and updated content immediately after publishing?"
msgstr "আপনি কি চান প্রকাশের পরপরই সার্চ ইঞ্জিনগুলি আপনার নতুন এবং আপডেট করা কন্টেন্ট ইন্ডেক্স করুক?"

#: build/admin/airygen-app.js
msgid "Uses the IndexNow protocol to push new and updated URLs to Bing and other supported search engines the moment content is published or changed — no waiting for crawlers. Especially valuable for news sites and time-sensitive content."
msgstr "কন্টেন্ট প্রকাশিত হওয়ার সাথে সাথে Bing-এ নতুন URL পুশ করতে IndexNow প্রোটোকল ব্যবহার করে।"

#: build/admin/airygen-app.js
msgid "Would you like AI to help you write article outlines, FAQ sets, or plan your full content strategy?"
msgstr "আপনি কি চান AI আর্টিকেল আউটলাইন, FAQ সেট লিখতে বা আপনার কন্টেন্ট কৌশল পরিকল্পনা করতে সাহায্য করুক?"

#: build/admin/airygen-app.js
msgid "A smart AI toolkit that generates article outlines, Content Blueprints, full Article drafts, and Deep FAQ sets from a keyword — making content creation faster and easier."
msgstr "একটি স্মার্ট AI টুলকিট যা কীওয়ার্ড থেকে আর্টিকেল আউটলাইন, কন্টেন্ট ব্লুপ্রিন্ট, সম্পূর্ণ আর্টিকেল ড্রাফট এবং ডিপ FAQ সেট তৈরি করে।"

#: build/admin/airygen-app.js
msgid "Would you like AI tools like ChatGPT and Perplexity to more easily discover and cite your site?"
msgstr "আপনি কি চান ChatGPT এবং Perplexity-এর মতো AI টুলগুলি আপনার সাইট আরও সহজে আবিষ্কার এবং উদ্ধৃত করুক?"

#: build/admin/airygen-app.js
msgid "AI search is changing how people find information — make sure your site is visible in the AI era."
msgstr "AI অনুসন্ধান মানুষের তথ্য খোঁজার পদ্ধতি বদলে দিচ্ছে — নিশ্চিত করুন যে AI যুগে আপনার সাইট দৃশ্যমান।"

#: build/admin/airygen-app.js
msgid "Automatically generates an llms.txt file — like a sitemap for AI — so tools like ChatGPT and Perplexity know what content on your site is available to cite."
msgstr "স্বয়ংক্রিয়ভাবে একটি llms.txt ফাইল তৈরি করে — AI-এর জন্য সাইটম্যাপের মতো — যাতে ChatGPT এবং Perplexity জানে আপনার সাইটে কোন কন্টেন্ট উদ্ধৃত করার জন্য উপলব্ধ।"

#: build/admin/airygen-app.js
msgid "Automatically converts your posts into AI-friendly Markdown so AI agents can read and understand your content without struggling to parse HTML."
msgstr "আপনার পোস্টগুলি স্বয়ংক্রিয়ভাবে AI-বান্ধব Markdown-এ রূপান্তর করে যাতে AI এজেন্টরা HTML পার্স না করেই আপনার কন্টেন্ট পড়তে পারে।"

#: build/admin/airygen-app.js
msgid "Includes Deep FAQ, which automatically generates structured Q&A from your post content. AI search engines favor content that directly answers questions, boosting your visibility in AI-powered search results."
msgstr "ডিপ FAQ অন্তর্ভুক্ত, যা আপনার পোস্ট কন্টেন্ট থেকে স্বয়ংক্রিয়ভাবে কাঠামোবদ্ধ প্রশ্নোত্তর তৈরি করে।"

#: build/admin/airygen-app.js
msgid "Free"
msgstr "বিনামূল্যে"

#: build/admin/airygen-app.js
msgid "Requires a plan upgrade"
msgstr "প্ল্যান আপগ্রেড প্রয়োজন"

#: build/admin/airygen-app.js
msgid "Requires"
msgstr "প্রয়োজন"

#: build/admin/airygen-app.js
msgid "plan to activate"
msgstr "সক্রিয় করতে প্ল্যান"

#: build/admin/airygen-app.js
msgid "Got it, don't show again"
msgstr "বুঝেছি, আর দেখাবেন না"

#: build/admin/airygen-app.js
msgid "← Back"
msgstr "← পিছে"

#: build/admin/airygen-app.js
msgid "Get started →"
msgstr "শুরু করুন →"

#: build/admin/airygen-app.js
msgid "Next →"
msgstr "পরবর্তী →"

#: build/admin/airygen-app.js
msgid "Apply & finish"
msgstr "প্রয়োগ করুন এবং শেষ করুন"

#: build/admin/airygen-app.js
msgid "Welcome to Airygen SEO!"
msgstr "Airygen SEO-তে স্বাগতম!"

#: build/admin/airygen-app.js
msgid "Answer 10 quick questions and we'll recommend the right SEO modules for your site — then enable them all with one click."
msgstr "১০টি দ্রুত প্রশ্নের উত্তর দিন এবং আমরা আপনার সাইটের জন্য সঠিক SEO মডিউলগুলি সুপারিশ করব — তারপর একটি ক্লিকে সেগুলি সক্ষম করুন।"

#: build/admin/airygen-app.js
msgid "Don't worry — every question is just Yes or No. No technical knowledge needed. It takes about 2 minutes. 😊"
msgstr "চিন্তা করবেন না — প্রতিটি প্রশ্ন শুধু হ্যাঁ বা না। কোনো প্রযুক্তিগত জ্ঞানের প্রয়োজন নেই। এতে প্রায় ২ মিনিট সময় লাগে। 😊"

#: build/admin/airygen-app.js
msgid "🎉 All done! Here's what we recommend based on your answers:"
msgstr "🎉 সব শেষ! আপনার উত্তরের ভিত্তিতে আমরা যা সুপারিশ করি:"

#: build/admin/airygen-app.js
msgid "Will be enabled (included in your plan)"
msgstr "সক্ষম করা হবে (আপনার প্ল্যানে অন্তর্ভুক্ত)"

#: build/admin/airygen-app.js
msgid "Requires an upgrade to enable"
msgstr "সক্ষম করতে আপগ্রেড প্রয়োজন"

#: build/admin/airygen-app.js
msgid "Upgrade to"
msgstr "আপগ্রেড করুন"

#: build/admin/airygen-app.js
msgid "No modules selected. Click Finish to close the wizard."
msgstr "কোনো মডিউল নির্বাচন করা হয়নি। উইজার্ড বন্ধ করতে সম্পন্ন ক্লিক করুন।"

#: build/admin/airygen-app.js
msgid "Setup Wizard"
msgstr "সেটআপ উইজার্ড"

#: build/admin/airygen-app.js
msgid "Drop blocks here"
msgstr "এখানে ব্লক ড্রপ করুন"

#: build/admin/airygen-app.js
msgid "Two ways to open settings"
msgstr "সেটিংস খোলার দুটি উপায়"

#: build/admin/airygen-app.js
msgid "Click \"Open global settings\" here, or use Settings in the top navigation bar — both take you to the same settings page."
msgstr "এখানে \"গ্লোবাল সেটিংস খুলুন\" ক্লিক করুন, বা উপরের নেভিগেশন বারে সেটিংস ব্যবহার করুন — উভয়ই আপনাকে একই সেটিংস পৃষ্ঠায় নিয়ে যাবে।"

#: build/admin/airygen-app.js
msgid "Drag modules to reorder"
msgstr "পুনর্বিন্যাসের জন্য মডিউলগুলি টেনে আনুন"

#: build/admin/airygen-app.js
msgid "Drag any module card to rearrange them. The Settings menu bar reflects this exact order — put your most-used modules up front."
msgstr "যেকোনো মডিউল কার্ড টেনে পুনর্বিন্যাস করুন। সেটিংস মেনু বারে এই সঠিক ক্রম প্রতিফলিত হয়।"

#: build/admin/airygen-app.js
msgid "Control editor panel order"
msgstr "এডিটর প্যানেলের ক্রম নিয়ন্ত্রণ করুন"

#: build/admin/airygen-app.js
msgid "Drag these panel cards to set the display order of sidebar panels shown in the post editor. The order here is the order there."
msgstr "পোস্ট এডিটরে দেখানো সাইডবার প্যানেলের প্রদর্শন ক্রম সেট করতে এই প্যানেল কার্ডগুলি টেনে আনুন।"

#: build/admin/airygen-app.js
msgid "Skip tour"
msgstr "ট্যুর এড়িয়ে যান"

#: build/admin/airygen-app.js
msgid "Done"
msgstr "সম্পন্ন"

#: build/admin/airygen-app.js
msgid "In-Article Content Order"
msgstr "নিবন্ধের মধ্যে কন্টেন্টের ক্রম"

#: build/admin/airygen-app.js
msgid "Drag content blocks between zones to control where they appear, and reorder within each zone to set their stacking sequence."
msgstr "কন্টেন্ট ব্লকগুলি জোনের মধ্যে টেনে নিয়ন্ত্রণ করুন সেগুলি কোথায় দেখা যাবে।"

#: build/admin/airygen-app.js
msgid "Gap between blocks (px)"
msgstr "ব্লকের মধ্যে গ্যাপ (px)"

#: build/admin/airygen-app.js
msgid "Content top margin (px)"
msgstr "কন্টেন্টের উপরের মার্জিন (px)"

#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "The focus keyphrase is the main keyword or phrase this post is optimized for. AI modules use it to guide content generation — keeping the output relevant and keyword-focused."
msgstr "ফোকাস কীফ্রেজ হল প্রধান কীওয়ার্ড যার জন্য এই পোস্টটি অপ্টিমাইজ করা হয়েছে। AI মডিউলগুলি কন্টেন্ট জেনারেশন গাইড করতে এটি ব্যবহার করে।"

#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Focus keyphrase help"
msgstr "ফোকাস কীফ্রেজ সহায়তা"
