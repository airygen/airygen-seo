msgstr "ঠিক আছে"

#: build/admin/airygen-app.js
msgid "Redirect"
msgstr "রিডাইরেক্ট"

#: build/admin/airygen-app.js
msgid "URL"
msgstr "URL"

#: build/admin/airygen-app.js
msgid "Checked at"
msgstr "যাচাইয়ের সময়"

#: build/admin/airygen-app.js
msgid "Edit post"
msgstr "পোস্ট সম্পাদনা করুন"

#: build/admin/airygen-app.js
msgid "View post"
msgstr "পোস্ট দেখুন"

#: build/admin/airygen-app.js
msgid "Open link"
msgstr "লিংক খুলুন"

#: build/admin/airygen-app.js
msgid "pts"
msgstr "পয়েন্ট"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Your SEO title should be long enough to explain the topic, but short enough to avoid truncation."
msgstr "আপনার SEO শিরোনাম বিষয়টি ব্যাখ্যা করার মতো দীর্ঘ হওয়া উচিত, কিন্তু ট্রাঙ্কেশন এড়াতে যথেষ্ট ছোট।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Aim for about 50–60 characters. Front-load the most important words."
msgstr "প্রায় 50–60 অক্ষর লক্ষ্য রাখুন। সবচেয়ে গুরুত্বপূর্ণ শব্দগুলো শুরুতেই রাখুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear, visible titles improve click-through rate from search results."
msgstr "পরিষ্কার ও দৃশ্যমান title search result থেকে click-through rate বাড়ায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Search engines expect the primary topic to appear in the title."
msgstr "সার্চ ইঞ্জিন শিরোনামে মূল বিষয় উপস্থিত থাকার প্রত্যাশা করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Include your focus keyphrase naturally near the start of the title."
msgstr "শিরোনামের শুরুর কাছে স্বাভাবিকভাবে আপনার ফোকাস কীফ্রেজ অন্তর্ভুক্ত করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves topical relevance and makes the result more recognizable."
msgstr "বিষয়গত প্রাসঙ্গিকতা উন্নত করে এবং ফলাফলকে আরও চেনা যায় করে তোলে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "A meta description helps search engines and users understand the page."
msgstr "একটি মেটা বর্ণনা সার্চ ইঞ্জিন এবং ব্যবহারকারীদের পৃষ্ঠাটি বুঝতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Write 1–2 sentences that summarize the page and invite a click."
msgstr "১–২টি বাক্য লিখুন যা পৃষ্ঠাটি সংক্ষেপ করে এবং ক্লিক আমন্ত্রণ জানায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Better snippets can lift click-through rate even if rankings stay the same."
msgstr "র‌্যাঙ্কিং একই থাকলেও ভালো স্নিপেট ক্লিক-থ্রু রেট বাড়াতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Descriptions that are too short or too long get cut off in results."
msgstr "অনেক ছোট বা অনেক দীর্ঘ বর্ণনা ফলাফলে কেটে যায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep it roughly 140–160 characters and prioritize the main benefit."
msgstr "এটি প্রায় ১৪০–১৬০ অক্ষরে রাখুন এবং মূল সুবিধাকে অগ্রাধিকার দিন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Full snippets look more professional and improve engagement."
msgstr "সম্পূর্ণ স্নিপেট আরও পেশাদার দেখায় এবং এনগেজমেন্ট উন্নত করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the focus phrase helps confirm the page topic."
msgstr "ফোকাস ফ্রেজ অন্তর্ভুক্ত করা পৃষ্ঠার বিষয় নিশ্চিত করতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Work the focus keyphrase into the first sentence naturally."
msgstr "প্রথম বাক্যে স্বাভাবিকভাবে ফোকাস কীফ্রেজ সন্নিবেশ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger relevance signals can improve ranking and user confidence."
msgstr "শক্তিশালী প্রাসঙ্গিকতার সংকেত র‍্যাঙ্কিং ও ব্যবহারকারীর আস্থা উন্নত করতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Title and description should not repeat each other."
msgstr "শিরোনাম ও বর্ণনা পরস্পরের পুনরাবৃত্তি করা উচিত নয়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the title to state the topic and the description to add benefit or context."
msgstr "বিষয় বলতে শিরোনাম এবং সুবিধা বা প্রসঙ্গ যোগ করতে বর্ণনা ব্যবহার করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Distinct messaging gives users more reasons to click."
msgstr "স্বতন্ত্র বার্তা ব্যবহারকারীদের ক্লিক করার আরও কারণ দেয়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Pages should have a single main heading (H1)."
msgstr "পৃষ্ঠায় একটি একক মূল শিরোনাম (H1) থাকা উচিত।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep one H1 that matches the page topic, and use H2/H3 for sections."
msgstr "পৃষ্ঠার বিষয়ের সাথে মিলে এমন একটি H1 রাখুন এবং অংশের জন্য H2/H3 ব্যবহার করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear structure helps search engines understand the content hierarchy."
msgstr "পরিষ্কার কাঠামো সার্চ ইঞ্জিনকে কনটেন্টের স্তরবিন্যাস বুঝতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Subheadings break long content into scannable sections."
msgstr "সাবহেডিং দীর্ঘ কনটেন্টকে স্ক্যানযোগ্য অংশে ভেঙে দেয়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add 2–8 H2/H3 headings that summarize key sections."
msgstr "মূল অংশগুলোকে সংক্ষেপে উপস্থাপন করে এমন 2–8টি H2/H3 শিরোনাম যোগ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves readability and keeps users engaged longer."
msgstr "পাঠযোগ্যতা উন্নত করে এবং ব্যবহারকারীদের আরও বেশিক্ষণ নিযুক্ত রাখে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the keyphrase in a subheading reinforces the main topic."
msgstr "সাবহেডিংয়ে কীফ্রেজ অন্তর্ভুক্ত করা মূল বিষয়কে শক্তিশালী করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Place the focus keyphrase in one relevant H2 or H3."
msgstr "একটি প্রাসঙ্গিক H2 বা H3-এ ফোকাস কীফ্রেজ রাখুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps search engines connect sections to the main theme."
msgstr "সার্চ ইঞ্জিনকে অংশগুলো মূল বিষয়ের সাথে সংযুক্ত করতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "The opening paragraph sets context for both users and search engines."
msgstr "খোলার অনুচ্ছেদ ব্যবহারকারী ও সার্চ ইঞ্জিন উভয়ের জন্য প্রসঙ্গ নির্ধারণ করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the focus keyphrase once in the first 1–2 sentences."
msgstr "প্রথম ১–২টি বাক্যে একবার ফোকাস কীফ্রেজ ব্যবহার করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger topical clarity can improve relevance signals."
msgstr "শক্তিশালী বিষয়গত স্পষ্টতা প্রাসঙ্গিকতার সংকেত উন্নত করতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keyphrase density shows how often the main topic appears."
msgstr "কীফ্রেজ ঘনত্ব দেখায় মূল বিষয় কতবার উপস্থিত হয়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the keyphrase naturally throughout the content without stuffing."
msgstr "স্টাফিং ছাড়া কনটেন্টজুড়ে স্বাভাবিকভাবে কীফ্রেজ ব্যবহার করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Balanced usage supports relevance while avoiding spam signals."
msgstr "ভারসাম্যপূর্ণ ব্যবহার প্রাসঙ্গিকতা সমর্থন করে এবং স্প্যাম সিগনাল এড়ায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long-tail phrases capture more specific search intent."
msgstr "লং-টেইল ফ্রেজগুলো আরও নির্দিষ্ট সার্চ অভিপ্রায় ধারণ করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add your long-tail phrases where they fit naturally in sections."
msgstr "সেকশনগুলোতে যেখানে স্বাভাবিকভাবে মানায় সেখানে আপনার লং-টেইল ফ্রেজগুলো যোগ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps the page rank for more specific queries."
msgstr "আরও নির্দিষ্ট কোয়েরির জন্য পৃষ্ঠার র‍্যাঙ্ক করতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Very short pages often lack depth to satisfy readers."
msgstr "অনেক ছোট পৃষ্ঠায় প্রায়ই পাঠকদের সন্তুষ্ট করার মতো গভীরতার অভাব থাকে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Expand the content with examples, steps, or FAQs."
msgstr "উদাহরণ, ধাপ বা FAQ দিয়ে কনটেন্ট সম্প্রসারিত করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "More complete content tends to perform better for informational queries."
msgstr "আরও সম্পূর্ণ কনটেন্ট তথ্যমূলক কোয়েরির জন্য আরও ভালো পারফর্ম করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Readable content keeps users engaged and reduces bounce."
msgstr "পাঠযোগ্য কনটেন্ট ব্যবহারকারীদের নিযুক্ত রাখে এবং বাউন্স কমায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Shorten sentences, use simpler words, and break up long paragraphs."
msgstr "বাক্য ছোট করুন, সহজ শব্দ ব্যবহার করুন এবং দীর্ঘ অনুচ্ছেদ ভেঙে দিন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improved clarity boosts dwell time and user satisfaction."
msgstr "উন্নত স্পষ্টতা ডওয়েল টাইম এবং ব্যবহারকারীর সন্তুষ্টি বাড়ায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long sentences are hard to read in CJK languages."
msgstr "CJK ভাষায় দীর্ঘ বাক্য পড়তে কঠিন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Split long sentences and add punctuation for clearer flow."
msgstr "দীর্ঘ বাক্য ভেঙে দিন এবং স্পষ্ট প্রবাহের জন্য বিরাম চিহ্ন যোগ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clearer reading experience helps users stay on the page."
msgstr "আরও পরিষ্কার পাঠ অভিজ্ঞতা ব্যবহারকারীদের page-এ থাকতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Images support understanding and break up long text."
msgstr "ছবি বোঝাপড়া সমর্থন করে এবং দীর্ঘ টেক্সট ভেঙে দেয়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add at least one relevant image that illustrates the topic."
msgstr "বিষয়টি বোঝাতে অন্তত একটি প্রাসঙ্গিক ছবি যোগ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Visuals improve engagement and can help with image search."
msgstr "ভিজ্যুয়াল এনগেজমেন্ট উন্নত করে এবং ইমেজ সার্চে সাহায্য করতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Alt text helps search engines and screen readers interpret images."
msgstr "Alt টেক্সট সার্চ ইঞ্জিন এবং স্ক্রিন রিডারকে ছবি বুঝতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Describe each image in plain language, focusing on what it shows."
msgstr "প্রতিটি ছবি সরল ভাষায় বর্ণনা করুন, এটি কী দেখাচ্ছে তার উপর মনোযোগ দিন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves accessibility and adds extra relevance signals."
msgstr "অ্যাক্সেসিবিলিটি উন্নত করে এবং অতিরিক্ত প্রাসঙ্গিকতার সংকেত যোগ করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spacing long-tail phrases prevents keyword stuffing."
msgstr "লং-টেইল ফ্রেজের স্পেসিং কীওয়ার্ড স্টাফিং প্রতিরোধ করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spread similar phrases across different sections."
msgstr "বিভিন্ন অংশে একই ধরনের ফ্রেজ ছড়িয়ে দিন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keeps content natural while still covering long-tail queries."
msgstr "দীর্ঘ-লেজের কোয়েরি কভার করার পাশাপাশি কনটেন্ট স্বাভাবিক রাখে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the keyphrase in one image alt text reinforces the topic."
msgstr "একটি ছবির alt টেক্সটে কীফ্রেজ অন্তর্ভুক্ত করা বিষয়কে শক্তিশালী করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the focus phrase in a single relevant image alt description."
msgstr "একটি প্রাসঙ্গিক ছবির alt বর্ণনায় ফোকাস ফ্রেজ ব্যবহার করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Adds topical relevance without over-optimizing every image."
msgstr "প্রতিটি ছবিকে অতিরিক্ত অপ্টিমাইজ না করেই বিষয়গত প্রাসঙ্গিকতা যোগ করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Internal links help users and search engines discover related pages."
msgstr "অভ্যন্তরীণ লিংক ব্যবহারকারী ও সার্চ ইঞ্জিনকে সম্পর্কিত পৃষ্ঠা আবিষ্কার করতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Link to 1–3 relevant posts or pages using descriptive anchor text."
msgstr "বর্ণনামূলক অ্যাংকর টেক্সট ব্যবহার করে ১–৩টি প্রাসঙ্গিক পোস্ট বা পৃষ্ঠায় লিংক করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves site structure and can pass authority to key pages."
msgstr "সাইটের কাঠামো উন্নত করে এবং মূল পৃষ্ঠাগুলোতে কর্তৃত্ব পাস করতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "External links show credibility and provide references."
msgstr "বাহ্যিক লিংক বিশ্বাসযোগ্যতা দেখায় এবং রেফারেন্স প্রদান করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add at least one trusted source link that supports your content."
msgstr "আপনার কনটেন্টকে সমর্থন করে এমন অন্তত একটি নির্ভরযোগ্য উৎসের লিংক যোগ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Builds trust and can improve perceived quality."
msgstr "এটি আস্থা তৈরি করে এবং মানের ধারণা উন্নত করতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Rel attributes clarify how external links should be treated."
msgstr "rel অ্যাট্রিবিউট বাহ্যিক লিংকগুলো কীভাবে পরিচালিত হবে তা স্পষ্ট করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add rel values like nofollow, sponsored, or ugc where appropriate."
msgstr "যেখানে উপযুক্ত সেখানে nofollow, sponsored বা ugc-এর মতো rel মান যোগ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps avoid link spam signals and keeps compliance clean."
msgstr "লিংক স্প্যাম সংকেত এড়াতে এবং সম্মতি পরিষ্কার রাখতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Short, readable URLs are easier to understand and share."
msgstr "ছোট, পাঠযোগ্য URL বোঝা ও শেয়ার করা সহজ।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use 2–5 words that match the topic and remove stop words."
msgstr "বিষয়ের সাথে মিলে এমন ২–৫টি শব্দ ব্যবহার করুন এবং স্টপ ওয়ার্ড সরান।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clean URLs improve clarity and can increase click confidence."
msgstr "পরিষ্কার URL স্পষ্টতা বাড়ায় এবং ক্লিক করার আস্থা বৃদ্ধি করতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the focus phrase in the URL reinforces relevance."
msgstr "URL-এ ফোকাস ফ্রেজ অন্তর্ভুক্ত করা প্রাসঙ্গিকতা শক্তিশালী করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add the focus keyphrase to the slug without extra filler."
msgstr "অতিরিক্ত filler ছাড়া slug-এ ফোকাস কীফ্রেজ যোগ করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Strengthens topical signals and makes URLs clearer."
msgstr "বিষয়গত সংকেত শক্তিশালী করে এবং URL আরও স্পষ্ট করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Canonical URLs tell search engines which version to index."
msgstr "Canonical URL সার্চ ইঞ্জিনকে কোন সংস্করণ index করতে হবে তা জানায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Ensure the canonical points to the main URL of the page."
msgstr "নিশ্চিত করুন ক্যানোনিক্যাল পৃষ্ঠার মূল URL-এ নির্দেশ করছে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Prevents duplicate content issues and consolidates ranking signals."
msgstr "ডুপ্লিকেট কনটেন্টের সমস্যা রোধ করে এবং র‍্যাঙ্কিং সংকেত একত্রিত করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Article schema helps search engines understand your content type."
msgstr "আর্টিকেল স্কিমা সার্চ ইঞ্জিনকে আপনার কনটেন্টের ধরন বুঝতে সাহায্য করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Enable Article schema in Schema Markup settings."
msgstr "স্ট্রাকচার্ড ডেটা মার্কআপ সেটিংসে Article স্কিমা সক্রিয় করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Structured data can improve search appearance and visibility."
msgstr "স্ট্রাকচার্ড ডেটা সার্চ উপস্থিতি ও দৃশ্যমানতা উন্নত করতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Breadcrumb schema shows navigation context in search results."
msgstr "ব্রেডক্রাম্ব স্কিমা search result-এ নেভিগেশনের প্রেক্ষাপট দেখায়।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Enable Breadcrumbs and the BreadcrumbList schema output."
msgstr "Breadcrumbs এবং BreadcrumbList স্কিমা আউটপুট সক্রিয় করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Breadcrumb rich results can improve CTR and clarity."
msgstr "ব্রেডক্রাম্ব রিচ রেজাল্ট CTR ও স্পষ্টতা বাড়াতে পারে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Sitewide SEO reflects the overall health of your site setup."
msgstr "সাইটব্যাপী SEO আপনার সাইটের সেটআপের সামগ্রিক স্বাস্থ্য প্রতিফলিত করে।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Resolve site health warnings and keep SEO modules configured."
msgstr "সাইট স্বাস্থ্য সতর্কতা সমাধান করুন এবং SEO মডিউল কনফিগার রাখুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "A healthier site foundation supports stable rankings."
msgstr "একটি আরও স্বাস্থ্যকর সাইটের ভিত্তি স্থিতিশীল র‌্যাঙ্কিংকে সমর্থন করে।"

#. translators: %s is the rule label.
#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
#, js-format
msgid "This rule checks: %s."
msgstr "এই নিয়মটি পরীক্ষা করে: %s।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Make sure the content aligns with the rule and update the page accordingly."
msgstr "নিশ্চিত করুন কনটেন্ট নিয়মের সাথে সামঞ্জস্যপূর্ণ এবং পৃষ্ঠাটি সেই অনুযায়ী আপডেট করুন।"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Passing more rules improves the overall SEO score."
msgstr "আরও বেশি নিয়ম পাস করলে সামগ্রিক SEO স্কোর উন্নত হয়।"

