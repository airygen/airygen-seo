#: build/admin/airygen-app.js
msgid "Broken Link Checker"
msgstr "ভাঙা লিংক পরীক্ষক"

#: build/admin/airygen-app.js
msgid "Scan content for broken and redirected links, and monitor crawl health."
msgstr "ভাঙা ও রিডাইরেক্টেড লিংকের জন্য কনটেন্ট স্ক্যান করুন এবং ক্রল স্বাস্থ্য মনিটর করুন।"

#: build/admin/airygen-app.js
msgid "Link Counter must be enabled to gather internal link data."
msgstr "অভ্যন্তরীণ লিংক ডেটা সংগ্রহ করতে লিংক কাউন্টার সক্রিয় করতে হবে।"

#: build/admin/airygen-app.js
msgid "Tune scan frequency and limits. Lower numbers are safer on shared hosts."
msgstr "স্ক্যানের কম্পাঙ্ক ও সীমা সামঞ্জস্য করুন। শেয়ার্ড হোস্টে কম সংখ্যা নিরাপদ।"

#: build/admin/airygen-app.js
msgid "How often the scanner runs. Set higher on large sites."
msgstr "স্ক্যানার কত ঘন ঘন চলে। বড় সাইটে বেশি সেট করুন।"

#: build/admin/airygen-app.js
msgid "Max requests per run"
msgstr "প্রতি রানে সর্বোচ্চ অনুরোধ"

#: build/admin/airygen-app.js
msgid "Limits simultaneous HTTP requests during a scan."
msgstr "স্ক্যানের সময় একযোগে HTTP অনুরোধ সীমিত করে।"

#: build/admin/airygen-app.js
msgid "Pause between request batches to reduce load."
msgstr "লোড কমাতে অনুরোধের ব্যাচের মধ্যে বিরতি দিন।"

#: build/admin/airygen-app.js
msgid "Older log entries are deleted automatically."
msgstr "পুরনো লগ এন্ট্রি স্বয়ংক্রিয়ভাবে মুছে যায়।"

#: build/admin/airygen-app.js
msgid "Max time to open a connection before aborting."
msgstr "বাতিল করার আগে একটি সংযোগ খোলার সর্বোচ্চ সময়।"

#: build/admin/airygen-app.js
msgid "Max time to complete a request before aborting."
msgstr "বাতিল করার আগে একটি অনুরোধ সম্পূর্ণ করার সর্বোচ্চ সময়।"

#: build/admin/airygen-app.js
msgid "Treat redirects as warnings"
msgstr "রিডাইরেক্টগুলো সতর্কতা হিসেবে বিবেচনা করুন"

#: build/admin/airygen-app.js
msgid "When on, redirected links are flagged but not counted as errors."
msgstr "চালু হলে রিডাইরেক্টেড লিংক চিহ্নিত হয় কিন্তু ত্রুটি হিসেবে গণ্য হয় না।"

#: build/admin/airygen-app.js
msgid "Choose which link types are included in broken-link scans."
msgstr "broken-link scan-এ কোন link typeগুলো অন্তর্ভুক্ত হবে তা বেছে নিন।"

#: build/admin/airygen-app.js
msgid "Link types to scan"
msgstr "স্ক্যান করার লিংক ধরনসমূহ"

#: build/admin/airygen-app.js
msgid "External"
msgstr "বাহ্যিক"

#: build/admin/airygen-app.js
msgid "Internal"
msgstr "অভ্যন্তরীণ"

#: build/admin/airygen-app.js
msgid "Shows current background job status for Broken Link Checker scans."
msgstr "Broken Link Checker স্ক্যানের বর্তমান ব্যাকগ্রাউন্ড জব স্ট্যাটাস দেখায়।"

#: build/admin/airygen-app.js
msgid "Link log"
msgstr "লিংক লগ"

#: build/admin/airygen-app.js
msgid "Review recent link checks and jump to affected posts."
msgstr "সাম্প্রতিক লিংক যাচাই পর্যালোচনা করুন এবং প্রভাবিত পোস্টে যান।"

#: build/admin/airygen-app.js
msgid "Filters"
msgstr "ফিল্টারসমূহ"

#: build/admin/airygen-app.js
msgid "Toggle which statuses appear in the log."
msgstr "লগে কোন স্ট্যাটাসগুলো দেখাবে তা টগল করুন।"

#: build/admin/airygen-app.js
