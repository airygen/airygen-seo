#: build/admin/airygen-app.js
msgid "Configure JSON-LD output for organization, website, breadcrumbs, and articles."
msgstr "organization, website, ব্রেডক্রাম্ব এবং article-এর জন্য JSON-LD output কনফিগার করুন।"

#: build/admin/airygen-app.js
msgid "Control author archive metadata, indexing, and author schema output."
msgstr "author archive metadata, indexing এবং author schema output নিয়ন্ত্রণ করুন।"

#: build/admin/airygen-app.js
msgid "Manage category, tag, and taxonomy archive metadata."
msgstr "ক্যাটাগরি, ট্যাগ এবং ট্যাক্সোনমি আর্কাইভ মেটাডেটা পরিচালনা করুন।"

#: build/admin/airygen-app.js
msgid "Add product-specific SEO templates and rely on WooCommerce native Product schema."
msgstr "প্রোডাক্ট-নির্দিষ্ট SEO টেমপ্লেট যোগ করুন এবং WooCommerce-এর নেটিভ Product schema-এর ওপর নির্ভর করুন।"

#: build/admin/airygen-app.js
msgid "Publish LocalBusiness schema, geo meta tags, and reusable business info shortcodes."
msgstr "LocalBusiness স্কিমা, জিও মেটা ট্যাগ এবং পুনর্ব্যবহারযোগ্য ব্যবসায়িক তথ্য শর্টকোড প্রকাশ করুন।"

#: build/admin/airygen-app.js
msgid "Display breadcrumb trails in templates and expose a matching Schema graph."
msgstr "টেমপ্লেটে breadcrumb ট্রেইল প্রদর্শন করুন এবং একটি মিলিত স্কিমা গ্রাফ প্রকাশ করুন।"

#: build/admin/airygen-app.js
msgid "Generate a linked outline of headings inside your content."
msgstr "আপনার কনটেন্টের ভিতরের শিরোনামের একটি লিংকযুক্ত আউটলাইন তৈরি করুন।"

#: build/admin/airygen-app.js
msgid "Organize pillar, cluster, and support content relationships."
msgstr "পিলার, ক্লাস্টার এবং সাপোর্ট কনটেন্ট সম্পর্ক সংগঠিত করুন।"

#: build/admin/airygen-app.js
msgid "Set default robots meta directives and extend WordPress' robots.txt."
msgstr "ডিফল্ট robots মেটা নির্দেশনা সেট করুন এবং WordPress-এর robots.txt সম্প্রসারিত করুন।"

#: build/admin/airygen-app.js
msgid "Automatically fill missing image alt/title attributes with custom templates."
msgstr "কাস্টম টেমপ্লেট দিয়ে অনুপস্থিত ইমেজ alt/title অ্যাট্রিবিউট স্বয়ংক্রিয়ভাবে পূরণ করুন।"

#: build/admin/airygen-app.js
msgid "Help search engines pick the right language URL for each visitor."
msgstr "প্রতিটি দর্শকের জন্য সঠিক ভাষার URL বেছে নিতে সার্চ ইঞ্জিনকে সাহায্য করুন।"

#: build/admin/airygen-app.js
msgid "Manage the sitemap index and exposed post types. When enabled, Airygen SEO replaces WordPress’ default sitemap."
msgstr "সাইটম্যাপ ইন্ডেক্স ও প্রকাশিত পোস্ট ধরন পরিচালনা করুন। সক্রিয় হলে Airygen SEO WordPress-এর ডিফল্ট সাইটম্যাপ প্রতিস্থাপন করে।"

#: build/admin/airygen-app.js
