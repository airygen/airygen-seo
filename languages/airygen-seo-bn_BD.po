#: build/admin/airygen-app.js
msgid "Choose a schema type for each content type (Post, Page, Media). Leave empty to use the Default article type."
msgstr "প্রতিটি content type-এর (Post, Page, Media) জন্য একটি schema type বেছে নিন। Default article type ব্যবহার করতে খালি রাখুন।"

#: build/admin/airygen-app.js
msgid "Used when generating schema for this content type."
msgstr "এই কনটেন্ট ধরনের স্কিমা তৈরি করার সময় ব্যবহৃত।"

#: build/admin/airygen-app.js
msgid "Visibility"
msgstr "দৃশ্যমানতা"

#: build/admin/airygen-app.js
msgid "Select which schema graphs Airygen SEO should output for visitors."
msgstr "Airygen SEO দর্শকদের জন্য কোন স্কিমা গ্রাফ আউটপুট করবে তা নির্বাচন করুন।"

#: build/admin/airygen-app.js
msgid "Output Organization graph"
msgstr "Organization গ্রাফ আউটপুট করুন"

#: build/admin/airygen-app.js
msgid "Includes Organization/LocalBusiness JSON-LD based on the details above."
msgstr "উপরের বিস্তারিতের উপর ভিত্তি করে Organization/LocalBusiness JSON-LD অন্তর্ভুক্ত করে।"

#: build/admin/airygen-app.js
msgid "Output Website graph"
msgstr "Website গ্রাফ আউটপুট করুন"

