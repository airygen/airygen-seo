#. Plugin Name of the plugin
msgid "Airygen"
msgstr "Airygen"

#. Plugin URI of the plugin
msgid "https://www.airygen.com/product/wordpress-seo-plugin/"
msgstr "https://www.airygen.com/product/wordpress-seo-plugin/"

#. Description of the plugin
msgid "The best SEO plugin for WordPress to optimize your website for search engines and improve your rankings."
msgstr "সার্চ ইঞ্জিনের জন্য আপনার ওয়েবসাইট অপ্টিমাইজ করতে এবং র‍্যাঙ্কিং উন্নত করতে WordPress-এর সেরা SEO প্লাগইন।"

#. Author of the plugin
msgid "Airygen Team"
msgstr "Airygen Team"

#. Author URI of the plugin
msgid "https://github.com/airygen"
msgstr "https://github.com/airygen"

msgid "SEO title length"
msgstr "SEO শিরোনামের দৈর্ঘ্য"

msgid "Title includes focus keyphrase"
msgstr "শিরোনামে ফোকাস কীফ্রেজ আছে"

msgid "Meta description present"
msgstr "মেটা বর্ণনা উপস্থিত"

#. translators: 1: minimum px width, 2: maximum px width.
#, php-format
