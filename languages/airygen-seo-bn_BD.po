msgstr "অন্তত একটি ছবির alt-এ ফোকাস কীফ্রেজ আছে"

#. translators: 1: minimum internal links, 2: maximum internal links.
#, php-format
msgid "Internal links between %1$d and %2$d"
msgstr "অভ্যন্তরীণ লিংক %1$d এবং %2$d-এর মধ্যে"

#. translators: %d is the minimum external links count.
#, php-format
msgid "External links at least %d"
msgstr "বাহ্যিক লিংক কমপক্ষে %d"

msgid "External links use rel attributes"
msgstr "বাহ্যিক লিংক rel অ্যাট্রিবিউট ব্যবহার করে"

msgid "Slug has 2–5 words"
msgstr "স্লাগে ২–৫টি শব্দ আছে"

msgid "Slug includes focus keyphrase"
msgstr "স্লাগে ফোকাস কীফ্রেজ আছে"

msgid "Canonical is valid"
msgstr "Canonical বৈধ"

msgid "Article structured data present"
msgstr "আর্টিকেলের স্ট্রাকচার্ড ডেটা উপস্থিত রয়েছে"

msgid "Breadcrumb structured data present"
msgstr "ব্রেডক্রাম্ব স্ট্রাকচার্ড ডেটা উপস্থিত"

