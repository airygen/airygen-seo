#, php-format
msgid "Focus keyphrase density %1$s%%-%2$s%%"
msgstr "ফোকাস কীফ্রেজ ঘনত্ব %1$s%%-%2$s%%"

#. translators: 1: per phrase minimum density, 2: per phrase maximum density, 3: total maximum density.
#, php-format
msgid "Long-tail keyphrase density %1$s%%-%2$s%% each, total <= %3$s%%"
msgstr "লং-টেইল কীফ্রেজ ঘনত্ব প্রতিটি %1$s%%-%2$s%%, মোট <= %3$s%%"

#. translators: %d is the minimum word count.
#, php-format
msgid "Word count at least %d"
msgstr "শব্দ গণনা কমপক্ষে %d"

#. translators: %d is the minimum Flesch score.
#, php-format
msgid "Flesch reading ease >= %d (non-CJK)"
msgstr "Flesch পাঠযোগ্যতা স্বাচ্ছন্দ্য >= %d (নন-CJK)"

#. translators: %d is the maximum CJK sentence length.
#, php-format
msgid "Average sentence length <= %d (CJK)"
msgstr "গড় বাক্যের দৈর্ঘ্য <= %d (CJK)"

msgid "At least one image in content"
msgstr "কনটেন্টে অন্তত একটি ছবি"

msgid "All images have alt text"
msgstr "সব ছবিতে alt টেক্সট রয়েছে"

#. translators: %d is the minimum spacing distance.
#, php-format
msgid "Long-tail keyphrases spaced %d+ words/chars from other keyphrases"
msgstr "লং-টেইল কীফ্রেজগুলো অন্য কীফ্রেজ থেকে %d+ শব্দ/অক্ষর দূরে"

