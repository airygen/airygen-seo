#: build/admin/airygen-app.js
msgid "Broken Link Checker"
msgstr "Verificador de Ligações Quebradas"

#: build/admin/airygen-app.js
msgid "Scan content for broken and redirected links, and monitor crawl health."
msgstr "Verificar conteúdo para ligações quebradas e redirecionadas, e monitorizar estado de rastreio."

#: build/admin/airygen-app.js
msgid "Link Counter must be enabled to gather internal link data."
msgstr "O Contador de Ligações deve estar ativado para recolher dados de ligações internas."

#: build/admin/airygen-app.js
msgid "Tune scan frequency and limits. Lower numbers are safer on shared hosts."
msgstr "Ajustar frequência e limites de verificação. Números mais baixos são mais seguros em alojamento partilhado."

#: build/admin/airygen-app.js
msgid "How often the scanner runs. Set higher on large sites."
msgstr "Com que frequência o verificador é executado. Defina mais alto em sites grandes."

#: build/admin/airygen-app.js
msgid "Max requests per run"
msgstr "Máximo de pedidos por execução"

#: build/admin/airygen-app.js
msgid "Limits simultaneous HTTP requests during a scan."
msgstr "Limita pedidos HTTP simultâneos durante uma verificação."

#: build/admin/airygen-app.js
msgid "Pause between request batches to reduce load."
msgstr "Pausa entre lotes de pedidos para reduzir carga."

#: build/admin/airygen-app.js
msgid "Older log entries are deleted automatically."
msgstr "Entradas de registo mais antigas são eliminadas automaticamente."

#: build/admin/airygen-app.js
msgid "Max time to open a connection before aborting."
msgstr "Tempo máximo para abrir uma ligação antes de abortar."

#: build/admin/airygen-app.js
msgid "Max time to complete a request before aborting."
msgstr "Tempo máximo para completar um pedido antes de abortar."

#: build/admin/airygen-app.js
msgid "Treat redirects as warnings"
msgstr "Tratar redirecionamentos como avisos"

#: build/admin/airygen-app.js
msgid "When on, redirected links are flagged but not counted as errors."
msgstr "Quando ativado, ligações redirecionadas são sinalizadas mas não contadas como erros."

#: build/admin/airygen-app.js
msgid "Choose which link types are included in broken-link scans."
msgstr "Escolha que tipos de ligação são incluídos nas análises de ligações quebradas."

#: build/admin/airygen-app.js
msgid "Link types to scan"
msgstr "Tipos de ligação a verificar"

