#: build/admin/airygen-app.js
msgid "Welcome to Airygen SEO!"
msgstr "Bem-vindo ao Airygen SEO!"

#: build/admin/airygen-app.js
msgid "Answer 10 quick questions and we'll recommend the right SEO modules for your site — then enable them all with one click."
msgstr "Responda a 10 perguntas rápidas e recomendaremos os módulos de SEO certos para o seu site — depois ative todos com um clique."

#: build/admin/airygen-app.js
msgid "Don't worry — every question is just Yes or No. No technical knowledge needed. It takes about 2 minutes. 😊"
msgstr "Não se preocupe — cada pergunta é apenas Sim ou Não. Não é necessário conhecimento técnico. Demora cerca de 2 minutos. 😊"

#: build/admin/airygen-app.js
msgid "🎉 All done! Here's what we recommend based on your answers:"
msgstr "🎉 Tudo concluído! Aqui está o que recomendamos com base nas suas respostas:"

#: build/admin/airygen-app.js
msgid "Will be enabled (included in your plan)"
msgstr "Será ativado (incluído no seu plano)"

#: build/admin/airygen-app.js
msgid "Requires an upgrade to enable"
msgstr "Requer atualização para ativar"

#: build/admin/airygen-app.js
msgid "Upgrade to"
msgstr "Atualizar para"

#: build/admin/airygen-app.js
msgid "No modules selected. Click Finish to close the wizard."
msgstr "Nenhum módulo selecionado. Clique em Concluir para fechar o assistente."

#: build/admin/airygen-app.js
msgid "Setup Wizard"
msgstr "Assistente de configuração"

#: build/admin/airygen-app.js
msgid "Drop blocks here"
msgstr "Solte blocos aqui"

#: build/admin/airygen-app.js
msgid "Two ways to open settings"
msgstr "Duas formas de abrir as definições"

#: build/admin/airygen-app.js
msgid "Click \"Open global settings\" here, or use Settings in the top navigation bar — both take you to the same settings page."
msgstr "Clique em \"Abrir definições globais\" aqui, ou utilize Definições na barra de navegação superior — ambos levam à mesma página de definições."

#: build/admin/airygen-app.js
msgid "Drag modules to reorder"
msgstr "Arraste módulos para reordenar"

#: build/admin/airygen-app.js
msgid "Drag any module card to rearrange them. The Settings menu bar reflects this exact order — put your most-used modules up front."
msgstr "Arraste qualquer cartão de módulo para reorganizá-los. A barra de menu Definições reflete exatamente esta ordem."

#: build/admin/airygen-app.js
msgid "Control editor panel order"
msgstr "Controlar ordem dos painéis do editor"

#: build/admin/airygen-app.js
msgid "Drag these panel cards to set the display order of sidebar panels shown in the post editor. The order here is the order there."
