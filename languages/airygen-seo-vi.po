#: build/admin/airygen-app.js
msgid "Broken Link Checker"
msgstr "Kiểm tra liên kết hỏng"

#: build/admin/airygen-app.js
msgid "Scan content for broken and redirected links, and monitor crawl health."
msgstr "Quét nội dung để phát hiện liên kết hỏng và chuyển hướng, giám sát sức khỏe thu thập dữ liệu."

#: build/admin/airygen-app.js
msgid "Link Counter must be enabled to gather internal link data."
msgstr "Bộ đếm liên kết phải được bật để thu thập dữ liệu liên kết nội bộ."

#: build/admin/airygen-app.js
msgid "Tune scan frequency and limits. Lower numbers are safer on shared hosts."
msgstr "Điều chỉnh tần suất quét và giới hạn. Số thấp hơn an toàn hơn trên hosting chia sẻ."

#: build/admin/airygen-app.js
msgid "How often the scanner runs. Set higher on large sites."
msgstr "Tần suất chạy quét. Đặt cao hơn trên trang web lớn."

#: build/admin/airygen-app.js
msgid "Max requests per run"
msgstr "Yêu cầu tối đa mỗi lần chạy"

#: build/admin/airygen-app.js
msgid "Limits simultaneous HTTP requests during a scan."
msgstr "Giới hạn yêu cầu HTTP đồng thời trong khi quét."

#: build/admin/airygen-app.js
msgid "Pause between request batches to reduce load."
msgstr "Tạm dừng giữa các đợt yêu cầu để giảm tải."

#: build/admin/airygen-app.js
msgid "Older log entries are deleted automatically."
msgstr "Mục nhật ký cũ bị xóa tự động."

#: build/admin/airygen-app.js
msgid "Max time to open a connection before aborting."
msgstr "Thời gian tối đa để mở kết nối trước khi hủy."

#: build/admin/airygen-app.js
msgid "Max time to complete a request before aborting."
msgstr "Thời gian tối đa để hoàn tất yêu cầu trước khi hủy."

#: build/admin/airygen-app.js
msgid "Treat redirects as warnings"
msgstr "Coi chuyển hướng là cảnh báo"

#: build/admin/airygen-app.js
msgid "When on, redirected links are flagged but not counted as errors."
msgstr "Khi bật, liên kết chuyển hướng được đánh dấu nhưng không tính là lỗi."

#: build/admin/airygen-app.js
msgid "Choose which link types are included in broken-link scans."
msgstr "Chọn loại liên kết được bao gồm khi quét liên kết hỏng."

#: build/admin/airygen-app.js
msgid "Link types to scan"
msgstr "Loại liên kết cần quét"

#: build/admin/airygen-app.js
msgid "External"
msgstr "Bên ngoài"

#: build/admin/airygen-app.js
msgid "Internal"
msgstr "Nội bộ"

#: build/admin/airygen-app.js
msgid "Shows current background job status for Broken Link Checker scans."
msgstr "Hiển thị trạng thái công việc nền hiện tại cho quét Kiểm tra liên kết hỏng."

#: build/admin/airygen-app.js
msgid "Link log"
msgstr "Nhật ký liên kết"

#: build/admin/airygen-app.js
msgid "Review recent link checks and jump to affected posts."
msgstr "Xem lại kiểm tra liên kết gần đây và chuyển đến bài viết bị ảnh hưởng."

#: build/admin/airygen-app.js
msgid "Filters"
msgstr "Bộ lọc"

#: build/admin/airygen-app.js
msgid "Toggle which statuses appear in the log."
msgstr "Bật/tắt trạng thái nào hiển thị trong nhật ký."

#: build/admin/airygen-app.js
msgid "OK"
msgstr "OK"

#: build/admin/airygen-app.js
msgid "Redirect"
msgstr "Chuyển hướng"

#: build/admin/airygen-app.js
msgid "URL"
msgstr "URL"

#: build/admin/airygen-app.js
msgid "Checked at"
msgstr "Kiểm tra lúc"

#: build/admin/airygen-app.js
msgid "Edit post"
msgstr "Chỉnh sửa bài viết"

#: build/admin/airygen-app.js
msgid "View post"
msgstr "Xem bài viết"

#: build/admin/airygen-app.js
msgid "Open link"
msgstr "Mở liên kết"

#: build/admin/airygen-app.js
msgid "pts"
msgstr "điểm"

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Your SEO title should be long enough to explain the topic, but short enough to avoid truncation."
msgstr "Tiêu đề SEO nên đủ dài để giải thích chủ đề, nhưng đủ ngắn để tránh bị cắt."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Aim for about 50–60 characters. Front-load the most important words."
msgstr "Nhắm khoảng 50–60 ký tự. Đặt từ quan trọng nhất lên đầu."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear, visible titles improve click-through rate from search results."
msgstr "Tiêu đề rõ ràng, dễ thấy cải thiện tỷ lệ nhấp từ kết quả tìm kiếm."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Search engines expect the primary topic to appear in the title."
msgstr "Công cụ tìm kiếm mong đợi chủ đề chính xuất hiện trong tiêu đề."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Include your focus keyphrase naturally near the start of the title."
msgstr "Bao gồm từ khóa trọng tâm tự nhiên gần đầu tiêu đề."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves topical relevance and makes the result more recognizable."
msgstr "Cải thiện tính liên quan chủ đề và giúp kết quả dễ nhận biết hơn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "A meta description helps search engines and users understand the page."
msgstr "Thẻ meta mô tả giúp công cụ tìm kiếm và người dùng hiểu nội dung trang."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Write 1–2 sentences that summarize the page and invite a click."
msgstr "Viết 1–2 câu tóm tắt trang và mời nhấp."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Better snippets can lift click-through rate even if rankings stay the same."
msgstr "Đoạn trích tốt hơn có thể tăng tỷ lệ nhấp ngay cả khi thứ hạng không đổi."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Descriptions that are too short or too long get cut off in results."
msgstr "Mô tả quá ngắn hoặc quá dài sẽ bị cắt trong kết quả."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep it roughly 140–160 characters and prioritize the main benefit."
msgstr "Giữ khoảng 140–160 ký tự và ưu tiên lợi ích chính."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Full snippets look more professional and improve engagement."
msgstr "Đoạn trích đầy đủ trông chuyên nghiệp hơn và cải thiện tương tác."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the focus phrase helps confirm the page topic."
msgstr "Bao gồm cụm từ trọng tâm giúp xác nhận chủ đề trang."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Work the focus keyphrase into the first sentence naturally."
msgstr "Đưa từ khóa trọng tâm vào câu đầu tiên một cách tự nhiên."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger relevance signals can improve ranking and user confidence."
msgstr "Tín hiệu liên quan mạnh hơn có thể cải thiện xếp hạng và lòng tin của người dùng."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Title and description should not repeat each other."
msgstr "Tiêu đề và mô tả không nên lặp lại nhau."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the title to state the topic and the description to add benefit or context."
msgstr "Sử dụng tiêu đề để nêu chủ đề và mô tả để thêm lợi ích hoặc bối cảnh."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Distinct messaging gives users more reasons to click."
msgstr "Thông điệp khác biệt cho người dùng thêm lý do để nhấp."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Pages should have a single main heading (H1)."
msgstr "Trang nên có một tiêu đề chính duy nhất (H1)."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keep one H1 that matches the page topic, and use H2/H3 for sections."
msgstr "Giữ một H1 phù hợp với chủ đề trang, và dùng H2/H3 cho các phần."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clear structure helps search engines understand the content hierarchy."
msgstr "Cấu trúc rõ ràng giúp công cụ tìm kiếm hiểu hệ thống phân cấp nội dung."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Subheadings break long content into scannable sections."
msgstr "Tiêu đề phụ chia nội dung dài thành các phần dễ quét."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add 2–8 H2/H3 headings that summarize key sections."
msgstr "Thêm 2–8 tiêu đề H2/H3 tóm tắt các phần chính."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves readability and keeps users engaged longer."
msgstr "Cải thiện khả năng đọc và giữ người dùng tương tác lâu hơn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the keyphrase in a subheading reinforces the main topic."
msgstr "Bao gồm từ khóa trọng tâm trong tiêu đề phụ củng cố chủ đề chính."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Place the focus keyphrase in one relevant H2 or H3."
msgstr "Đặt từ khóa trọng tâm trong một H2 hoặc H3 liên quan."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps search engines connect sections to the main theme."
msgstr "Giúp công cụ tìm kiếm kết nối các phần với chủ đề chính."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "The opening paragraph sets context for both users and search engines."
msgstr "Đoạn mở đầu đặt bối cảnh cho cả người dùng và công cụ tìm kiếm."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the focus keyphrase once in the first 1–2 sentences."
msgstr "Sử dụng từ khóa trọng tâm một lần trong 1–2 câu đầu tiên."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Stronger topical clarity can improve relevance signals."
msgstr "Độ rõ ràng chủ đề mạnh hơn có thể cải thiện tín hiệu liên quan."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keyphrase density shows how often the main topic appears."
msgstr "Mật độ từ khóa trọng tâm cho thấy chủ đề chính xuất hiện thường xuyên như thế nào."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the keyphrase naturally throughout the content without stuffing."
msgstr "Sử dụng từ khóa trọng tâm tự nhiên trong toàn bộ nội dung mà không nhồi."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Balanced usage supports relevance while avoiding spam signals."
msgstr "Sử dụng cân bằng hỗ trợ tính liên quan đồng thời tránh tín hiệu spam."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long-tail phrases capture more specific search intent."
msgstr "Cụm từ đuôi dài nắm bắt ý định tìm kiếm cụ thể hơn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add your long-tail phrases where they fit naturally in sections."
msgstr "Thêm cụm từ đuôi dài vào những vị trí phù hợp tự nhiên trong các phần."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps the page rank for more specific queries."
msgstr "Giúp trang xếp hạng cho truy vấn cụ thể hơn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Very short pages often lack depth to satisfy readers."
msgstr "Trang quá ngắn thường thiếu chiều sâu để thỏa mãn người đọc."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Expand the content with examples, steps, or FAQs."
msgstr "Mở rộng nội dung bằng ví dụ, bước thực hiện hoặc FAQ."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "More complete content tends to perform better for informational queries."
msgstr "Nội dung đầy đủ hơn có xu hướng hoạt động tốt hơn cho truy vấn thông tin."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Readable content keeps users engaged and reduces bounce."
msgstr "Nội dung dễ đọc giữ người dùng tương tác và giảm thoát."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Shorten sentences, use simpler words, and break up long paragraphs."
msgstr "Rút ngắn câu, sử dụng từ đơn giản hơn và chia nhỏ đoạn văn dài."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improved clarity boosts dwell time and user satisfaction."
msgstr "Độ rõ ràng cải thiện giúp tăng thời gian ở lại và sự hài lòng của người dùng."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Long sentences are hard to read in CJK languages."
msgstr "Câu dài khó đọc trong ngôn ngữ CJK."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Split long sentences and add punctuation for clearer flow."
msgstr "Chia câu dài và thêm dấu câu để dòng chảy rõ ràng hơn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clearer reading experience helps users stay on the page."
msgstr "Trải nghiệm đọc rõ ràng hơn giúp người dùng ở lại trang."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Images support understanding and break up long text."
msgstr "Hình ảnh hỗ trợ hiểu nội dung và chia nhỏ văn bản dài."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add at least one relevant image that illustrates the topic."
msgstr "Thêm ít nhất một hình ảnh liên quan minh họa cho chủ đề."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Visuals improve engagement and can help with image search."
msgstr "Hình ảnh trực quan cải thiện tương tác và có thể hỗ trợ tìm kiếm hình ảnh."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Alt text helps search engines and screen readers interpret images."
msgstr "Văn bản alt giúp công cụ tìm kiếm và trình đọc màn hình hiểu hình ảnh."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Describe each image in plain language, focusing on what it shows."
msgstr "Mô tả mỗi hình ảnh bằng ngôn ngữ đơn giản, tập trung vào nội dung hiển thị."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves accessibility and adds extra relevance signals."
msgstr "Cải thiện khả năng truy cập và thêm tín hiệu liên quan."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spacing long-tail phrases prevents keyword stuffing."
msgstr "Giãn cách cụm từ đuôi dài giúp tránh nhồi từ khóa."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Spread similar phrases across different sections."
msgstr "Rải cụm từ tương tự qua các phần khác nhau."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Keeps content natural while still covering long-tail queries."
msgstr "Giữ nội dung tự nhiên trong khi vẫn bao phủ truy vấn đuôi dài."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the keyphrase in one image alt text reinforces the topic."
msgstr "Bao gồm từ khóa trọng tâm trong văn bản alt một hình ảnh củng cố chủ đề."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use the focus phrase in a single relevant image alt description."
msgstr "Sử dụng cụm từ trọng tâm trong mô tả alt một hình ảnh liên quan."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Adds topical relevance without over-optimizing every image."
msgstr "Tăng tính liên quan chủ đề mà không tối ưu hóa quá mức mọi hình ảnh."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Internal links help users and search engines discover related pages."
msgstr "Liên kết nội bộ giúp người dùng và công cụ tìm kiếm khám phá trang liên quan."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Link to 1–3 relevant posts or pages using descriptive anchor text."
msgstr "Liên kết đến 1–3 bài viết hoặc trang liên quan bằng văn bản neo mô tả."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Improves site structure and can pass authority to key pages."
msgstr "Cải thiện cấu trúc trang web và có thể chuyển uy tín cho các trang quan trọng."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "External links show credibility and provide references."
msgstr "Liên kết ngoài thể hiện sự đáng tin cậy và cung cấp tài liệu tham khảo."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add at least one trusted source link that supports your content."
msgstr "Thêm ít nhất một liên kết nguồn đáng tin cậy hỗ trợ nội dung của bạn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Builds trust and can improve perceived quality."
msgstr "Xây dựng lòng tin và có thể cải thiện chất lượng cảm nhận."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Rel attributes clarify how external links should be treated."
msgstr "Thuộc tính rel làm rõ cách xử lý liên kết ngoài."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add rel values like nofollow, sponsored, or ugc where appropriate."
msgstr "Thêm giá trị rel như nofollow, sponsored hoặc ugc ở vị trí phù hợp."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Helps avoid link spam signals and keeps compliance clean."
msgstr "Giúp tránh tín hiệu liên kết spam và duy trì tuân thủ."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Short, readable URLs are easier to understand and share."
msgstr "URL ngắn, dễ đọc giúp dễ hiểu và chia sẻ hơn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Use 2–5 words that match the topic and remove stop words."
msgstr "Sử dụng 2–5 từ phù hợp với chủ đề và loại bỏ từ dừng."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Clean URLs improve clarity and can increase click confidence."
msgstr "URL gọn gàng cải thiện độ rõ ràng và có thể tăng độ tin cậy khi nhấp."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Including the focus phrase in the URL reinforces relevance."
msgstr "Bao gồm cụm từ trọng tâm trong URL tăng cường tính liên quan."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Add the focus keyphrase to the slug without extra filler."
msgstr "Thêm từ khóa trọng tâm vào slug mà không thêm từ thừa."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Strengthens topical signals and makes URLs clearer."
msgstr "Tăng cường tín hiệu chủ đề và làm URL rõ ràng hơn."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Canonical URLs tell search engines which version to index."
msgstr "URL chuẩn tắc cho công cụ tìm kiếm biết phiên bản nào cần lập chỉ mục."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Ensure the canonical points to the main URL of the page."
msgstr "Đảm bảo URL chuẩn tắc trỏ đến URL chính của trang."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
msgid "Prevents duplicate content issues and consolidates ranking signals."
msgstr "Ngăn vấn đề nội dung trùng lặp và hợp nhất tín hiệu xếp hạng."

#: build/admin/airygen-app.js
#: build/block-editor/airygen-editor.js
#: build/classic-editor/airygen-editor.js
