msgstr "Bỏ qua bài viết yêu cầu mật khẩu."

#: build/admin/airygen-app.js
msgid "Exclude posts below word count"
msgstr "Loại trừ bài viết dưới số từ"

#: build/admin/airygen-app.js
msgid "Exclude auto-selected posts with fewer words than this value."
msgstr "Loại trừ bài viết tự động chọn có ít từ hơn giá trị này."

#: build/admin/airygen-app.js
msgid "Arrange curated selection cards for llms.txt output."
msgstr "Sắp xếp thẻ lựa chọn cho đầu ra llms.txt."

#: build/admin/airygen-app.js
