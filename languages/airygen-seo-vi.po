msgstr "Kiểm soát nội dung nào nên bị loại trừ khỏi đầu ra LLMs.txt."

#: build/admin/airygen-app.js
msgid "Exclude noindex"
msgstr "Loại trừ noindex"

#: build/admin/airygen-app.js
