msgstr "Dùng làm dòng mô tả trích dẫn dưới tiêu đề H1."

#: build/admin/airygen-app.js
msgid "File path"
msgstr "Đường dẫn tệp"

#: build/admin/airygen-app.js
msgid "Set the output path using a folder path and file name."
msgstr "Đặt đường dẫn đầu ra bằng đường dẫn thư mục và tên tệp."

#: build/admin/airygen-app.js
msgid "Optional instructions included only in this extension output."
msgstr "Hướng dẫn tùy chọn chỉ bao gồm trong đầu ra tiện ích mở rộng này."

#: build/admin/airygen-app.js
msgid "Arrange curated selection cards for this extension override."
msgstr "Sắp xếp thẻ lựa chọn cho ghi đè tiện ích mở rộng này."

#: build/admin/airygen-app.js
msgid "Preview generated llms.txt output from current curated and scope settings."
msgstr "Xem trước đầu ra llms.txt từ cài đặt tuyển chọn và phạm vi hiện tại."

#: build/admin/airygen-app.js
msgid "Preview loaded."
msgstr "Đã tải xem trước."

#: build/admin/airygen-app.js
