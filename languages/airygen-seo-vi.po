msgstr "Tiêu đề này là nhãn phần mà LLM sẽ đọc trong llms.txt."

#: build/admin/airygen-app.js
msgid "This description is included in the generated llms.txt file."
msgstr "Mô tả này được bao gồm trong tệp llms.txt được tạo."

#: build/admin/airygen-app.js
