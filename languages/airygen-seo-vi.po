#: build/admin/airygen-app.js
msgid "Manage Open Graph and Twitter defaults."
msgstr "Quản lý mặc định Open Graph và Twitter."

#: build/admin/airygen-app.js
msgid "Configure JSON-LD output for organization, website, breadcrumbs, and articles."
msgstr "Cấu hình đầu ra JSON-LD cho tổ chức, trang web, đường dẫn điều hướng và bài viết."

#: build/admin/airygen-app.js
msgid "Control author archive metadata, indexing, and author schema output."
msgstr "Kiểm soát siêu dữ liệu trang lưu trữ tác giả, lập chỉ mục và đầu ra schema tác giả."

#: build/admin/airygen-app.js
msgid "Manage category, tag, and taxonomy archive metadata."
msgstr "Quản lý siêu dữ liệu trang lưu trữ danh mục, thẻ và phân loại."

#: build/admin/airygen-app.js
msgid "Add product-specific SEO templates and rely on WooCommerce native Product schema."
msgstr "Thêm mẫu SEO dành riêng cho sản phẩm và sử dụng schema Product gốc của WooCommerce."

#: build/admin/airygen-app.js
msgid "Publish LocalBusiness schema, geo meta tags, and reusable business info shortcodes."
msgstr "Xuất bản schema LocalBusiness, thẻ meta địa lý và shortcode thông tin doanh nghiệp tái sử dụng."

#: build/admin/airygen-app.js
msgid "Display breadcrumb trails in templates and expose a matching Schema graph."
msgstr "Hiển thị đường dẫn điều hướng trong mẫu và cung cấp biểu đồ Schema tương ứng."

#: build/admin/airygen-app.js
msgid "Generate a linked outline of headings inside your content."
msgstr "Tạo dàn ý có liên kết từ tiêu đề trong nội dung."

#: build/admin/airygen-app.js
msgid "Organize pillar, cluster, and support content relationships."
msgstr "Tổ chức mối quan hệ nội dung trụ cột, cụm và hỗ trợ."

#: build/admin/airygen-app.js
msgid "Set default robots meta directives and extend WordPress' robots.txt."
msgstr "Đặt chỉ thị thẻ meta robots mặc định và mở rộng robots.txt của WordPress."

#: build/admin/airygen-app.js
msgid "Automatically fill missing image alt/title attributes with custom templates."
msgstr "Tự động điền thuộc tính alt/title hình ảnh còn thiếu bằng mẫu tùy chỉnh."

#: build/admin/airygen-app.js
msgid "Help search engines pick the right language URL for each visitor."
msgstr "Giúp công cụ tìm kiếm chọn URL ngôn ngữ phù hợp cho mỗi khách truy cập."

#: build/admin/airygen-app.js
msgid "Manage the sitemap index and exposed post types. When enabled, Airygen SEO replaces WordPress’ default sitemap."
msgstr "Quản lý chỉ mục sơ đồ trang web và loại bài viết được hiển thị. Khi bật, Airygen SEO thay thế sơ đồ trang web mặc định của WordPress."

#: build/admin/airygen-app.js
msgid "Manage GA4, GTM, and custom tracking snippets in one place."
msgstr "Quản lý GA4, GTM và đoạn mã theo dõi tùy chỉnh tại một nơi."

#: build/admin/airygen-app.js
msgid "Add site verification tokens for search engines and webmaster platforms."
msgstr "Thêm mã xác minh trang web cho công cụ tìm kiếm và nền tảng quản trị web."

#: build/admin/airygen-app.js
msgid "Add custom signature text before and after RSS feed entries."
msgstr "Thêm chữ ký tùy chỉnh trước và sau mục nguồn cấp RSS."

#: build/admin/airygen-app.js
msgid "Notify IndexNow partners when URLs change and manage quota/backfill jobs."
msgstr "Thông báo cho đối tác IndexNow khi URL thay đổi và quản lý hạn mức/công việc bổ sung dữ liệu."

#: build/admin/airygen-app.js
msgid "Track internal, external, and incoming links with automated rescans."
msgstr "Theo dõi liên kết nội bộ, ngoài và đến với quét lại tự động."

#: build/admin/airygen-app.js
msgid "Serve up smart internal link suggestions based on keyphrases."
msgstr "Cung cấp gợi ý liên kết nội bộ thông minh dựa trên từ khóa trọng tâm."

#: build/admin/airygen-app.js
msgid "Collect 404 requests, monitor missing URLs, and define fallback behaviors."
msgstr "Thu thập yêu cầu 404, giám sát URL bị thiếu và xác định hành vi dự phòng."

#: build/admin/airygen-app.js
msgid "Send daily digest notifications via Email, Telegram, Discord, or Teams."
msgstr "Gửi thông báo tóm tắt hằng ngày qua Email, Telegram, Discord hoặc Teams."

#: build/admin/airygen-app.js
msgid "Expose clean markdown output from published content for AI clients."
msgstr "Cung cấp đầu ra markdown gọn từ nội dung đã xuất bản cho ứng dụng AI."

#: build/admin/airygen-app.js
msgid "Power the in-editor SEO score panel and REST endpoint."
msgstr "Cung cấp bảng điểm SEO trong trình soạn thảo và endpoint REST."

#: build/admin/airygen-app.js
msgid "Monitor outbound URLs for errors once link counting completes."
msgstr "Giám sát URL ra ngoài để phát hiện lỗi sau khi đếm liên kết hoàn tất."

