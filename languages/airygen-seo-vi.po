#: build/admin/airygen-app.js
msgid "Check basic sitewide SEO health and configuration."
msgstr "Kiểm tra tình trạng SEO cơ bản toàn site và cấu hình."

msgid "Mirror WordPress Sitewide SEO diagnostics with Airygen-specific checks (SSL, Safe Browsing, focus keywords)."
msgstr "Phản ánh chẩn đoán SEO toàn trang của WordPress bằng các kiểm tra riêng của Airygen (SSL, Safe Browsing, từ khóa trọng tâm)."

msgid "Mind map items contain invalid post data."
msgstr "Các mục trong sơ đồ tư duy chứa dữ liệu bài viết không hợp lệ."

msgid "One or more posts cannot be edited."
msgstr "Không thể chỉnh sửa một hoặc nhiều bài viết."

msgid "Each group must contain exactly one L1 topic before saving the mind map."
msgstr "Mỗi nhóm phải chứa chính xác một chủ đề L1 trước khi lưu sơ đồ tư duy."

msgid "Every L2 or L3 topic must reference a valid parent in the same group."
msgstr "Mỗi chủ đề L2 hoặc L3 phải tham chiếu đến phần tử cha hợp lệ trong cùng nhóm."

msgid "L2 topics must reference an L1 parent."
msgstr "Chủ đề L2 phải tham chiếu đến phần tử cha L1."

msgid "L3 topics must reference an L2 parent."
msgstr "Chủ đề L3 phải tham chiếu đến phần tử cha L2."

msgid "Previous ordering links must point to the same level in the same group."
msgstr "Liên kết sắp xếp trước đó phải trỏ đến cùng cấp độ trong cùng nhóm."

msgid "L3 ordering links must stay within the same parent topic."
msgstr "Liên kết sắp xếp L3 phải nằm trong cùng chủ đề cha."

msgid "Next ordering links must point to the same level in the same group."
msgstr "Liên kết sắp xếp tiếp theo phải trỏ đến cùng cấp độ trong cùng nhóm."

#: build/admin/airygen-app.js
msgid "Topic Cluster level updated in draft."
msgstr "Đã cập nhật cấp độ Topic Cluster trong bản nháp."

#: build/admin/airygen-app.js
msgid "L3 ordering only works within the same L2 parent."
msgstr "Sắp xếp L3 chỉ hoạt động trong cùng phần tử cha L2."

#: build/admin/airygen-app.js
msgid "Left/right ordering updated in draft."
msgstr "Đã cập nhật thứ tự trái/phải trong bản nháp."

#: build/admin/airygen-app.js
msgid "Cluster relationship updated in draft."
msgstr "Đã cập nhật mối quan hệ cụm trong bản nháp."

#: build/admin/airygen-app.js
msgid "Relation removed in draft."
msgstr "Đã xóa quan hệ trong bản nháp."

#: build/admin/airygen-app.js
msgid "Select a group before saving the mind map."
msgstr "Chọn một nhóm trước khi lưu sơ đồ tư duy."

#: build/admin/airygen-app.js
msgid "Mind map saved."
msgstr "Đã lưu sơ đồ tư duy."

#: build/admin/airygen-app.js
msgid "Unable to save the mind map."
msgstr "Không thể lưu sơ đồ tư duy."

#: build/admin/airygen-app.js
msgid "Mind map reset to last saved state."
msgstr "Đã đặt lại sơ đồ tư duy về trạng thái đã lưu gần nhất."

#: build/admin/airygen-app.js
msgid "Reset mind map changes"
msgstr "Đặt lại các thay đổi của sơ đồ tư duy"

#: build/admin/airygen-app.js
msgid "Reset the current mind map to the last saved state?"
msgstr "Đặt lại sơ đồ tư duy hiện tại về trạng thái đã lưu gần nhất?"

#: build/admin/airygen-app.js
msgid "Unsaved node positions and relationships in this mind map will be discarded."
msgstr "Vị trí nút và các mối quan hệ chưa lưu trong sơ đồ tư duy này sẽ bị loại bỏ."

#. translators: 1: current PHP version, 2: required PHP version
#, php-format
msgid "Airygen SEO requires PHP %2$s or higher. Your current PHP version is %1$s. Please upgrade PHP and try again."
msgstr "Airygen SEO yêu cầu PHP %2$s trở lên. Phiên bản PHP hiện tại của bạn là %1$s. Vui lòng nâng cấp PHP và thử lại."

msgid "Plugin Activation Error"
msgstr "Lỗi kích hoạt plugin"

msgid "Invalid import payload."
msgstr "Tải trọng nhập không hợp lệ."

msgid "Missing settings key in import payload."
msgstr "Thiếu khóa cài đặt trong tải trọng nhập."

msgid "Only network administrators can change uninstall preferences."
msgstr "Chỉ quản trị viên mạng mới có thể thay đổi tùy chọn gỡ cài đặt."

msgid "Invalid uninstall preferences payload."
msgstr "Tải trọng tùy chọn gỡ cài đặt không hợp lệ."

#: build/admin/airygen-app.js
msgid "Export or import all plugin settings, and configure what data is removed when the plugin is uninstalled."
msgstr "Xuất hoặc nhập tất cả cài đặt plugin và cấu hình dữ liệu nào sẽ bị xóa khi gỡ cài đặt."

#: build/admin/airygen-app.js
msgid "Export settings"
msgstr "Xuất cài đặt"

#: build/admin/airygen-app.js
msgid "Download a JSON snapshot of all your current settings. Use this to back up your configuration or transfer it to another site."
msgstr "Tải xuống ảnh chụp nhanh JSON của tất cả các cài đặt hiện tại của bạn. Dùng để sao lưu cấu hình hoặc chuyển sang trang web khác."

#: build/admin/airygen-app.js
msgid "Exporting…"
msgstr "Đang xuất…"

#: build/admin/airygen-app.js
msgid "Export"
msgstr "Xuất"

#: build/admin/airygen-app.js
msgid "Import settings"
msgstr "Nhập cài đặt"

#: build/admin/airygen-app.js
msgid "Upload a JSON file exported from Airygen SEO to restore or copy your settings. Existing settings will be overwritten."
msgstr "Tải lên tệp JSON được xuất từ Airygen SEO để khôi phục hoặc sao chép cài đặt của bạn. Các cài đặt hiện có sẽ bị ghi đè."

#: build/admin/airygen-app.js
msgid "Settings imported successfully."
msgstr "Đã nhập cài đặt thành công."

#: build/admin/airygen-app.js
msgid "Import failed. Please check the file and try again."
msgstr "Nhập không thành công. Vui lòng kiểm tra tệp và thử lại."

#: build/admin/airygen-app.js
msgid "An unexpected error occurred."
msgstr "Đã xảy ra lỗi không mong muốn."

#: build/admin/airygen-app.js
msgid "Uninstall"
msgstr "Gỡ cài đặt"

#: build/admin/airygen-app.js
msgid "Choose what data is permanently removed when the plugin is deleted. These actions only run on full uninstall, not on deactivation."
msgstr "Chọn dữ liệu nào sẽ bị xóa vĩnh viễn khi gỡ cài đặt plugin. Các thao tác này chỉ chạy khi gỡ cài đặt hoàn toàn, không phải khi tắt."

#: build/admin/airygen-app.js
msgid "Remove all custom database tables"
msgstr "Xóa tất cả các bảng cơ sở dữ liệu tùy chỉnh"

#: build/admin/airygen-app.js
msgid "Remove all plugin settings (wp_options)"
msgstr "Xóa tất cả cài đặt plugin (wp_options)"

#: build/admin/airygen-app.js
msgid "Remove all post, term, and user metadata"
msgstr "Xóa tất cả siêu dữ liệu bài viết, phân loại và người dùng"

#: build/admin/airygen-app.js
msgid "Preferences saved."
msgstr "Đã lưu tùy chọn."

#: build/admin/airygen-app.js
msgid "Failed to save preferences."
msgstr "Không thể lưu tùy chọn."

#. translators: %s is the required link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "%s is the link placeholder and must appear exactly once."
msgstr "%s là phần giữ chỗ cho liên kết và phải xuất hiện đúng một lần."

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "Shown above the main series links. Do not include %s in this description."
msgstr "Hiển thị phía trên các liên kết chuỗi chính. Không bao gồm %s trong mô tả này."

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L3 relation link description must contain exactly one %s."
msgstr "Mô tả liên kết quan hệ L3 phải chứa đúng một %s."

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L2 relation link description must contain exactly one %s."
msgstr "Mô tả liên kết quan hệ L2 phải chứa đúng một %s."

#. translators: %s is the link placeholder token.
#: build/admin/airygen-app.js
#, js-format
msgid "L1 relation link description must not contain %s."
msgstr "Mô tả liên kết quan hệ L1 không được chứa %s."

#: build/admin/airygen-app.js
msgid "Relation link descriptions"
msgstr "Mô tả liên kết quan hệ"

#: build/admin/airygen-app.js
msgid "Customize the descriptions shown before related Topic Cluster links in L1, L2, and L3 articles."
msgstr "Tùy chỉnh các mô tả hiển thị trước các liên kết Cụm chủ đề liên quan trong các bài viết L1, L2 và L3."

#: build/admin/airygen-app.js
msgid "Does your website represent a business with a physical location?"
msgstr "Trang web của bạn có đại diện cho một doanh nghiệp có địa điểm thực tế không?"

#: build/admin/airygen-app.js
msgid "For example, a restaurant, clinic, law firm, gym, or retail store."
msgstr "Ví dụ, nhà hàng, phòng khám, công ty luật, phòng tập gym hoặc cửa hàng bán lẻ."

#: build/admin/airygen-app.js
msgid "Adds LocalBusiness schema to your site so Google can show your address, phone number, and opening hours in local search results and Maps — making it easier for nearby customers to find you."
msgstr "Thêm schema LocalBusiness vào trang web của bạn để Google có thể hiển thị địa chỉ, số điện thoại và giờ mở cửa trong kết quả tìm kiếm địa phương."

#: build/admin/airygen-app.js
msgid "Alongside local data, also outputs Organization and WebSite schema to help Google better understand your brand."
msgstr "Ngoài dữ liệu địa phương, còn xuất schema Organization và WebSite để giúp Google hiểu thương hiệu của bạn tốt hơn."

#: build/admin/airygen-app.js
msgid "Does your website sell products or services online?"
msgstr "Trang web của bạn có bán sản phẩm hoặc dịch vụ trực tuyến không?"

#: build/admin/airygen-app.js
msgid "For example, a WooCommerce store or any site with a shopping cart."
msgstr "Ví dụ, cửa hàng WooCommerce hoặc bất kỳ trang web nào có giỏ hàng."

#: build/admin/airygen-app.js
msgid "Automatically generates Product schema for every product page so Google can display price, stock status, and star ratings directly in search results."
msgstr "Tự động tạo schema Product cho mỗi trang sản phẩm để Google có thể hiển thị giá, tình trạng kho và đánh giá sao trong kết quả tìm kiếm."

#: build/admin/airygen-app.js
msgid "Adds site-level Organization schema to help Google identify your brand and store."
msgstr "Thêm schema Organization cấp trang web để giúp Google nhận dạng thương hiệu và cửa hàng của bạn."

#: build/admin/airygen-app.js
msgid "Does your site have multiple language versions or serve users in different countries?"
msgstr "Trang web của bạn có nhiều phiên bản ngôn ngữ hoặc phục vụ người dùng ở các quốc gia khác nhau không?"

#: build/admin/airygen-app.js
msgid "For example, separate English and Spanish versions, or different URLs targeting different regions."
msgstr "Ví dụ, các phiên bản tiếng Anh và tiếng Tây Ban Nha riêng biệt, hoặc các URL khác nhau nhắm đến các khu vực khác nhau."

#: build/admin/airygen-app.js
msgid "Hreflang"
msgstr "Hreflang"

#: build/admin/airygen-app.js
msgid "Automatically adds hreflang tags to every page so Google serves the right language version to the right audience, preventing different variants from competing with each other in search rankings."
msgstr "Tự động thêm thẻ hreflang vào mỗi trang để Google phục vụ đúng phiên bản ngôn ngữ cho đúng đối tượng."

#: build/admin/airygen-app.js
msgid "Do you want links to your site to display a rich preview when shared on social media?"
msgstr "Bạn có muốn các liên kết đến trang web của mình hiển thị bản xem trước phong phú khi được chia sẻ trên mạng xã hội không?"

#: build/admin/airygen-app.js
msgid "Social Cards"
msgstr "Thẻ Mạng xã hội"

#: build/admin/airygen-app.js
msgid "Automatically generates Open Graph and Twitter Card meta tags for every post so shared links display your chosen image and title instead of letting platforms pick a random one."
msgstr "Tự động tạo thẻ meta Open Graph và Twitter Card cho mỗi bài đăng để các liên kết được chia sẻ hiển thị hình ảnh và tiêu đề bạn chọn."

#: build/admin/airygen-app.js
msgid "Does your site publish long-form articles, tutorials, or in-depth knowledge content?"
msgstr "Trang web của bạn có đăng các bài viết dài, hướng dẫn hoặc nội dung kiến thức chuyên sâu không?"

#: build/admin/airygen-app.js
msgid "For example, a blog, technical documentation site, or educational platform."
msgstr "Ví dụ, một blog, trang tài liệu kỹ thuật hoặc nền tảng giáo dục."

#: build/admin/airygen-app.js
msgid "Automatically generates a table of contents at the top of long posts so readers can jump straight to any section. Google sometimes surfaces TOC links directly in search results."
msgstr "Tự động tạo mục lục ở đầu các bài đăng dài để độc giả có thể chuyển thẳng đến bất kỳ phần nào."

#: build/admin/airygen-app.js
msgid "Recommends related posts at the bottom of each article based on categories and tags, keeping readers engaged and reducing bounce rate."
msgstr "Gợi ý các bài đăng liên quan ở cuối mỗi bài viết dựa trên danh mục và thẻ."

#: build/admin/airygen-app.js
msgid "Helps you manage a topic cluster structure (pillar → cluster → supporting articles) and automatically renders a topic navigation block within posts, making it easy for readers to explore related content while signaling topical depth to Google."
msgstr "Giúp bạn quản lý cấu trúc cụm chủ đề và tự động hiển thị khối điều hướng chủ đề trong các bài đăng."

#: build/admin/airygen-app.js
msgid "Does your site have multiple authors or use many categories and tags to organize content?"
msgstr "Trang web của bạn có nhiều tác giả hoặc sử dụng nhiều danh mục và thẻ để tổ chức nội dung không?"

#: build/admin/airygen-app.js
msgid "Generates Person schema for every author page to establish authorship identity and strengthen the E-E-A-T signals Google increasingly factors into rankings."
msgstr "Tạo schema Person cho mỗi trang tác giả để thiết lập danh tính tác giả và củng cố các tín hiệu E-E-A-T."

#: build/admin/airygen-app.js
msgid "Lets you customize meta titles and descriptions for taxonomy archive pages and control which ones Google should index, preventing SEO authority from being diluted across low-value pages."
msgstr "Cho phép bạn tùy chỉnh tiêu đề meta và mô tả cho các trang lưu trữ phân loại và kiểm soát trang nào Google nên lập chỉ mục."

#: build/admin/airygen-app.js
msgid "Has your site ever changed its URL structure, or do you know some links lead to 404 pages?"
msgstr "Trang web của bạn đã từng thay đổi cấu trúc URL chưa, hoặc bạn có biết một số liên kết dẫn đến trang 404 không?"

#: build/admin/airygen-app.js
msgid "Set up 301/302 redirects to seamlessly transfer traffic and SEO ranking power from old URLs to new ones so your hard-earned rankings are never lost."
msgstr "Thiết lập chuyển hướng 301/302 để chuyển lưu lượng truy cập và sức mạnh xếp hạng SEO từ URL cũ sang URL mới."

#: build/admin/airygen-app.js
msgid "404 Manager"
msgstr "Quản lý 404"

#: build/admin/airygen-app.js
msgid "Automatically logs every 404 visit so you can see at a glance which broken links need fixing, and set up redirects directly from the interface."
msgstr "Tự động ghi lại mỗi lần truy cập 404 để bạn có thể nhìn thấy ngay những liên kết nào bị hỏng cần sửa."

#: build/admin/airygen-app.js
msgid "Actively crawls your entire site to surface all broken internal and external links before Google finds them and uses them against your rankings."
msgstr "Chủ động thu thập toàn bộ trang web của bạn để tìm tất cả các liên kết bị hỏng trước khi Google tìm thấy chúng."

#: build/admin/airygen-app.js
msgid "Would you like search engines to index your new and updated content immediately after publishing?"
msgstr "Bạn có muốn các công cụ tìm kiếm lập chỉ mục nội dung mới của bạn ngay sau khi xuất bản không?"

#: build/admin/airygen-app.js
msgid "Uses the IndexNow protocol to push new and updated URLs to Bing and other supported search engines the moment content is published or changed — no waiting for crawlers. Especially valuable for news sites and time-sensitive content."
msgstr "Sử dụng giao thức IndexNow để đẩy URL mới đến Bing ngay khi nội dung được xuất bản."

#: build/admin/airygen-app.js
msgid "Would you like AI to help you write article outlines, FAQ sets, or plan your full content strategy?"
msgstr "Bạn có muốn AI giúp bạn viết phác thảo bài viết, bộ FAQ hoặc lên kế hoạch cho chiến lược nội dung không?"

#: build/admin/airygen-app.js
msgid "A smart AI toolkit that generates article outlines, Content Blueprints, full Article drafts, and Deep FAQ sets from a keyword — making content creation faster and easier."
msgstr "Bộ công cụ AI thông minh tạo phác thảo bài viết, Bản thiết kế Nội dung, bản nháp bài viết hoàn chỉnh và bộ Deep FAQ từ một từ khóa."

#: build/admin/airygen-app.js
msgid "Would you like AI tools like ChatGPT and Perplexity to more easily discover and cite your site?"
msgstr "Bạn có muốn các công cụ AI như ChatGPT và Perplexity dễ dàng khám phá và trích dẫn trang web của bạn hơn không?"

#: build/admin/airygen-app.js
msgid "AI search is changing how people find information — make sure your site is visible in the AI era."
msgstr "Tìm kiếm AI đang thay đổi cách mọi người tìm kiếm thông tin — hãy đảm bảo trang web của bạn hiển thị trong kỷ nguyên AI."

#: build/admin/airygen-app.js
msgid "Automatically generates an llms.txt file — like a sitemap for AI — so tools like ChatGPT and Perplexity know what content on your site is available to cite."
msgstr "Tự động tạo tệp llms.txt — như sitemap cho AI — để các công cụ như ChatGPT và Perplexity biết nội dung nào trên trang web của bạn có thể trích dẫn."

#: build/admin/airygen-app.js
msgid "Automatically converts your posts into AI-friendly Markdown so AI agents can read and understand your content without struggling to parse HTML."
msgstr "Tự động chuyển đổi bài viết của bạn sang Markdown thân thiện với AI để các tác nhân AI có thể đọc và hiểu nội dung của bạn."

#: build/admin/airygen-app.js
msgid "Includes Deep FAQ, which automatically generates structured Q&A from your post content. AI search engines favor content that directly answers questions, boosting your visibility in AI-powered search results."
msgstr "Bao gồm Deep FAQ, tự động tạo Q&A có cấu trúc từ nội dung bài đăng của bạn."

#: build/admin/airygen-app.js
msgid "Free"
msgstr "Miễn phí"

#: build/admin/airygen-app.js
msgid "Requires a plan upgrade"
msgstr "Yêu cầu nâng cấp gói"

#: build/admin/airygen-app.js
msgid "Requires"
msgstr "Yêu cầu"

#: build/admin/airygen-app.js
msgid "plan to activate"
msgstr "gói để kích hoạt"

