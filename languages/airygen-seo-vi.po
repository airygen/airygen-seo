msgstr "Tiện ích mở rộng"

#: build/admin/airygen-app.js
msgid "Extension selections override the base llms.txt selections when used."
msgstr "Lựa chọn tiện ích mở rộng ghi đè lựa chọn llms.txt cơ sở khi được sử dụng."

#: build/admin/airygen-app.js
msgid "Configure extension basics before arranging selection overrides."
msgstr "Cấu hình cơ bản tiện ích mở rộng trước khi sắp xếp ghi đè lựa chọn."

#: build/admin/airygen-app.js
msgid "Used as the H1 title for this extension output."
msgstr "Dùng làm tiêu đề H1 cho đầu ra tiện ích mở rộng này."

#: build/admin/airygen-app.js
