[
  {
    "type": "admin",
    "name": "topic-cluster-overview",
    "path": "admin.php?page=airygen-topic-cluster",
    "waitFor": "#airygen-root",
    "views": [
      {
        "name": "settings",
        "click": "[data-airygen-e2e='tab-settings']",
        "waitAfterClick": 3000
      },
      {
        "name": "groups",
        "click": "[data-airygen-e2e='tab-groups']",
        "waitAfterClick": 3000
      },
      {
        "name": "mindmap",
        "click": "[data-airygen-e2e='tab-groups']",
        "waitAfterClick": 3000,
        "clicks": [
          {
            "selector": "[data-airygen-e2e='topic-cluster-launch-group-2']",
            "wait": 2000
          },
          {
            "selector": "[data-airygen-e2e='tab-mindmap']",
            "wait": 1200
          },
          {
            "selector": "[data-airygen-e2e='topic-cluster-zoom-out']",
            "wait": 400
          },
          {
            "selector": "[data-airygen-e2e='topic-cluster-zoom-out']",
            "wait": 800
          }
        ],
        "waitFor": "[data-airygen-e2e='topic-cluster-mindmap']",
        "drags": [
          {
            "source": "[data-airygen-e2e='topic-cluster-canvas']",
            "deltaX": -220,
            "deltaY": -90,
            "wait": 2000
          }
        ]
      }
    ]
  },
  {
    "type": "editor",
    "name": "topic-cluster-editor",
    "path": "post.php?post={POST_ID}&action=edit",
    "waitFor": ".editor-post-title",
    "views": [
      {
        "name": "editor",
        "clicks": [
          {
            "selector": "button[aria-controls='airygen-seo-sidebar:airygen-seo-sidebar']",
            "wait": 2000
          },
          {
            "selector": "[data-airygen-e2e='editor-panel-topicCluster'] .components-panel__body-toggle",
            "wait": 400
          }
        ]
      }
    ]
  }
]
