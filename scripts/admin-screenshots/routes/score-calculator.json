[
  {
    "name": "score-calculator-settings",
    "path": "admin.php?page=airygen-settings#settings/scoreCalculator",
    "waitFor": "#airygen-root",
    "views": [
      {
        "name": "settings"
      },
      {
        "name": "ruleWeights",
        "waitAfterClick": 400,
        "click": "[data-airygen-e2e='tab-rules']"
      },
      {
        "name": "customRules",
        "waitAfterClick": 400,
        "click": "[data-airygen-e2e='tab-custom']"
      }
    ],
    "type": "admin"
  },
  {
    "name": "score-calculator-editor",
    "path": "post.php?post={POST_ID}&action=edit",
    "waitFor": ".editor-post-title",
    "views": [
      {
        "name": "editor",
        "clicks": [
          {
            "selector": "button[aria-controls='airygen-seo-sidebar:airygen-seo-sidebar']",
            "wait": 2000
          },
          {
            "selector": "[data-airygen-e2e='editor-panel-scoreCalculator'] .components-panel__body-toggle",
            "wait": 5000
          },
          {
            "selector": "[data-airygen-e2e='classic-tab-score']",
            "wait": 5000
          },
          {
            "selector": "[data-airygen-e2e='score-show-tips']",
            "wait": 3000
          },
          {
            "selector": "[data-airygen-e2e='score-show-tips']",
            "wait": 3000
          }
        ]
      }
    ],
    "type": "editor"
  }
]
