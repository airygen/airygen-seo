{
  "name": "airygen",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:block-editor": "wp-scripts start block-editor=./packages/block-editor/src/index.tsx --output-path=build/block-editor --output-filename=airygen-editor.js",
    "dev:classic-editor": "wp-scripts start classic-editor=./packages/classic-editor/src/index.tsx --output-path=build/classic-editor --output-filename=airygen-editor.js",
    "dev:admin": "wp-scripts start ./packages/admin/app.tsx --output-path=build/admin --output-filename=airygen-app.js",
    "build": "wp-scripts build block-editor=./packages/block-editor/src/index.tsx --output-path=build/block-editor --output-filename=airygen-editor.js && wp-scripts build classic-editor=./packages/classic-editor/src/index.tsx --output-path=build/classic-editor --output-filename=airygen-editor.js && wp-scripts build ./packages/admin/app.tsx --output-path=build/admin --output-filename=airygen-app.js",
    "typecheck": "tsc --noEmit",
    "record:admin": "node scripts/admin-screenshots/record.mjs",
    "record:admin:headed": "AIRYGEN_CAPTURE_HEADLESS=0 node scripts/admin-screenshots/record.mjs"
  },
  "browserslist": [
    "> 1%",
    "last 1 Android versions",
    "last 1 ChromeAndroid versions",
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 Edge versions",
    "last 2 Opera versions"
  ],
  "devDependencies": {
    "@types/react": "18.3.3",
    "@types/wordpress__blocks": "^12.5.18",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@wordpress/api-fetch": "^7.34.0",
    "@wordpress/block-editor": "^15.8.0",
    "@wordpress/blocks": "^15.9.0",
    "@wordpress/components": "^30.7.0",
    "@wordpress/core-data": "^7.35.0",
    "@wordpress/data": "^10.34.0",
    "@wordpress/dom-ready": "^4.34.0",
    "@wordpress/edit-post": "^8.35.0",
    "@wordpress/editor": "^14.35.0",
    "@wordpress/element": "^6.34.0",
    "@wordpress/i18n": "^6.7.0",
    "@wordpress/plugins": "^7.35.0",
    "@wordpress/scripts": "^30.26.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "sass": "^1.94.0",
    "tailwindcss": "3.4.13",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "tinyld": "^1.3.4"
  }
}
